const VOICE_SCRIPTS=[
  {id:'intro',label:' Introduction',text:`Welcome to SteelGuard AI — a smart predictive maintenance system for steel plants. This dashboard shows you the health of a blast furnace in real time. Think of it like a doctor keeping an eye on a patient, but instead of a human, we are monitoring a giant furnace that runs at over 800 degrees Celsius! The goal is simple: catch problems before they happen, saving the plant from expensive breakdowns.`},
  {id:'problem',label:' The Problem',text:`Here is the real-world problem this solves. Imagine a steel plant is running at full capacity. Suddenly, a bearing in the rolling mill fails. The entire production line stops. Every hour of downtime can cost 10 to 50 lakh rupees. Traditional maintenance means either checking machines too early — which wastes money — or too late — when the machine has already broken. Our system predicts failures 24 to 72 hours in advance, giving engineers time to fix it before disaster strikes.`},
  {id:'sensors',label:' The Sensors',text:`We use 6 sensors, all connected to a tiny ESP32 microcontroller that costs around 300 rupees. First, a K-Type Thermocouple measures the furnace temperature up to 1250 degrees. Second, an ADXL345 accelerometer detects vibration — when a bearing is failing, the machine starts shaking more than usual. Third, an ACS712 sensor measures electric current — a motor drawing too much or too little current is a warning sign. Fourth, BMP280 monitors pressure. Fifth, MQ-2 detects toxic gases. And sixth, DS18B20 measures the ambient temperature.`},
  {id:'twin',label:' Motor Digital Twin',text:`The Motor Digital Twin is the live simulation engine. It models a 3-phase induction motor with real physics — temperature ramp, vibration signatures, RPM drop, and current surge. You can inject faults like bearing wear, rotor imbalance, phase loss, or cooling failure. Watch the arc gauges react and the motor anatomy highlight exactly which components are affected in real time. This demonstrates how a digital twin bridges the gap between physical hardware and software intelligence.`},
  {id:'cost',label:' Cost & Impact',text:`The entire hardware setup costs only around 6 thousand 700 rupees — less than a single hour of downtime in a real steel plant. Our system detected anomalies with 97.3 percent accuracy in testing. The mean time between failures improved from 200 hours to 342 hours. And the estimated cost saved this month alone is 4.2 lakh rupees in prevented downtime. For a hackathon project built with beginner-friendly components, this demonstrates a real, deployable, high-impact solution for the steel industry.`}
];
let voiceSynth=window.speechSynthesis,voiceUtter=null,voicePlaying=false,voiceCurrentIdx=0,voiceSpeed=1;
const speeds=[0.8,1,1.2,1.5];let speedIdx=1,voiceTimer=null,voiceElapsed=0,voiceEstDuration=0;
function buildVoiceSections(){const w=document.getElementById('voiceSections');if(!w)return;w.innerHTML=VOICE_SCRIPTS.map((s,i)=>`<button class="voice-section-btn${i===0?' active':''}" onclick="jumpVoice(${i})">${s.label}</button>`).join('');}
buildVoiceSections();
function setVoiceActive(idx){document.querySelectorAll('.voice-section-btn').forEach((b,i)=>b.classList.toggle('active',i===idx));}
function highlightText(text){const kw=['predictive','maintenance','anomaly','fault','vibration','temperature','current','pressure','ESP32','Raspberry Pi','MQTT','steel plant','digital twin'];let h=text;kw.forEach(k=>{const re=new RegExp('\\b('+k.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+'s?)\\b','gi');h=h.replace(re,'<span class="voice-highlight">$1</span>');});return h;}
function fmtTime(s){return`${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`;}
function speakScript(idx){if(voiceUtter)voiceSynth.cancel();clearInterval(voiceTimer);voiceCurrentIdx=idx;setVoiceActive(idx);const sc=VOICE_SCRIPTS[idx];const td=document.getElementById('voiceTextDisplay');if(td)td.innerHTML=`<em style="color:var(--text);font-size:0.75rem;">Now playing:</em> ${highlightText(sc.text)}`;voiceUtter=new SpeechSynthesisUtterance(sc.text);voiceUtter.rate=voiceSpeed;voiceUtter.pitch=1.05;voiceUtter.volume=1;voiceEstDuration=Math.ceil(sc.text.split(' ').length/(voiceSpeed*2.5));voiceElapsed=0;const vd=document.getElementById('voiceDuration');if(vd)vd.textContent=fmtTime(voiceEstDuration);voiceUtter.onend=()=>{clearInterval(voiceTimer);voicePlaying=false;const pb=document.getElementById('voicePlayBtn');if(pb)pb.textContent='';const vp=document.getElementById('voiceProgress');if(vp)vp.style.width='100%';if(voiceCurrentIdx<VOICE_SCRIPTS.length-1)setTimeout(()=>{if(!voicePlaying)speakScript(voiceCurrentIdx+1);},800);};voiceSynth.speak(voiceUtter);voicePlaying=true;const pb=document.getElementById('voicePlayBtn');if(pb)pb.textContent='';voiceTimer=setInterval(()=>{voiceElapsed=Math.min(voiceElapsed+1,voiceEstDuration);const pct=voiceEstDuration>0?(voiceElapsed/voiceEstDuration*100):0;const vp=document.getElementById('voiceProgress');if(vp)vp.style.width=pct+'%';const vt=document.getElementById('voiceTime');if(vt)vt.textContent=fmtTime(voiceElapsed);},1000);}
function toggleVoice(){if(voicePlaying){voiceSynth.pause();clearInterval(voiceTimer);voicePlaying=false;const pb=document.getElementById('voicePlayBtn');if(pb)pb.textContent='';}else{if(voiceSynth.paused){voiceSynth.resume();voicePlaying=true;const pb=document.getElementById('voicePlayBtn');if(pb)pb.textContent='';voiceTimer=setInterval(()=>{voiceElapsed=Math.min(voiceElapsed+1,voiceEstDuration);const pct=voiceEstDuration>0?(voiceElapsed/voiceEstDuration*100):0;const vp=document.getElementById('voiceProgress');if(vp)vp.style.width=pct+'%';const vt=document.getElementById('voiceTime');if(vt)vt.textContent=fmtTime(voiceElapsed);},1000);}else{speakScript(voiceCurrentIdx);}}}
function restartVoice(){voicePlaying=false;speakScript(voiceCurrentIdx);}
function jumpVoice(idx){voicePlaying=false;speakScript(idx);}
function cycleSpeed(){speedIdx=(speedIdx+1)%speeds.length;voiceSpeed=speeds[speedIdx];const sb=document.getElementById('voiceSpeedBtn');if(sb)sb.textContent=voiceSpeed+'×';if(voicePlaying){voicePlaying=false;speakScript(voiceCurrentIdx);}}
function seekVoice(e){const rect=e.currentTarget.getBoundingClientRect();const pct=(e.clientX-rect.left)/rect.width;voiceElapsed=Math.floor(pct*voiceEstDuration);const vp=document.getElementById('voiceProgress');if(vp)vp.style.width=(pct*100)+'%';}

/* 
   ARC GAUGE RENDERER  (from JARVIS)
 */
function drawGauge(canvasId,opts){
  const canvas=document.getElementById(canvasId);
  if(!canvas)return;
  const rect=canvas.getBoundingClientRect();
  const W=canvas.width&&canvas.width>10?canvas.width:(rect.width>10?Math.round(rect.width):(canvas.offsetWidth||180));
  const H=canvas.height||170;
  if(canvas.width!==W&&W>10)canvas.width=W;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const{value,max,warn,alarm,color,label,unit}=opts;
  const cx=W/2,cy=H*0.48,R=Math.min(W,H)*0.38,p=Math.min(1,Math.max(0,value/max));
  let accentCol=color;
  const isAlarm=alarm&&value>=alarm,isWarn=!isAlarm&&warn&&value>=warn;
  if(isAlarm)accentCol='#f87171';else if(isWarn)accentCol='#fbbf24';
  const START=Math.PI*0.75,SWEEP=Math.PI*1.5;
  // Tick ring
  for(let i=0;i<=60;i++){const frac=i/60,ang=START+SWEEP*frac,isLong=i%10===0,isMed=i%5===0,r1=R+5,r2=R+(isLong?16:isMed?11:7);let tCol;if(alarm&&frac>=alarm/max)tCol=`rgba(248,113,113,${isLong?0.8:0.4})`;else if(warn&&frac>=warn/max)tCol=`rgba(251,191,36,${isLong?0.7:0.35})`;else tCol=`rgba(43,144,217,${isLong?0.6:isMed?0.35:0.2})`;ctx.strokeStyle=tCol;ctx.lineWidth=isLong?2:1;ctx.beginPath();ctx.moveTo(cx+Math.cos(ang)*r1,cy+Math.sin(ang)*r1);ctx.lineTo(cx+Math.cos(ang)*r2,cy+Math.sin(ang)*r2);ctx.stroke();}
  // Arc track bg
  ctx.save();ctx.strokeStyle='rgba(255,255,255,0.06)';ctx.lineWidth=4;ctx.lineCap='round';ctx.beginPath();ctx.arc(cx,cy,R,START,START+SWEEP);ctx.stroke();ctx.restore();
  // Warn zone
  if(warn){const wF=warn/max,wS=START+SWEEP*wF,wE=alarm?START+SWEEP*(alarm/max):START+SWEEP;ctx.save();ctx.strokeStyle='rgba(251,191,36,0.18)';ctx.lineWidth=4;ctx.lineCap='round';ctx.beginPath();ctx.arc(cx,cy,R,wS,wE);ctx.stroke();ctx.restore();}
  // Alarm zone
  if(alarm){const aF=alarm/max;ctx.save();ctx.strokeStyle='rgba(248,113,113,0.18)';ctx.lineWidth=4;ctx.lineCap='round';ctx.beginPath();ctx.arc(cx,cy,R,START+SWEEP*aF,START+SWEEP);ctx.stroke();ctx.restore();}
  // Value arc
  if(p>0.005){ctx.save();ctx.strokeStyle=accentCol;ctx.lineWidth=4;ctx.lineCap='round';ctx.shadowColor=accentCol;ctx.shadowBlur=12;ctx.beginPath();ctx.arc(cx,cy,R,START,START+SWEEP*p);ctx.stroke();ctx.lineWidth=1.5;ctx.shadowBlur=18;ctx.globalAlpha=0.45;ctx.beginPath();ctx.arc(cx,cy,R+2,START,START+SWEEP*p);ctx.stroke();ctx.restore();
  // Glowing tip
  const tA=START+SWEEP*p;ctx.save();ctx.shadowColor=accentCol;ctx.shadowBlur=20;ctx.fillStyle='#ffffff';ctx.beginPath();ctx.arc(cx+Math.cos(tA)*R,cy+Math.sin(tA)*R,4,0,Math.PI*2);ctx.fill();ctx.shadowBlur=8;ctx.fillStyle=accentCol;ctx.beginPath();ctx.arc(cx+Math.cos(tA)*R,cy+Math.sin(tA)*R,2.5,0,Math.PI*2);ctx.fill();ctx.restore();}
  // Inner deco rings
  [R*0.72,R*0.52].forEach((r,i)=>{ctx.save();ctx.strokeStyle=`rgba(43,144,217,${0.06+i*0.03})`;ctx.lineWidth=0.7;ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.stroke();ctx.restore();});
  // Value text
  const dv=value>=1000?Math.round(value).toString():value>=100?value.toFixed(0):value>=10?value.toFixed(1):value.toFixed(2);
  ctx.save();ctx.font=`bold ${value>=1000?22:26}px Inter,sans-serif`;ctx.fillStyle=accentCol;ctx.textAlign='center';ctx.shadowColor=accentCol;ctx.shadowBlur=12;ctx.fillText(dv,cx,cy+9);ctx.restore();
  ctx.save();ctx.font='9px Inter,sans-serif';ctx.fillStyle='rgba(150,190,210,0.5)';ctx.textAlign='center';ctx.fillText(unit,cx,cy+24);ctx.restore();
  ctx.save();ctx.font='700 8px Inter,sans-serif';ctx.fillStyle='rgba(43,144,217,0.45)';ctx.textAlign='center';ctx.fillText(label.toUpperCase(),cx,H-12);ctx.restore();
  // HUD corner brackets
  const bS=8,bP=5;ctx.save();ctx.strokeStyle='rgba(43,144,217,0.22)';ctx.lineWidth=1;[[bP,bP,1,1],[W-bP,bP,-1,1],[bP,H-bP,1,-1],[W-bP,H-bP,-1,-1]].forEach(([x,y,dx,dy])=>{ctx.beginPath();ctx.moveTo(x+dx*bS,y);ctx.lineTo(x,y);ctx.lineTo(x,y+dy*bS);ctx.stroke();});ctx.restore();
  // Spin arc
  const now=performance.now()/1000;ctx.save();ctx.strokeStyle='rgba(43,144,217,0.2)';ctx.lineWidth=1.5;const ss=now*1.5;ctx.beginPath();ctx.arc(cx,cy,R*0.62,ss,ss+Math.PI*0.6);ctx.stroke();ctx.restore();
}

/* 
   MOTOR SIMULATOR CORE  (from JARVIS)
 */
let twinStep=0,twinMode='normal',faultType='none',faultSeverity=0.9,faultOnset=-1;
let tempState=45,twinAlertCount=0,peakTemp=45,peakVib=0.3,tickInterval=700,tickTimer=null;
let lastTwinReading=null; // caches last reading so tab-switches can redraw with live values
const twinBuffers={temp:[],vib:[],cur:[]};

const faultEffects={
  bearing_wear:{temp:25,vibMul:4.5,rpm:-80,cur:1.2},
  overload:{temp:35,vibMul:1.3,rpm:-120,cur:3.8},
  rotor_imbalance:{temp:10,vibMul:7.0,rpm:-20,cur:0.6},
  phase_loss:{temp:20,vibMul:2.0,rpm:-300,cur:5.0},
  cooling_failure:{temp:45,vibMul:1.1,rpm:-10,cur:0.3},
};
const faultDescs={
  bearing_wear:'Progressive bearing wear — elevated vibration, thermal buildup, slight RPM loss.',
  overload:'Motor beyond rated load — high current draw, temperature spike, RPM reduction.',
  rotor_imbalance:'Uneven rotor mass — extreme vibration signature, minimal thermal impact.',
  phase_loss:'Single phase lost — severe RPM drop, overcurrent on remaining phases.',
  cooling_failure:'Cooling system failed — extreme temperature rise, minimal other effects.',
};

function sigmoid(x){return 1/(1+Math.exp(-10*(x-0.5)));}
function randn(s){let u=0,v=0;while(!u)u=Math.random();while(!v)v=Math.random();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v)*s;}
function getNoise(){return parseFloat(document.getElementById('cfg-noise-temp')?.value)||0.30;}
function getAlarmT(){return parseFloat(document.getElementById('cfg-alarm-temp')?.value)||80;}
function getAlarmV(){return parseFloat(document.getElementById('cfg-alarm-vib')?.value)||1.5;}
function getRamp(){return parseFloat(document.getElementById('cfg-ramp')?.value)||80;}

function getTwinReading(){
  twinStep++;
  let rT,rV,rR,rC,rP;
  if(customInjActive){
    // Use noise-buffered injected values; fall back to baseline if that param is OFF
    rT = getInjVal('temp') ?? 45;
    rV = getInjVal('vib')  ?? 0.30;
    rR = 1500;
    rC = getInjVal('cur')  ?? 4.2;
    rP = getInjVal('pres') ?? 1013;
  } else {
    let fx={temp:0,vibMul:1,rpm:0,cur:0};
    if(faultType!=='none'&&faultOnset>=0){
      const eff=faultEffects[faultType]||{};
      const prog=Math.min(1,(twinStep-faultOnset)/getRamp());
      const s=sigmoid(prog)*faultSeverity;
      fx.temp=(eff.temp||0)*s;fx.vibMul=1+((eff.vibMul||1)-1)*s;fx.rpm=(eff.rpm||0)*s;fx.cur=(eff.cur||0)*s;
    }
    if(twinMode==='normal'){rT=45;rV=0.30;rR=1500;rC=4.2;rP=1013;}
    else if(twinMode==='degrading'||twinMode==='fault'){
      tempState+=(1/300)*(45+fx.temp-tempState);
      rT=tempState;rV=0.30*fx.vibMul;rR=1500+fx.rpm;rC=4.2+fx.cur;rP=1013;
    } else if(twinMode==='recovering'){
      tempState+=(1/210)*(45-tempState);
      rT=tempState;rV=0.30;rR=1500*Math.min(1,(twinStep%300)/200);rC=4.2*Math.min(1,(twinStep%300)/200);rP=1013;
    } else {rT=45;rV=0.30;rR=1500;rC=4.2;rP=1013;}
  }
  // Dynamic clamps: when injection is active allow values up to 3× their threshold
  // so injected values above nominal threshold are never wrongly cut off
  const tMax = customInjActive ? Math.max(200, getThreshTemp() * 3) : 150;
  const vMax = customInjActive ? Math.max(20,  getThreshVib()  * 3) : 20;
  const cMax = customInjActive ? Math.max(20,  getThreshCur()  * 3) : 20;
  const pMax = customInjActive ? Math.max(3000,getThreshPres() * 3) : 3000;
  // When injection is active, do NOT add extra noise — the injected buffer value IS the value
  const noiseScale = customInjActive ? 0 : 1;
  const temp    =Math.max(20, Math.min(tMax, rT+randn(getNoise()*noiseScale)));
  const vib     =Math.max(0,  Math.min(vMax, rV+randn(0.015*noiseScale)));
  const rpm     =Math.max(0,  Math.min(3000, rR+randn(8*noiseScale)));
  const current =Math.max(0,  Math.min(cMax, rC+randn(0.08*noiseScale)));
  const pressure=Math.max(200,Math.min(pMax, rP+randn(1.5*noiseScale)));
  if(temp>peakTemp)peakTemp=temp;if(vib>peakVib)peakVib=vib;
  const aT=getAlarmT(),aV=getAlarmV();
  const aP=getThreshPres();
  const tA=temp>aT,vA=vib>aV,pA=pressure>aP*1.05||pressure<aP*0.92;
  const anomaly=tA||vA||pA||customInjActive||(faultType!=='none'&&twinStep-faultOnset>30);
  const hint=anomaly?'anomaly':(twinMode==='degrading'?'warning':'normal');
  return{temp,vib,rpm,current,pressure,anomaly_hint:hint,tempAlarm:tA,vibAlarm:vA,presAlarm:pA};
}

function updateTwinCards(r){
  const aT=getAlarmT(),aV=getAlarmV();
  drawGauge('gauge-temp',{value:r.temp,max:100,warn:aT*0.82,alarm:aT,color:'#f87171',label:'Temperature',unit:'°C'});
  drawGauge('gauge-vib',{value:r.vib,max:2,warn:aV*0.55,alarm:aV,color:'#4da6e8',label:'Vibration',unit:'g'});
  drawGauge('gauge-cur',{value:r.current,max:12,warn:7.5,alarm:10,color:'#34d399',label:'Current',unit:'A'});
  const setCard=(id,alarm,warn)=>{const el=document.getElementById(id);if(!el)return;el.classList.toggle('alarm',alarm);el.classList.toggle('warning',warn&&!alarm);};
  setCard('card-temp',r.tempAlarm,r.temp>aT*0.8);
  setCard('card-vib',r.vibAlarm,r.vib>aV*0.55);
  setCard('card-cur',r.current>10,r.current>7.5);
  // Stats
  const set=(id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v;};
  set('ana-steps',twinStep);
  set('ana-anomalies',twinAlertCount);
  set('ana-peak-temp',peakTemp.toFixed(1));
  set('ana-peak-vib',peakVib.toFixed(3));
  const bp=document.getElementById('bar-steps');if(bp)bp.style.width=Math.min(100,twinStep/10)+'%';
  const ba=document.getElementById('bar-anomalies');if(ba)ba.style.width=Math.min(100,twinAlertCount*2)+'%';
  const bt=document.getElementById('bar-peak-temp');if(bt)bt.style.width=Math.min(100,(peakTemp/80)*100)+'%';
  const bv=document.getElementById('bar-peak-vib');if(bv)bv.style.width=Math.min(100,(peakVib/1.5)*100)+'%';
  // Inject tab
  const af=faultType!=='none'?faultType.replace(/_/g,' ').toUpperCase():'NONE';
  set('active-fault-display',af);
  const afd=document.getElementById('active-fault-since');
  if(afd)afd.textContent=faultOnset>=0?`injected step ${faultOnset} · ${twinStep-faultOnset} ticks ago`:'—';
  // sim label
  const sl=document.getElementById('sim-mode-label');
  if(sl)sl.textContent='MODE: '+twinMode.toUpperCase()+(faultType!=='none'?' · '+faultType.replace(/_/g,' ').toUpperCase():'');
}

function addTwinAlert(r){
  if(r.anomaly_hint==='normal')return;
  twinAlertCount++;
  const aCount=document.getElementById('alert-count');if(aCount)aCount.textContent=twinAlertCount+' anomalies';
  const now=new Date().toTimeString().slice(0,8);
  const aT=getAlarmT(),aV=getAlarmV();
  const msg=r.tempAlarm?`TEMP CRITICAL ${r.temp.toFixed(1)}°C > ${aT}°C`:r.vibAlarm?`VIB HIGH ${r.vib.toFixed(3)}g > ${aV}g`:`ANOMALY · mode=${twinMode} · fault=${faultType}`;
  const col=r.anomaly_hint==='anomaly'?'var(--red)':r.anomaly_hint==='warning'?'var(--yellow)':'var(--green)';
  const row=document.createElement('div');
  row.className='alert-row '+(r.anomaly_hint==='anomaly'?'crit':'warn');
  row.innerHTML=`<span class="at">${now}</span><span style="color:${col};font-size:0.68rem;font-weight:700;min-width:72px;">${r.anomaly_hint.toUpperCase()}</span><span style="font-size:0.68rem;color:var(--muted);">${msg}</span>`;
  const list=document.getElementById('alert-list');
  if(list){list.insertBefore(row,list.firstChild);if(list.children.length>14)list.removeChild(list.lastChild);}
}

/* 
   TWIN CHARTS  (raw canvas, no Chart.js)
 */
let twinChartCanvas,twinChartCtx,twinTempCanvas,twinTempCtx,twinVCCanvas,twinVCCtx;

function initTwinCharts(){
  twinChartCanvas=document.getElementById('chart');
  twinTempCanvas=document.getElementById('chart-temp');
  twinVCCanvas=document.getElementById('chart-vib-cur');
  if(twinChartCanvas)twinChartCtx=twinChartCanvas.getContext('2d');
  if(twinTempCanvas)twinTempCtx=twinTempCanvas.getContext('2d');
  if(twinVCCanvas)twinVCCtx=twinVCCanvas.getContext('2d');
}
initTwinCharts();

function resizeTwinChartCanvases(){
  [twinChartCanvas,twinTempCanvas,twinVCCanvas].forEach(c=>{
    if(!c)return;
    c.width=c.offsetWidth||c.parentElement?.offsetWidth||600;
    c.height=c.offsetHeight||150;
  });
}

function pushTwinBuffer(key,val,min,max){
  twinBuffers[key].push((val-min)/(max-min));
  const maxBuf=parseInt(document.getElementById('cfg-buf')?.value)||300;
  if(twinBuffers[key].length>maxBuf)twinBuffers[key].shift();
}

function drawTwinGrid(ctx,cw,ch){
  ctx.save();ctx.strokeStyle='rgba(43,144,217,0.06)';ctx.lineWidth=0.5;
  for(let i=1;i<8;i++){const x=(i/8)*cw;ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,ch);ctx.stroke();}
  for(let i=0;i<=4;i++){const y=(i/4)*ch;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(cw,y);ctx.stroke();}
  for(let i=0;i<=4;i++){const y=(i/4)*ch;ctx.fillStyle='rgba(43,144,217,0.18)';ctx.font='7px Inter,sans-serif';ctx.textAlign='left';ctx.fillText(Math.round((1-i/4)*100)+'%',3,y+8);}
  ctx.restore();
}

function drawTwinLine(ctx,buf,color,cw,ch,n,glowR){
  if(buf.length<2)return;
  ctx.save();ctx.shadowColor=color;ctx.shadowBlur=glowR||6;ctx.strokeStyle=color;ctx.lineWidth=1.5;ctx.globalAlpha=0.9;ctx.lineCap='round';ctx.lineJoin='round';
  ctx.beginPath();
  buf.forEach((v,i)=>{const x=(i/(n-1))*cw,y=ch-v*ch*0.85-ch*0.05;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.stroke();
  ctx.globalAlpha=0.04;ctx.shadowBlur=0;ctx.lineTo(cw,ch);ctx.lineTo(0,ch);ctx.closePath();ctx.fillStyle=color;ctx.fill();
  ctx.restore();
}

function drawTwinChart(){
  if(twinChartCtx){
    const cw=twinChartCanvas.width,ch=twinChartCanvas.height;
    twinChartCtx.clearRect(0,0,cw,ch);drawTwinGrid(twinChartCtx,cw,ch);
    const n=twinBuffers.temp.length||1;
    drawTwinLine(twinChartCtx,twinBuffers.cur,'#34d399',cw,ch,n,4);
    drawTwinLine(twinChartCtx,twinBuffers.vib,'#4da6e8',cw,ch,n,5);
    drawTwinLine(twinChartCtx,twinBuffers.temp,'#f87171',cw,ch,n,6);
  }
  if(twinTempCtx){
    const tw=twinTempCanvas.width,th=twinTempCanvas.height;
    twinTempCtx.clearRect(0,0,tw,th);drawTwinGrid(twinTempCtx,tw,th);
    const n=twinBuffers.temp.length||1;
    drawTwinLine(twinTempCtx,twinBuffers.temp,'#f87171',tw,th,n,6);
    const aN=(getAlarmT()-20)/130;const ty=th-aN*th*0.85-th*0.05;
    twinTempCtx.save();twinTempCtx.strokeStyle='rgba(43,144,217,0.35)';twinTempCtx.lineWidth=1;twinTempCtx.setLineDash([6,4]);twinTempCtx.beginPath();twinTempCtx.moveTo(0,ty);twinTempCtx.lineTo(tw,ty);twinTempCtx.stroke();twinTempCtx.setLineDash([]);twinTempCtx.fillStyle='rgba(43,144,217,0.4)';twinTempCtx.font='8px Inter,sans-serif';twinTempCtx.textAlign='right';twinTempCtx.fillText('ALARM',tw-4,ty-3);twinTempCtx.restore();
  }
  if(twinVCCtx){
    const vw=twinVCCanvas.width,vh=twinVCCanvas.height;
    twinVCCtx.clearRect(0,0,vw,vh);drawTwinGrid(twinVCCtx,vw,vh);
    const n=twinBuffers.temp.length||1;
    drawTwinLine(twinVCCtx,twinBuffers.vib,'#4da6e8',vw,vh,n,5);
    drawTwinLine(twinVCCtx,twinBuffers.cur,'#34d399',vw,vh,n,4);
  }
}

/* 
   MOTOR ANATOMY SYSTEM  (from JARVIS, SteelGuard theme)
 */
const PART_METADATA=[
  {id:'housing',label:'Frame/Housing'},{id:'cooling-fins',label:'Cooling Fins'},
  {id:'stator-core',label:'Stator Core'},{id:'winding-a',label:'Phase A'},
  {id:'winding-b',label:'Phase B'},{id:'winding-c',label:'Phase C'},
  {id:'air-gap',label:'Air Gap'},{id:'rotor',label:'Rotor'},
  {id:'shaft',label:'Shaft'},{id:'front-bearing',label:'Front Bearing'},
  {id:'rear-bearing',label:'Rear Bearing'},{id:'terminal-box',label:'Terminal Box'},
];
const FAULT_ALERT_PARTS={
  bearing_wear:['front-bearing','rear-bearing','shaft','rotor'],
  overload:['winding-a','winding-b','winding-c','terminal-box','stator-core'],
  rotor_imbalance:['rotor','shaft','front-bearing','rear-bearing'],
  phase_loss:['winding-a','terminal-box','rotor'],
  cooling_failure:['cooling-fins','housing','winding-a','winding-b','winding-c'],
};

// ─── STATUS_FAULT_MAP ──────────────────────────────────────────────────────
// Maps keyword substrings found in Raspberry Pi Final_Status strings to the
// matching FAULT_ALERT_PARTS key.  Evaluated top-to-bottom; first match wins.
// Examples handled:
//   "CRITICAL_BEARING_WEAR"  → bearing_wear   (ALERT)
//   "WARNING_BEARING_WEAR"   → bearing_wear   (WARN)
//   "CRITICAL_OVERLOAD"      → overload       (ALERT)
//   "CRITICAL_PHASE_LOSS"    → phase_loss     (ALERT)
//   "WARNING_DEGRADATION"    → overload       (WARN, generic fallback)
//   "CRITICAL_MACHINE_FAULT" → overload       (ALERT, generic fallback)
const STATUS_FAULT_MAP = [
  { keywords: ['BEARING'],                          faultKey: 'bearing_wear'    },
  { keywords: ['ROTOR', 'IMBALANCE', 'UNBALANCE'],  faultKey: 'rotor_imbalance' },
  { keywords: ['PHASE'],                            faultKey: 'phase_loss'      },
  { keywords: ['COOL', 'THERMAL', 'OVERHEAT'],      faultKey: 'cooling_failure' },
  { keywords: ['OVERLOAD', 'OVERCURRENT'],          faultKey: 'overload'        },
  // Generic catch-all (MACHINE_FAULT, DEGRADATION, etc.)
  { keywords: ['FAULT', 'DEGRAD', 'GENERAL'],       faultKey: 'overload'        },
];

const SENSOR_ALERT_PARTS={
  temp:['winding-a','winding-b','winding-c','cooling-fins','stator-core'],
  vib:['front-bearing','rear-bearing','shaft','rotor'],
  cur:['winding-a','winding-b','winding-c','terminal-box'],
  rpm:['rotor','shaft'],
};
let anatomyAlertParts=new Set(),anatomyWarnParts=new Set(),anatomyAnimTime=0;
// Stores the latest Final_Status string received from the Raspberry Pi backend.
// Set by liveTick() and read by computeAnatomyParts() for live fault mapping.
let lastFinalStatus = 'NORMAL';

function computeAnatomyParts(r){
  const alert=new Set(),warn=new Set();

  // ── LAYER 1: Simulation / Injection fault (original logic — untouched) ─────
  // Highlights parts based on manually-injected fault type from the Twin engine.
  if(faultType!=='none'&&FAULT_ALERT_PARTS[faultType]&&faultOnset>=0&&(twinStep-faultOnset)>5)
    FAULT_ALERT_PARTS[faultType].forEach(p=>alert.add(p));

  // ── LAYER 2: Live backend Final_Status parsing (NEW) ──────────────────────
  // Only activates in normal sim mode with no active injection so it doesn't
  // interfere with manual fault-injection sessions.
  // Parses `lastFinalStatus` (set by liveTick from Raspberry Pi CSV col 8).
  if(twinMode==='normal' && !customInjActive && lastFinalStatus){
    const fs = lastFinalStatus.toUpperCase();
    const isBackendCritical = fs.includes('CRITICAL') || fs.includes('FAULT');
    const isBackendWarning  = fs.includes('WARNING')  || fs.includes('DEGRAD');

    if(isBackendCritical || isBackendWarning){
      // Walk STATUS_FAULT_MAP top-to-bottom; first keyword match wins.
      let matchedKey = null;
      for(const entry of STATUS_FAULT_MAP){
        if(entry.keywords.some(kw => fs.includes(kw))){
          matchedKey = entry.faultKey;
          break;
        }
      }
      // Fall back to 'overload' (most comprehensive part set) when no keyword
      // matches — covers generic strings like 'CRITICAL_MACHINE_FAULT'.
      const targetParts = FAULT_ALERT_PARTS[matchedKey] || FAULT_ALERT_PARTS['overload'];

      if(isBackendCritical){
        targetParts.forEach(p => alert.add(p));
      } else {
        // WARNING-level: add to warn set only (yellow, not red)
        targetParts.forEach(p => warn.add(p));
      }
    }
  }

  // ── LAYER 3: Per-sensor threshold checks (original logic — untouched) ──────
  if(r){
    const aT=getAlarmT(),aV=getAlarmV();
    if(r.tempAlarm)SENSOR_ALERT_PARTS.temp.forEach(p=>alert.add(p));
    else if(r.temp>aT*0.78)SENSOR_ALERT_PARTS.temp.forEach(p=>warn.add(p));
    if(r.vibAlarm)SENSOR_ALERT_PARTS.vib.forEach(p=>alert.add(p));
    else if(r.vib>aV*0.55)SENSOR_ALERT_PARTS.vib.forEach(p=>warn.add(p));
    if(r.current>9)SENSOR_ALERT_PARTS.cur.forEach(p=>alert.add(p));
    else if(r.current>7)SENSOR_ALERT_PARTS.cur.forEach(p=>warn.add(p));
    if(r.rpm<1100)SENSOR_ALERT_PARTS.rpm.forEach(p=>alert.add(p));
    else if(r.rpm<1350)SENSOR_ALERT_PARTS.rpm.forEach(p=>warn.add(p));
    // Pressure fault → housing and cooling system parts
    if(r.presAlarm){['housing','cooling-fins','stator-core'].forEach(p=>alert.add(p));}
  }

  // Alert always wins over warn for the same part
  alert.forEach(p=>warn.delete(p));
  anatomyAlertParts=alert;anatomyWarnParts=warn;
}

function updateAnatomyChips(){
  let alertCount = 0, warnCount = 0;

  PART_METADATA.forEach(pm => {
    const chip = document.getElementById('chip-' + pm.id);
    if(!chip) return;

    const isAlert = anatomyAlertParts.has(pm.id);
    const isWarn  = !isAlert && anatomyWarnParts.has(pm.id);

    // ── State classes (CSS handles alert chipFlare; warn gets inline pulse)
    chip.classList.toggle('part-alert', isAlert);
    chip.classList.toggle('part-warn',  isWarn);
    // Warn chips: CSS has no animation — inject chipFlare via inline style (slower/yellow tone)
    chip.style.animation = isWarn ? 'chipFlare 1.6s ease-in-out infinite' : '';

    // ── Live status badge — created once, updated every tick
    let badge = chip.querySelector('.sg-chip-badge');
    if(!badge){
      badge = document.createElement('span');
      badge.className = 'sg-chip-badge';
      badge.style.cssText = [
        'margin-left:auto',
        'font-size:0.52rem',
        'font-weight:800',
        'letter-spacing:1px',
        'padding:2px 5px',
        'border-radius:3px',
        'border:1px solid transparent',
        'white-space:nowrap',
        'font-family:"IBM Plex Mono",monospace',
        'flex-shrink:0',
        'transition:all 0.3s',
      ].join(';');
      chip.appendChild(badge);
    }

    if(isAlert){
      badge.textContent  = 'FAULT';
      badge.style.color       = 'rgba(248,113,113,0.95)';
      badge.style.borderColor = 'rgba(248,113,113,0.45)';
      badge.style.background  = 'rgba(248,113,113,0.10)';
      badge.style.display     = 'inline-block';
      alertCount++;
    } else if(isWarn){
      badge.textContent  = 'WARN';
      badge.style.color       = 'rgba(251,191,36,0.95)';
      badge.style.borderColor = 'rgba(251,191,36,0.45)';
      badge.style.background  = 'rgba(251,191,36,0.08)';
      badge.style.display     = 'inline-block';
      warnCount++;
    } else {
      badge.style.display = 'none';
    }
  });

  // ── Live count label injected into "Component Status Grid" card-title
  const grid      = document.getElementById('parts-status-grid');
  const cardTitle = grid ? grid.previousElementSibling : null;
  if(cardTitle && cardTitle.classList.contains('card-title')){
    let counter = cardTitle.querySelector('.sg-grid-live-count');
    if(!counter){
      counter = document.createElement('span');
      counter.className = 'sg-grid-live-count';
      counter.style.cssText = [
        'margin-left:auto',
        'font-size:0.6rem',
        'font-weight:700',
        'letter-spacing:1px',
        'padding:2px 8px',
        'border-radius:4px',
        'border:1px solid',
        'font-family:"IBM Plex Mono",monospace',
      ].join(';');
      cardTitle.appendChild(counter);
    }
    if(alertCount > 0){
      counter.textContent    = alertCount + (alertCount > 1 ? ' FAULTS' : ' FAULT') + (warnCount > 0 ? ' · ' + warnCount + ' WARN' : '');
      counter.style.color       = 'rgba(248,113,113,0.9)';
      counter.style.borderColor = 'rgba(248,113,113,0.3)';
      counter.style.background  = 'rgba(248,113,113,0.07)';
    } else if(warnCount > 0){
      counter.textContent    = warnCount + ' DEGRADED';
      counter.style.color       = 'rgba(251,191,36,0.9)';
      counter.style.borderColor = 'rgba(251,191,36,0.3)';
      counter.style.background  = 'rgba(251,191,36,0.06)';
    } else {
      counter.textContent    = 'ALL NOMINAL';
      counter.style.color       = 'rgba(34,197,94,0.85)';
      counter.style.borderColor = 'rgba(34,197,94,0.2)';
      counter.style.background  = 'rgba(34,197,94,0.06)';
    }
  }
}

function updateAnatomyBanners(r){
  const fb = document.getElementById('anatomy-fault-banner');
  const wb = document.getElementById('anatomy-warn-banner');
  const hasAlert = anatomyAlertParts.size > 0;
  const hasWarn  = !hasAlert && anatomyWarnParts.size > 0;

  fb?.classList.toggle('active', hasAlert);
  wb?.classList.toggle('active', hasWarn);

  // ── Icon dots — first <span> inside each banner becomes a pulsing indicator
  const faultIconSpan = fb?.querySelector('span:first-child');
  if(faultIconSpan){
    faultIconSpan.style.cssText = hasAlert
      ? 'display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--red);box-shadow:0 0 8px var(--red);flex-shrink:0;animation:livePulse 1.1s infinite;'
      : '';
  }
  const warnIconSpan = wb?.querySelector('span:first-child');
  if(warnIconSpan){
    warnIconSpan.style.cssText = hasWarn
      ? 'display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--yellow);box-shadow:0 0 7px var(--yellow);flex-shrink:0;animation:livePulse 1.5s infinite;'
      : '';
  }

  // ── FAULT BANNER (red) ────────────────────────────────────────────────────
  if(hasAlert){
    const bt = document.getElementById('anatomy-banner-text');
    if(!bt) return;

    // Friendly labels for up to 3 affected parts
    const affectedLabels = [...anatomyAlertParts]
      .slice(0, 3)
      .map(id => PART_METADATA.find(m => m.id === id)?.label || id)
      .join(', ');
    const moreCount = anatomyAlertParts.size > 3 ? ` +${anatomyAlertParts.size - 3} more` : '';

    // Compact live sensor snapshot
    const snap = r
      ? `  |  T:${r.temp != null ? r.temp.toFixed(1) : '—'}°C  V:${r.vib != null ? r.vib.toFixed(2) : '—'}g  I:${r.current != null ? r.current.toFixed(1) : '—'}A`
      : '';

    // ── Priority 1: Named injection fault type
    if(faultType !== 'none' && FAULT_ALERT_PARTS[faultType]){
      const FAULT_DESC = {
        bearing_wear:    'Bearing Wear — friction & vibration cascade',
        overload:        'Motor Overload — winding thermal stress',
        rotor_imbalance: 'Rotor Imbalance — unbalanced centrifugal forces',
        phase_loss:      'Phase Loss — supply asymmetry detected',
        cooling_failure: 'Cooling Failure — thermal runaway risk',
      };
      const desc = FAULT_DESC[faultType] || faultType.replace(/_/g,' ').toUpperCase();
      bt.textContent = `⚠ ${desc} — Affected: ${affectedLabels}${moreCount}${snap}`;
    }
    // ── Priority 2: Live Pi backend Final_Status string
    else if(lastFinalStatus && !['NORMAL','NOMINAL',''].includes(lastFinalStatus.toUpperCase().trim())){
      const fs = lastFinalStatus.toUpperCase();
      let fDesc = 'System Fault';
      if     (fs.includes('BEARING'))                                       fDesc = 'Bearing Fault';
      else if(fs.includes('ROTOR') || fs.includes('IMBALANCE'))             fDesc = 'Rotor Imbalance';
      else if(fs.includes('PHASE'))                                          fDesc = 'Phase Loss';
      else if(fs.includes('COOL') || fs.includes('THERMAL') || fs.includes('OVERHEAT')) fDesc = 'Cooling / Thermal Fault';
      else if(fs.includes('OVERLOAD') || fs.includes('OVERCURRENT'))        fDesc = 'Overload / Overcurrent';
      bt.textContent = `⚠ Pi: ${fDesc} [${lastFinalStatus}] — ${affectedLabels}${moreCount}${snap}`;
    }
    // ── Priority 3: Sensor threshold breach (no named fault type)
    else if(r){
      const aT = getAlarmT(), aV = getAlarmV();
      const triggers = [];
      if(r.tempAlarm  || r.temp    > aT)  triggers.push(`TEMP ${r.temp?.toFixed(1)}°C > ${aT}°C`);
      if(r.vibAlarm   || r.vib     > aV)  triggers.push(`VIB ${r.vib?.toFixed(2)}g > ${aV}g`);
      if(r.current > 9)                   triggers.push(`CURR ${r.current?.toFixed(1)}A over limit`);
      if(r.rpm < 1100)                    triggers.push(`RPM ${r.rpm} critical low`);
      if(r.presAlarm)                     triggers.push(`PRES alarm`);
      const trigStr = triggers.length > 0 ? triggers.join(' · ') : `${anatomyAlertParts.size} sensor(s) in alarm`;
      bt.textContent = `⚠ Sensor Alarm — ${trigStr} — ${affectedLabels}${moreCount}`;
    }
    // ── Fallback
    else {
      bt.textContent = `⚠ Fault Active — ${anatomyAlertParts.size} component(s) critical: ${affectedLabels}${moreCount}`;
    }
  }

  // ── WARN BANNER (yellow) ──────────────────────────────────────────────────
  if(hasWarn){
    const wt = document.getElementById('anatomy-warn-text');
    if(!wt) return;

    const warnLabels = [...anatomyWarnParts]
      .slice(0, 3)
      .map(id => PART_METADATA.find(m => m.id === id)?.label || id)
      .join(', ');
    const warnMore = anatomyWarnParts.size > 3 ? ` +${anatomyWarnParts.size - 3} more` : '';

    const triggers = [];

    // Pi backend warning first
    if(twinMode === 'normal' && lastFinalStatus){
      const fs = lastFinalStatus.toUpperCase();
      if(fs.includes('WARNING') || fs.includes('DEGRAD')){
        triggers.push(`Pi: ${lastFinalStatus.replace(/_/g,' ')}`);
      }
    }

    // Sensor-level degradation indicators
    if(r){
      const aT = getAlarmT(), aV = getAlarmV();
      if(r.temp > aT * 0.78 && r.temp <= aT)
        triggers.push(`TEMP ${r.temp.toFixed(1)}°C (${Math.round(r.temp / aT * 100)}% of alarm)`);
      if(r.vib  > aV * 0.55 && r.vib  <= aV)
        triggers.push(`VIB ${r.vib.toFixed(2)}g (${Math.round(r.vib / aV * 100)}% of alarm)`);
      if(r.current > 7 && r.current <= 9)
        triggers.push(`CURR ${r.current.toFixed(1)}A elevated`);
      if(r.rpm < 1350 && r.rpm >= 1100)
        triggers.push(`RPM ${r.rpm} — drifting low`);
    }

    // Degradation mode active
    if(twinMode === 'warn' && faultType === 'none') triggers.push('Degradation mode active');

    const triggerStr = triggers.length > 0
      ? triggers.join(' · ')
      : `${anatomyWarnParts.size} component(s) trending toward limits`;

    wt.textContent = `⚡ Degradation Detected — ${triggerStr} — At risk: ${warnLabels}${warnMore}`;
  }
}

function buildPartsStatusGrid(){
  const grid=document.getElementById('parts-status-grid');if(!grid)return;
  grid.innerHTML='';
  PART_METADATA.forEach(pm=>{
    const chip=document.createElement('div');
    chip.className='part-chip-sg';chip.id='chip-'+pm.id;chip.title=pm.label;
    chip.innerHTML=`<div class="part-dot-sg"></div><div class="part-name-sg">${pm.label}</div>`;
    grid.appendChild(chip);
  });
}

// Anatomy drawing helpers
function partFill(id,n,a,w){if(anatomyAlertParts.has(id))return a||'rgba(248,113,113,0.5)';if(anatomyWarnParts.has(id))return w||'rgba(251,191,36,0.4)';return n;}
function partStroke(id,n){if(anatomyAlertParts.has(id))return '#f87171';if(anatomyWarnParts.has(id))return '#fbbf24';return n;}
function partGlow(ctx,id){if(anatomyAlertParts.has(id)){const p=0.5+0.5*Math.sin(anatomyAnimTime*5);ctx.shadowColor=`rgba(248,113,113,${0.6+0.4*p})`;ctx.shadowBlur=8+6*p;}else if(anatomyWarnParts.has(id)){ctx.shadowColor='rgba(251,191,36,0.5)';ctx.shadowBlur=6;}else{ctx.shadowColor='transparent';ctx.shadowBlur=0;}}
function drawArcSector(ctx,cx,cy,r1,r2,s,e){const sa=s*Math.PI/180,ea=e*Math.PI/180;ctx.beginPath();ctx.arc(cx,cy,r1,sa,ea,false);ctx.arc(cx,cy,r2,ea,sa,true);ctx.closePath();}
function drawAnLabel(ctx,text,x,y,col,size){ctx.save();ctx.font=`${size||9}px Inter,sans-serif`;ctx.fillStyle=col||'rgba(43,144,217,0.5)';ctx.textAlign='center';ctx.shadowBlur=0;ctx.fillText(text,x,y);ctx.restore();}
function drawLabelLine(ctx,x1,y1,x2,y2,label,alignLeft,alertPart){const col=alertPart&&anatomyAlertParts.has(alertPart)?'rgba(248,113,113,0.6)':alertPart&&anatomyWarnParts.has(alertPart)?'rgba(251,191,36,0.55)':'rgba(43,144,217,0.3)';ctx.save();ctx.strokeStyle=col;ctx.lineWidth=0.7;ctx.setLineDash([3,4]);ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();ctx.setLineDash([]);ctx.font='8px Inter,sans-serif';ctx.fillStyle=col;ctx.textAlign=alignLeft?'left':'right';ctx.fillText(label,alignLeft?x2+4:x2-4,y2+3);ctx.restore();}

function drawCrossSection(canvas){
  const W=canvas.width,H=canvas.height,ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  drawAnLabel(ctx,'TOP-DOWN PLAN VIEW',W/2,14,'rgba(43,144,217,0.35)',8);
  const S=Math.min(W,H)/420;
  const cx=W*0.5, cy=H*0.55;
  // --- TRACKS (left/right, pill-shaped in plan) ---
  const trackLen=230*S, trackW=32*S, trackGap=94*S;
  for(const side of [-1,1]){
    const id=side<0?'track-left':'track-right';
    const tx=cx+side*trackGap/2;
    ctx.save();partGlow(ctx,id);
    ctx.fillStyle=partFill(id,'rgba(14,6,32,0.88)','rgba(248,113,113,0.3)','rgba(251,191,36,0.2)');
    ctx.strokeStyle=partStroke(id,'rgba(77,166,232,0.6)');ctx.lineWidth=1.5;
    const rr=trackW/2;
    ctx.beginPath();
    ctx.moveTo(tx-rr+rr, cy-trackLen/2);
    ctx.lineTo(tx+rr-rr, cy-trackLen/2);
    ctx.lineTo(tx+rr, cy-trackLen/2);
    ctx.arc(tx, cy-trackLen/2+rr, rr, -Math.PI/2, Math.PI/2, true);
    ctx.lineTo(tx+rr, cy+trackLen/2-rr);
    ctx.arc(tx, cy+trackLen/2-rr, rr, -Math.PI/2, Math.PI/2, false);
    ctx.lineTo(tx-rr, cy+trackLen/2-rr);
    ctx.closePath();
    // simpler rounded rect
    ctx.beginPath();
    const x0=tx-trackW/2, y0=cy-trackLen/2;
    ctx.moveTo(x0+rr,y0);
    ctx.lineTo(x0+trackW-rr,y0);
    ctx.arcTo(x0+trackW,y0,x0+trackW,y0+rr,rr);
    ctx.lineTo(x0+trackW,y0+trackLen-rr);
    ctx.arcTo(x0+trackW,y0+trackLen,x0+trackW-rr,y0+trackLen,rr);
    ctx.lineTo(x0+rr,y0+trackLen);
    ctx.arcTo(x0,y0+trackLen,x0,y0+trackLen-rr,rr);
    ctx.lineTo(x0,y0+rr);
    ctx.arcTo(x0,y0,x0+rr,y0,rr);
    ctx.closePath();
    ctx.fill();ctx.stroke();
    // tread pattern
    ctx.strokeStyle='rgba(43,144,217,0.32)';ctx.lineWidth=0.8;
    for(let i=0;i<20;i++){
      const ty=y0+4+i*(trackLen-8)/20;
      ctx.beginPath();ctx.moveTo(x0+3,ty);ctx.lineTo(x0+trackW-3,ty);ctx.stroke();
    }
    ctx.restore();
  }
  // --- UNDERCARRIAGE frame ---
  ctx.save();partGlow(ctx,'undercarriage');
  ctx.fillStyle=partFill('undercarriage','rgba(13,6,34,0.75)','rgba(248,113,113,0.25)','rgba(251,191,36,0.18)');
  ctx.strokeStyle=partStroke('undercarriage','rgba(43,144,217,0.5)');ctx.lineWidth=1;
  ctx.fillRect(cx-trackGap/2-2,cy-40*S,trackGap+4,80*S);
  ctx.strokeRect(cx-trackGap/2-2,cy-40*S,trackGap+4,80*S);
  ctx.restore();
  // --- SLEWING RING ---
  ctx.save();partGlow(ctx,'slewing-ring');
  const ringR=55*S;
  ctx.beginPath();ctx.arc(cx,cy,ringR,0,Math.PI*2);
  ctx.fillStyle=partFill('slewing-ring','rgba(22,9,46,0.85)','rgba(248,113,113,0.3)','rgba(251,191,36,0.22)');
  ctx.strokeStyle=partStroke('slewing-ring','rgba(139,92,246,0.75)');ctx.lineWidth=1.5;
  ctx.fill();ctx.stroke();
  ctx.beginPath();ctx.arc(cx,cy,ringR*0.76,0,Math.PI*2);
  ctx.strokeStyle='rgba(139,92,246,0.4)';ctx.lineWidth=0.8;ctx.stroke();
  for(let i=0;i<28;i++){const a=(i/28)*Math.PI*2;
    ctx.beginPath();ctx.arc(cx+Math.cos(a)*ringR*0.88,cy+Math.sin(a)*ringR*0.88,1.8*S,0,Math.PI*2);
    ctx.fillStyle='rgba(139,92,246,0.55)';ctx.fill();
  }
  ctx.restore();
  // --- UPPER PLATFORM outline ---
  ctx.save();partGlow(ctx,'upper-platform');
  const upW=130*S, upL=165*S;
  ctx.fillStyle=partFill('upper-platform','rgba(14,6,32,0.45)');
  ctx.strokeStyle=partStroke('upper-platform','rgba(43,144,217,0.55)');ctx.lineWidth=1;
  ctx.globalAlpha=0.75;
  ctx.fillRect(cx-upW/2,cy-upL/2,upW,upL);
  ctx.strokeRect(cx-upW/2,cy-upL/2,upW,upL);
  ctx.restore();
  // --- OPERATOR CAB (front-left of upper) ---
  ctx.save();partGlow(ctx,'operator-cab');
  const cabW=52*S, cabL=68*S;
  const cabX=cx-42*S-cabW/2, cabY=cy-55*S-cabL/2;
  ctx.fillStyle=partFill('operator-cab','rgba(20,8,48,0.9)','rgba(248,113,113,0.5)','rgba(251,191,36,0.35)');
  ctx.strokeStyle=partStroke('operator-cab','rgba(77,166,232,0.65)');ctx.lineWidth=1.5;
  ctx.fillRect(cabX,cabY,cabW,cabL);ctx.strokeRect(cabX,cabY,cabW,cabL);
  ctx.strokeStyle='rgba(139,92,246,0.45)';ctx.lineWidth=0.6;
  ctx.strokeRect(cabX+cabW*0.22,cabY+cabL*0.12,cabW*0.56,cabL*0.35);
  ctx.restore();
  // --- ENGINE BAY (rear of upper) ---
  ctx.save();partGlow(ctx,'engine-bay');
  const engW=118*S, engL=72*S;
  const engX=cx+4*S-engW/2, engY=cy+48*S-engL/2;
  ctx.fillStyle=partFill('engine-bay','rgba(16,6,40,0.9)','rgba(248,113,113,0.45)','rgba(251,191,36,0.3)');
  ctx.strokeStyle=partStroke('engine-bay','rgba(43,144,217,0.6)');ctx.lineWidth=1.5;
  ctx.fillRect(engX,engY,engW,engL);ctx.strokeRect(engX,engY,engW,engL);
  ctx.strokeStyle='rgba(43,144,217,0.32)';ctx.lineWidth=0.6;
  for(let i=1;i<9;i++){const lx=engX+i*engW/9;ctx.beginPath();ctx.moveTo(lx,engY+4);ctx.lineTo(lx,engY+engL-4);ctx.stroke();}
  ctx.restore();
  // --- COUNTERWEIGHT ---
  ctx.save();partGlow(ctx,'counterweight');
  const cwW=134*S, cwL=28*S;
  const cwX=cx-cwW/2, cwY=cy+92*S-cwL/2;
  ctx.fillStyle=partFill('counterweight','rgba(5,2,16,0.95)','rgba(248,113,113,0.4)','rgba(251,191,36,0.28)');
  ctx.strokeStyle=partStroke('counterweight','rgba(77,166,232,0.6)');ctx.lineWidth=1.5;
  ctx.fillRect(cwX,cwY,cwW,cwL);ctx.strokeRect(cwX,cwY,cwW,cwL);
  ctx.restore();
  // --- BOOM projected (from slewing center forward = up in image) ---
  ctx.save();partGlow(ctx,'boom');
  const boomW=24*S, boomLenPlan=155*Math.cos(35*Math.PI/180)*S;
  ctx.fillStyle=partFill('boom','rgba(20,8,38,0.85)','rgba(248,113,113,0.5)','rgba(251,191,36,0.35)');
  ctx.strokeStyle=partStroke('boom','rgba(139,92,246,0.75)');ctx.lineWidth=1.5;
  const boomTopY=cy-upL/2-boomLenPlan;
  ctx.fillRect(cx-boomW/2, boomTopY, boomW, boomLenPlan+20*S);
  ctx.strokeRect(cx-boomW/2, boomTopY, boomW, boomLenPlan+20*S);
  ctx.restore();
  // --- STICK projected (continues forward) ---
  ctx.save();partGlow(ctx,'stick');
  const stickW=19*S, stickLenPlan=115*Math.cos(60*Math.PI/180)*S;
  ctx.fillStyle=partFill('stick','rgba(15,6,32,0.85)','rgba(248,113,113,0.5)','rgba(251,191,36,0.35)');
  ctx.strokeStyle=partStroke('stick','rgba(139,92,246,0.75)');ctx.lineWidth=1.5;
  const stickTopY=boomTopY-stickLenPlan;
  ctx.fillRect(cx-stickW/2, stickTopY, stickW, stickLenPlan+4*S);
  ctx.strokeRect(cx-stickW/2, stickTopY, stickW, stickLenPlan+4*S);
  ctx.restore();
  // --- BUCKET at stick tip ---
  ctx.save();partGlow(ctx,'bucket');
  const buckW=40*S, buckL=28*S;
  const buckY=stickTopY-buckL;
  ctx.fillStyle=partFill('bucket','rgba(18,8,40,0.9)','rgba(248,113,113,0.55)','rgba(251,191,36,0.4)');
  ctx.strokeStyle=partStroke('bucket','rgba(139,92,246,0.8)');ctx.lineWidth=1.5;
  ctx.fillRect(cx-buckW/2, buckY, buckW, buckL);ctx.strokeRect(cx-buckW/2, buckY, buckW, buckL);
  for(let i=0;i<6;i++){const tx=cx-buckW/2+(i+0.5)*buckW/6;
    ctx.beginPath();
    ctx.moveTo(tx-3*S, buckY);
    ctx.lineTo(tx, buckY-5*S);
    ctx.lineTo(tx+3*S, buckY);
    ctx.closePath();
    ctx.fillStyle='rgba(139,92,246,0.55)';ctx.fill();
  }
  ctx.restore();
  // --- Hydraulic cylinder hints (short strokes on boom) ---
  ctx.save();partGlow(ctx,'boom-cyl');
  ctx.strokeStyle=partStroke('boom-cyl','rgba(139,92,246,0.65)');ctx.lineWidth=2.5;ctx.lineCap='round';
  ctx.beginPath();ctx.moveTo(cx-6*S, cy-upL/2+4*S);ctx.lineTo(cx-6*S, cy-upL/2-boomLenPlan*0.35);ctx.stroke();
  ctx.beginPath();ctx.moveTo(cx+6*S, cy-upL/2+4*S);ctx.lineTo(cx+6*S, cy-upL/2-boomLenPlan*0.35);ctx.stroke();
  ctx.restore();
  // --- LABELS ---
  const LX=W-10;
  drawLabelLine(ctx, cx-trackGap/2-trackW/2, cy-trackLen/2+30*S, 10, 32, 'L-TRACK', true, 'track-left');
  drawLabelLine(ctx, cx+trackGap/2+trackW/2, cy-trackLen/2+30*S, LX, 32, 'R-TRACK', false, 'track-right');
  drawLabelLine(ctx, cx+ringR*0.7, cy-ringR*0.7, LX, 78, 'SLEW RING', false, 'slewing-ring');
  drawLabelLine(ctx, cabX, cabY+cabL*0.5, 10, 110, 'CAB', true, 'operator-cab');
  drawLabelLine(ctx, cx+engW*0.45, cy+48*S-engL*0.3, LX, cy-20, 'ENGINE', false, 'engine-bay');
  drawLabelLine(ctx, cx-cwW*0.5, cy+92*S, 10, H-50, 'C-WEIGHT', true, 'counterweight');
  drawLabelLine(ctx, cx+boomW/2, cy-upL/2-boomLenPlan*0.55, LX, 150, 'BOOM', false, 'boom');
  drawLabelLine(ctx, cx-stickW/2, stickTopY+stickLenPlan*0.4, 10, 180, 'STICK', true, 'stick');
  drawLabelLine(ctx, cx+buckW/2, buckY+buckL*0.5, LX, 210, 'BUCKET', false, 'bucket');
  // Legend
  const lcx=12, lcy=H-22;
  ctx.save();ctx.font='8px Inter,sans-serif';ctx.fillStyle='rgba(43,144,217,0.45)';ctx.textAlign='left';
  ctx.fillText('▲ BUCKET FORWARD', lcx, lcy);
  ctx.fillText('■ SLEW AXIS CENTER', lcx+130, lcy);
  ctx.restore();
}

function drawSideView(canvas){
  const W=canvas.width,H=canvas.height,ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  drawAnLabel(ctx,'SIDE PROFILE VIEW — MACHINE LEFT',W/2,13,'rgba(43,144,217,0.35)',8);
  const S=Math.min(W,H)/260;
  const groundY=H*0.82, cx=W*0.62;
  // Ground line
  ctx.save();ctx.strokeStyle='rgba(43,144,217,0.25)';ctx.lineWidth=0.8;ctx.setLineDash([3,5]);
  ctx.beginPath();ctx.moveTo(10,groundY);ctx.lineTo(W-10,groundY);ctx.stroke();
  ctx.setLineDash([]);ctx.restore();
  // --- TRACK (side view = pill shape) ---
  const trackLen=230*S, trackH=30*S;
  const trackX0=cx-130*S, trackY0=groundY-trackH;
  ctx.save();partGlow(ctx,'track-left');
  ctx.fillStyle=partFill('track-left','rgba(10,5,24,0.9)','rgba(248,113,113,0.3)','rgba(251,191,36,0.2)');
  ctx.strokeStyle=partStroke('track-left','rgba(77,166,232,0.65)');ctx.lineWidth=1.5;
  const rr=trackH/2;
  ctx.beginPath();
  ctx.moveTo(trackX0+rr, trackY0);
  ctx.lineTo(trackX0+trackLen-rr, trackY0);
  ctx.arc(trackX0+trackLen-rr, trackY0+rr, rr, -Math.PI/2, Math.PI/2);
  ctx.lineTo(trackX0+rr, trackY0+trackH);
  ctx.arc(trackX0+rr, trackY0+rr, rr, Math.PI/2, -Math.PI/2);
  ctx.closePath();
  ctx.fill();ctx.stroke();
  // Front idler (large wheel, left end)
  ctx.beginPath();ctx.arc(trackX0+rr, trackY0+rr, rr*0.7, 0, Math.PI*2);
  ctx.fillStyle=partFill('track-left','rgba(20,10,48,0.95)');
  ctx.strokeStyle=partStroke('track-left','rgba(139,92,246,0.6)');ctx.lineWidth=1;
  ctx.fill();ctx.stroke();
  // Rear sprocket with teeth
  const spX=trackX0+trackLen-rr, spY=trackY0+rr;
  ctx.beginPath();ctx.arc(spX, spY, rr*0.7, 0, Math.PI*2);ctx.fill();ctx.stroke();
  for(let i=0;i<12;i++){const a=(i/12)*Math.PI*2;
    ctx.beginPath();
    ctx.moveTo(spX+Math.cos(a)*rr*0.7, spY+Math.sin(a)*rr*0.7);
    ctx.lineTo(spX+Math.cos(a)*rr*0.92, spY+Math.sin(a)*rr*0.92);
    ctx.strokeStyle='rgba(139,92,246,0.55)';ctx.lineWidth=1;ctx.stroke();
  }
  // Track rollers (small wheels at bottom)
  for(let i=0;i<5;i++){const rx=trackX0+rr*2.3+i*(trackLen-rr*4.6)/4;
    ctx.beginPath();ctx.arc(rx, trackY0+trackH*0.72, rr*0.32, 0, Math.PI*2);
    ctx.fillStyle='rgba(20,10,48,0.95)';ctx.fill();
    ctx.strokeStyle='rgba(77,166,232,0.45)';ctx.lineWidth=0.5;ctx.stroke();
  }
  // Tread pattern on top of track
  ctx.strokeStyle='rgba(43,144,217,0.3)';ctx.lineWidth=0.6;
  for(let i=0;i<22;i++){const tx=trackX0+rr+i*(trackLen-rr*2)/21;
    ctx.beginPath();ctx.moveTo(tx, trackY0+3);ctx.lineTo(tx, trackY0+7);ctx.stroke();
    ctx.beginPath();ctx.moveTo(tx, trackY0+trackH-3);ctx.lineTo(tx, trackY0+trackH-7);ctx.stroke();
  }
  ctx.restore();
  // --- UNDERCARRIAGE frame (thin bar above track) ---
  ctx.save();partGlow(ctx,'undercarriage');
  const ucW=160*S, ucH=13*S;
  const ucX=cx-ucW/2, ucY=trackY0-ucH+3*S;
  ctx.fillStyle=partFill('undercarriage','rgba(13,6,34,0.92)','rgba(248,113,113,0.3)','rgba(251,191,36,0.2)');
  ctx.strokeStyle=partStroke('undercarriage','rgba(43,144,217,0.6)');ctx.lineWidth=1.5;
  ctx.fillRect(ucX, ucY, ucW, ucH);ctx.strokeRect(ucX, ucY, ucW, ucH);
  ctx.restore();
  // --- SLEWING RING ---
  ctx.save();partGlow(ctx,'slewing-ring');
  const srW=110*S, srH=11*S;
  const srX=cx-srW/2, srY=ucY-srH;
  ctx.fillStyle=partFill('slewing-ring','rgba(22,9,46,0.92)','rgba(248,113,113,0.35)','rgba(251,191,36,0.25)');
  ctx.strokeStyle=partStroke('slewing-ring','rgba(139,92,246,0.75)');ctx.lineWidth=1.5;
  ctx.fillRect(srX, srY, srW, srH);ctx.strokeRect(srX, srY, srW, srH);
  // tooth pattern
  for(let i=0;i<14;i++){const tx=srX+(i+0.5)*srW/14;
    ctx.beginPath();ctx.moveTo(tx, srY+2);ctx.lineTo(tx, srY+srH-2);
    ctx.strokeStyle='rgba(139,92,246,0.4)';ctx.lineWidth=0.5;ctx.stroke();
  }
  ctx.restore();
  // --- UPPER PLATFORM ---
  ctx.save();partGlow(ctx,'upper-platform');
  const upW=165*S, upH=13*S;
  const upX=cx-upW/2, upY=srY-upH;
  ctx.fillStyle=partFill('upper-platform','rgba(14,6,32,0.88)');
  ctx.strokeStyle=partStroke('upper-platform','rgba(43,144,217,0.55)');ctx.lineWidth=1;
  ctx.fillRect(upX, upY, upW, upH);ctx.strokeRect(upX, upY, upW, upH);
  ctx.restore();
  // --- OPERATOR CAB (angled windshield) ---
  ctx.save();partGlow(ctx,'operator-cab');
  const cabW=58*S, cabH=52*S;
  const cabX=upX+8*S, cabY=upY-cabH;
  ctx.fillStyle=partFill('operator-cab','rgba(20,8,48,0.95)','rgba(248,113,113,0.5)','rgba(251,191,36,0.35)');
  ctx.strokeStyle=partStroke('operator-cab','rgba(77,166,232,0.7)');ctx.lineWidth=1.5;
  ctx.beginPath();
  ctx.moveTo(cabX, cabY+cabH);
  ctx.lineTo(cabX, cabY+cabH*0.42);
  ctx.lineTo(cabX+cabW*0.28, cabY);
  ctx.lineTo(cabX+cabW, cabY);
  ctx.lineTo(cabX+cabW, cabY+cabH);
  ctx.closePath();
  ctx.fill();ctx.stroke();
  // Windshield tint
  ctx.beginPath();
  ctx.moveTo(cabX+3, cabY+cabH*0.43);
  ctx.lineTo(cabX+cabW*0.26, cabY+3);
  ctx.lineTo(cabX+cabW*0.94, cabY+3);
  ctx.lineTo(cabX+cabW*0.94, cabY+cabH*0.43);
  ctx.closePath();
  ctx.fillStyle='rgba(77,166,232,0.18)';
  ctx.strokeStyle='rgba(139,92,246,0.55)';ctx.lineWidth=0.8;
  ctx.fill();ctx.stroke();
  // Side window
  ctx.strokeRect(cabX+cabW*0.32, cabY+cabH*0.5, cabW*0.55, cabH*0.32);
  ctx.restore();
  // --- ENGINE BAY ---
  ctx.save();partGlow(ctx,'engine-bay');
  const engW=72*S, engH=48*S;
  const engX=cabX+cabW+8*S, engY=upY-engH;
  ctx.fillStyle=partFill('engine-bay','rgba(16,6,40,0.95)','rgba(248,113,113,0.45)','rgba(251,191,36,0.3)');
  ctx.strokeStyle=partStroke('engine-bay','rgba(43,144,217,0.6)');ctx.lineWidth=1.5;
  ctx.fillRect(engX, engY, engW, engH);ctx.strokeRect(engX, engY, engW, engH);
  ctx.strokeStyle='rgba(43,144,217,0.32)';ctx.lineWidth=0.6;
  for(let i=1;i<9;i++){const vy=engY+i*engH/9;
    ctx.beginPath();ctx.moveTo(engX+4, vy);ctx.lineTo(engX+engW-4, vy);ctx.stroke();
  }
  ctx.restore();
  // --- COUNTERWEIGHT (angled rear face) ---
  ctx.save();partGlow(ctx,'counterweight');
  const cwW=28*S, cwH=42*S;
  const cwX=engX+engW+2*S, cwY=upY-cwH;
  ctx.fillStyle=partFill('counterweight','rgba(5,2,16,0.95)','rgba(248,113,113,0.4)','rgba(251,191,36,0.3)');
  ctx.strokeStyle=partStroke('counterweight','rgba(77,166,232,0.6)');ctx.lineWidth=1.5;
  ctx.beginPath();
  ctx.moveTo(cwX, cwY+cwH);
  ctx.lineTo(cwX, cwY+6);
  ctx.lineTo(cwX+8*S, cwY);
  ctx.lineTo(cwX+cwW, cwY);
  ctx.lineTo(cwX+cwW, cwY+cwH);
  ctx.closePath();
  ctx.fill();ctx.stroke();
  ctx.restore();
  // --- BOOM (angled up-forward / up-left in image) ---
  const boomPivX=upX+6*S, boomPivY=upY+upH*0.3;
  const boomLen=155*S, boomAng=35*Math.PI/180;
  const boomEndX=boomPivX-Math.cos(boomAng)*boomLen;
  const boomEndY=boomPivY-Math.sin(boomAng)*boomLen;
  const bWH=15*S;
  ctx.save();partGlow(ctx,'boom');
  const bAng=Math.atan2(boomEndY-boomPivY, boomEndX-boomPivX);
  const bpA=bAng+Math.PI/2;
  const bNx=Math.cos(bpA), bNy=Math.sin(bpA);
  ctx.fillStyle=partFill('boom','rgba(20,8,38,0.9)','rgba(248,113,113,0.5)','rgba(251,191,36,0.35)');
  ctx.strokeStyle=partStroke('boom','rgba(139,92,246,0.8)');ctx.lineWidth=1.5;
  ctx.beginPath();
  ctx.moveTo(boomPivX+bNx*bWH, boomPivY+bNy*bWH);
  ctx.lineTo(boomEndX+bNx*bWH, boomEndY+bNy*bWH);
  ctx.lineTo(boomEndX-bNx*bWH, boomEndY-bNy*bWH);
  ctx.lineTo(boomPivX-bNx*bWH, boomPivY-bNy*bWH);
  ctx.closePath();
  ctx.fill();ctx.stroke();
  // Pivot pin
  ctx.beginPath();ctx.arc(boomPivX, boomPivY, 3*S, 0, Math.PI*2);
  ctx.fillStyle='rgba(139,92,246,0.7)';ctx.fill();
  ctx.restore();
  // --- STICK ---
  const stickLen=115*S, stickAng=60*Math.PI/180;
  const stickEndX=boomEndX-Math.cos(stickAng)*stickLen;
  const stickEndY=boomEndY+Math.sin(stickAng)*stickLen;
  const sWH=12*S;
  ctx.save();partGlow(ctx,'stick');
  const sAng=Math.atan2(stickEndY-boomEndY, stickEndX-boomEndX);
  const spA=sAng+Math.PI/2;
  const sNx=Math.cos(spA), sNy=Math.sin(spA);
  ctx.fillStyle=partFill('stick','rgba(15,6,32,0.9)','rgba(248,113,113,0.5)','rgba(251,191,36,0.35)');
  ctx.strokeStyle=partStroke('stick','rgba(139,92,246,0.8)');ctx.lineWidth=1.5;
  ctx.beginPath();
  ctx.moveTo(boomEndX+sNx*sWH, boomEndY+sNy*sWH);
  ctx.lineTo(stickEndX+sNx*sWH, stickEndY+sNy*sWH);
  ctx.lineTo(stickEndX-sNx*sWH, stickEndY-sNy*sWH);
  ctx.lineTo(boomEndX-sNx*sWH, boomEndY-sNy*sWH);
  ctx.closePath();
  ctx.fill();ctx.stroke();
  // Boom-stick pivot
  ctx.beginPath();ctx.arc(boomEndX, boomEndY, 2.5*S, 0, Math.PI*2);
  ctx.fillStyle='rgba(139,92,246,0.7)';ctx.fill();
  ctx.restore();
  // --- BUCKET (curved scoop with teeth) ---
  ctx.save();partGlow(ctx,'bucket');
  ctx.fillStyle=partFill('bucket','rgba(18,8,40,0.92)','rgba(248,113,113,0.55)','rgba(251,191,36,0.4)');
  ctx.strokeStyle=partStroke('bucket','rgba(139,92,246,0.85)');ctx.lineWidth=1.5;
  const bR=24*S;
  const bCX=stickEndX, bCY=stickEndY;
  ctx.beginPath();
  ctx.moveTo(bCX+bR*0.5, bCY-bR*0.4);
  ctx.lineTo(bCX+bR*0.55, bCY+bR*0.35);
  ctx.quadraticCurveTo(bCX+bR*0.25, bCY+bR*0.75, bCX-bR*0.4, bCY+bR*0.55);
  ctx.lineTo(bCX-bR*1.05, bCY+bR*0.25);
  ctx.quadraticCurveTo(bCX-bR*1.15, bCY, bCX-bR*0.85, bCY-bR*0.2);
  ctx.closePath();
  ctx.fill();ctx.stroke();
  // Teeth
  for(let i=0;i<4;i++){const ty=bCY-bR*0.12+i*bR*0.18;
    ctx.beginPath();
    ctx.moveTo(bCX-bR*1.08, ty);
    ctx.lineTo(bCX-bR*1.3, ty+bR*0.08);
    ctx.lineTo(bCX-bR*1.08, ty+bR*0.18);
    ctx.closePath();
    ctx.fillStyle=partStroke('bucket','rgba(139,92,246,0.7)');ctx.fill();
  }
  // Stick-bucket pivot
  ctx.beginPath();ctx.arc(stickEndX, stickEndY, 2.5*S, 0, Math.PI*2);
  ctx.fillStyle='rgba(139,92,246,0.7)';ctx.fill();
  ctx.restore();
  // --- HYDRAULIC CYLINDERS ---
  function drawCyl(id, x1, y1, x2, y2, r){
    ctx.save();partGlow(ctx, id);
    ctx.strokeStyle=partStroke(id,'rgba(139,92,246,0.9)');
    ctx.lineWidth=r*2;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
    ctx.strokeStyle='rgba(22,9,46,0.75)';ctx.lineWidth=r*0.9;
    const mx=(x1+x2)/2, my=(y1+y2)/2;
    ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(mx,my);ctx.stroke();
    ctx.restore();
  }
  // Boom cylinder: upper-platform → 40% along boom (top side)
  const bcFromX=upX+upW*0.32, bcFromY=upY+3;
  const bcToX=boomPivX+(boomEndX-boomPivX)*0.40+bNx*bWH*1.05;
  const bcToY=boomPivY+(boomEndY-boomPivY)*0.40+bNy*bWH*1.05;
  drawCyl('boom-cyl', bcFromX, bcFromY, bcToX, bcToY, 4*S);
  // Stick cylinder: ~15% along boom top → 22% along stick top
  const scFromX=boomPivX+(boomEndX-boomPivX)*0.15+bNx*bWH*1.3;
  const scFromY=boomPivY+(boomEndY-boomPivY)*0.15+bNy*bWH*1.3;
  const scToX=boomEndX+(stickEndX-boomEndX)*0.22+sNx*sWH;
  const scToY=boomEndY+(stickEndY-boomEndY)*0.22+sNy*sWH;
  drawCyl('stick-cyl', scFromX, scFromY, scToX, scToY, 3.5*S);
  // Bucket cylinder: near boom end top → linkage above bucket
  const bkFromX=boomEndX+sNx*sWH*1.4+Math.cos(sAng)*6*S;
  const bkFromY=boomEndY+sNy*sWH*1.4+Math.sin(sAng)*6*S;
  const bkToX=stickEndX+Math.cos(sAng-Math.PI*0.25)*12*S;
  const bkToY=stickEndY+Math.sin(sAng-Math.PI*0.25)*12*S-6*S;
  drawCyl('bucket-cyl', bkFromX, bkFromY, bkToX, bkToY, 3*S);
  // --- LABELS ---
  drawLabelLine(ctx, trackX0+trackLen*0.5, trackY0+trackH*0.5, W-15, H-15, 'TRACK', false, 'track-left');
  drawLabelLine(ctx, srX+srW*0.5, srY+srH*0.5, 15, H-15, 'SLEW RING', true, 'slewing-ring');
  drawLabelLine(ctx, cabX+cabW*0.5, cabY+6, 15, 30, 'CAB', true, 'operator-cab');
  drawLabelLine(ctx, engX+engW*0.5, engY+6, W-15, 24, 'ENGINE', false, 'engine-bay');
  drawLabelLine(ctx, cwX+cwW*0.5, cwY+6, W-15, 60, 'C-WEIGHT', false, 'counterweight');
  drawLabelLine(ctx, (boomPivX+boomEndX)*0.5+bNx*bWH, (boomPivY+boomEndY)*0.5+bNy*bWH, 15, 60, 'BOOM', true, 'boom');
  drawLabelLine(ctx, (boomEndX+stickEndX)*0.5-sNx*sWH, (boomEndY+stickEndY)*0.5-sNy*sWH, 15, 100, 'STICK', true, 'stick');
  drawLabelLine(ctx, bCX-bR*1.2, bCY+bR*0.3, 15, H-40, 'BUCKET', true, 'bucket');
  drawLabelLine(ctx, bcToX, bcToY-5, W-15, 100, 'BOOM-CYL', false, 'boom-cyl');
}

function resizeAnatomyCanvases(){
  const cc=document.getElementById('canvas-cross'),cs=document.getElementById('canvas-side');
  if(cc)cc.width=cc.offsetWidth||cc.parentElement?.offsetWidth||600;
  if(cs)cs.width=cs.offsetWidth||cs.parentElement?.offsetWidth||600;
  if(engine3d&&engine3d.resize)engine3d.resize();
}
let _anatLastT = 0;
function animateAnatomy(ts){
  const dtAnat = ts - _anatLastT;
  if(dtAnat >= 16){ // ~60fps cap
    _anatLastT = ts;
    anatomyAnimTime += 0.016;
    const cc=document.getElementById('canvas-cross'),cs=document.getElementById('canvas-side');
    if(cc&&cc.width>0)drawCrossSection(cc);
    if(cs&&cs.width>0)drawSideView(cs);
  }
  requestAnimationFrame(animateAnatomy);
}

/* 
   DAMAGE PINS OVERLAY
 */
const PIN_COORDS={
  cross:{'housing':{x:50,y:10},'stator-core':{x:50,y:20},'winding-a':{x:50,y:30},'rotor':{x:50,y:50},'front-bearing':{x:50,y:50},'shaft':{x:50,y:50},'cooling-fins':{x:90,y:20}},
  side:{'housing':{x:50,y:15},'stator-core':{x:45,y:30},'winding-a':{x:30,y:35},'terminal-box':{x:50,y:5},'rotor':{x:50,y:50},'shaft':{x:85,y:50},'front-bearing':{x:20,y:50},'rear-bearing':{x:80,y:50},'cooling-fins':{x:45,y:5}}
};
function updateDamagePins(){
  ['cross','side'].forEach(view=>{
    const c=document.getElementById(`canvas-${view}`),cont=document.getElementById(`damage-pins-${view}`);
    if(!c||!cont)return;
    cont.innerHTML='';
    const w=c.offsetWidth,h=c.offsetHeight;if(w===0||h===0)return;
    const drawn=new Set();
    const addPin=(id,isWarn)=>{
      if(drawn.has(id)||!PIN_COORDS[view][id])return;
      drawn.add(id);
      const pos=PIN_COORDS[view][id],px=(pos.x/100)*w,py=(pos.y/100)*h;
      const pin=document.createElement('div');pin.className='damage-pin';pin.style.left=px+'px';pin.style.top=py+'px';
      const pClass=isWarn?'warn':'';
      const label=PART_METADATA.find(p=>p.id===id)?.label||id.toUpperCase();
      pin.innerHTML=`<div class="damage-pin-ring ${pClass}"></div><div class="damage-pin-dot ${pClass}"></div><div class="damage-label ${pClass}">${label} [${isWarn?'WARN':'CRIT'}]</div>`;
      cont.appendChild(pin);
    };
    anatomyAlertParts.forEach(id=>addPin(id,false));
    anatomyWarnParts.forEach(id=>addPin(id,true));
    // Update badges (SteelGuard uses view-badge-sg class)
    const updateBadge=(bid,parts,labels)=>{
      const bd=document.getElementById(bid);if(!bd)return;
      const isAlert=parts.some(p=>anatomyAlertParts.has(p));
      const isWarn=!isAlert&&parts.some(p=>anatomyWarnParts.has(p));
      bd.className='view-badge-sg'+(isAlert?' alert':isWarn?' warn-badge':'');
      bd.textContent=labels[isAlert?0:isWarn?1:2];
    };
    if(view==='cross'){
      updateBadge('badge-cross-status',['housing','stator-core','rotor'],['STRUCTURAL COMPROMISE','STRUCTURAL STRESS','NOMINAL']);
      updateBadge('badge-cross-phase',['winding-a','winding-b','winding-c'],['PHASE FAULT','PHASE IMBALANCE','PHASE A/B/C: OK']);
      updateBadge('badge-cross-bearing',['front-bearing'],['BRG CRITICAL','BRG WEAR','BEARINGS: OK']);
    }else{
      updateBadge('badge-side-status',['terminal-box','housing'],['SYS FAIL','SYS DEGRADED','SYS NOMINAL']);
      updateBadge('badge-side-shaft',['shaft','rotor'],['SHAFT CRITICAL','SHAFT VIB','SHAFT: OK']);
      updateBadge('badge-side-thermal',['cooling-fins','stator-core'],['THERMAL RUNAWAY','ELEVATED TEMP','THERMAL: OK']);
    }
  });
}

/* 
   3D MOTOR ENGINE  (from JARVIS)
 */
const engine3d={
  canvas:null,ctx:null,w:0,h:0,
  pitch:0.32,yaw:0.7,dist:380,zoom:1.8,
  autoRotate:true,explode:0,wireframe:false,
  isDragging:false,lastX:0,lastY:0,parts:[],_rig:null,
  init(){
    this.canvas=document.getElementById('canvas-3d');if(!this.canvas)return;
    this.ctx=this.canvas.getContext('2d');this.resize();this.buildGeometry();
    const wrap=document.getElementById('motor3d-wrap');
    if(wrap){
      wrap.addEventListener('mousedown',e=>{this.isDragging=true;this.lastX=e.clientX;this.lastY=e.clientY;this.autoRotate=false;document.getElementById('btn3d-rotate')?.classList.remove('active');});
      window.addEventListener('mouseup',()=>this.isDragging=false);
      window.addEventListener('mousemove',e=>{if(!this.isDragging)return;this.yaw+=(e.clientX-this.lastX)*0.01;this.pitch+=(e.clientY-this.lastY)*0.01;this.pitch=Math.max(-Math.PI/2,Math.min(Math.PI/2,this.pitch));this.lastX=e.clientX;this.lastY=e.clientY;});
      wrap.addEventListener('wheel',e=>{e.preventDefault();this.dist+=e.deltaY*0.5;this.dist=Math.max(180,Math.min(900,this.dist));},{passive:false});
    }
    window.addEventListener('resize',()=>this.resize());
    this.renderLoop();
  },
  resize(){if(!this.canvas)return;this.w=this.canvas.width=this.canvas.offsetWidth;this.h=this.canvas.height=this.canvas.offsetHeight;},
  buildGeometry(){
    // Excavator coords: +X right, +Y down, +Z into scene (bucket faces -Z).
    const bp={x:0,y:18,z:-80};
    const boomLen=155, boomAngMag=35*Math.PI/180;
    const boomEnd={x:bp.x, y:bp.y-Math.sin(boomAngMag)*boomLen, z:bp.z-Math.cos(boomAngMag)*boomLen};
    const stickLen=115, stickAngMag=60*Math.PI/180;
    const stickEnd={x:boomEnd.x, y:boomEnd.y+Math.sin(stickAngMag)*stickLen, z:boomEnd.z-Math.cos(stickAngMag)*stickLen};
    this._rig={bp,boomEnd,stickEnd,boomAngMag,stickAngMag,boomLen,stickLen};
    this.parts=[
      {id:'track-left', type:'box3d', w:30,h:28,d:230,x:-62,y:82,z:0, col:'#0a0518',stroke:'rgba(77,166,232,0.55)',detail:'track',exX:-30},
      {id:'track-right',type:'box3d', w:30,h:28,d:230,x:62, y:82,z:0, col:'#0a0518',stroke:'rgba(77,166,232,0.55)',detail:'track',exX:30},
      {id:'undercarriage',type:'box3d', w:160,h:14,d:140,x:0,y:58,z:0, col:'#0d0622',stroke:'rgba(43,144,217,0.5)',exY:-5},
      {id:'slewing-ring',type:'disc-y', r:55,h:12,x:0,y:48,z:0, col:'#16092e',stroke:'rgba(139,92,246,0.7)',exY:-15},
      {id:'upper-platform',type:'box3d', w:130,h:14,d:165,x:0,y:37,z:0, col:'#0e0620',stroke:'rgba(43,144,217,0.5)',exY:-10},
      {id:'operator-cab',type:'box3d', w:52,h:62,d:68,x:-42,y:-1,z:-55, col:'#140830',stroke:'rgba(77,166,232,0.6)',detail:'cab',exY:-55},
      {id:'engine-bay', type:'box3d', w:118,h:50,d:72,x:4,y:5,z:48, col:'#100628',stroke:'rgba(43,144,217,0.55)',detail:'vents',exY:-50,exZ:10},
      {id:'counterweight',type:'box3d', w:134,h:44,d:28,x:0,y:10,z:92, col:'#050210',stroke:'rgba(77,166,232,0.55)',exZ:50},
      {id:'boom', type:'angled-box', w:24,h:32,from:bp,to:boomEnd, col:'#140826',stroke:'rgba(139,92,246,0.7)',exY:-30},
      {id:'stick',type:'angled-box', w:19,h:26,from:boomEnd,to:stickEnd, col:'#0f0620',stroke:'rgba(139,92,246,0.7)',exY:-45,exZ:-20},
      {id:'bucket',type:'bucket', pivot:stickEnd, size:36, col:'#120828',stroke:'rgba(139,92,246,0.75)',exY:-15,exZ:-30},
      {id:'boom-cyl', type:'hyd-cyl', r:4.5,
        from:{x:-22,y:27,z:-50},
        to:{x:bp.x, y:bp.y-Math.sin(boomAngMag)*boomLen*0.40, z:bp.z-Math.cos(boomAngMag)*boomLen*0.40},
        col:'#1f0d3a',stroke:'rgba(139,92,246,0.85)'},
      {id:'stick-cyl',type:'hyd-cyl', r:4,
        from:{x:bp.x, y:bp.y-Math.sin(boomAngMag)*boomLen*0.15-18, z:bp.z-Math.cos(boomAngMag)*boomLen*0.15},
        to:{x:boomEnd.x, y:boomEnd.y+Math.sin(stickAngMag)*stickLen*0.22-4, z:boomEnd.z-Math.cos(stickAngMag)*stickLen*0.22},
        col:'#1f0d3a',stroke:'rgba(139,92,246,0.85)'},
      {id:'bucket-cyl',type:'hyd-cyl', r:3.5,
        from:{x:boomEnd.x, y:boomEnd.y+Math.sin(stickAngMag)*stickLen*0.10-14, z:boomEnd.z-Math.cos(stickAngMag)*stickLen*0.10},
        to:{x:stickEnd.x, y:stickEnd.y-18, z:stickEnd.z+6},
        col:'#1f0d3a',stroke:'rgba(139,92,246,0.85)'}
    ];
  },
  project(x,y,z){
    const sY=Math.sin(this.yaw),cY=Math.cos(this.yaw);
    const x1=x*cY-z*sY,z1=z*cY+x*sY;
    const sX=Math.sin(this.pitch),cX=Math.cos(this.pitch);
    const y2=y*cX-z1*sX,z2=z1*cX+y*sX;
    const f=this.zoom*900/(900+z2+this.dist);
    return{x:x1*f+this.w/2,y:y2*f+this.h/2,s:f,z:z2};
  },
  _shade(hex,k){
    if(!hex||hex.startsWith('rgb'))return hex;
    const h=hex.replace('#',''), r=parseInt(h.slice(0,2),16), g=parseInt(h.slice(2,4),16), b=parseInt(h.slice(4,6),16);
    const c=v=>Math.min(255,Math.max(0,Math.round(v*k)));
    return`rgb(${c(r)},${c(g)},${c(b)})`;
  },
  _off(p){const e=this.explode/100;return{dx:(p.exX||0)*e, dy:(p.exY||0)*e, dz:(p.exZ||0)*e};},
  _style(p){
    let fill=p.col, stroke=p.stroke, glow=0, glowCol='transparent', override=false;
    if(typeof anatomyAlertParts!=='undefined' && anatomyAlertParts.has(p.id)){
      fill='rgba(150,20,40,0.55)'; stroke='rgba(248,113,113,0.9)'; glow=14; glowCol='rgba(248,113,113,0.6)'; override=true;
    } else if(typeof anatomyWarnParts!=='undefined' && anatomyWarnParts.has(p.id)){
      fill='rgba(110,70,0,0.45)'; stroke='rgba(251,191,36,0.75)'; glow=8; glowCol='rgba(251,191,36,0.45)'; override=true;
    }
    return{fill,stroke,glow,glowCol,override};
  },
  renderLoop(ts){
    const dt=(ts||0)-(this._lastRenderT||0);
    if(dt>=16){this._lastRenderT=ts; if(this.autoRotate)this.yaw-=0.005; this.render();}
    requestAnimationFrame(t=>this.renderLoop(t));
  },
  render(){
    if(!this.ctx)return;
    const ctx=this.ctx;
    ctx.clearRect(0,0,this.w,this.h);
    // Ground grid
    ctx.save();ctx.globalAlpha=0.11;ctx.strokeStyle='rgba(43,144,217,0.35)';ctx.lineWidth=0.5;
    for(let i=-3;i<=3;i++){
      const a=this.project(i*45,112,-160), b=this.project(i*45,112,160);
      ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.stroke();
      const c=this.project(-160,112,i*45), d=this.project(160,112,i*45);
      ctx.beginPath();ctx.moveTo(c.x,c.y);ctx.lineTo(d.x,d.y);ctx.stroke();
    }
    ctx.restore();
    // Collect drawables
    const draws=[];
    this.parts.forEach(p=>{
      const off=this._off(p), st=this._style(p);
      switch(p.type){
        case 'box3d': this._box(draws,p,off,st); break;
        case 'disc-y': this._disc(draws,p,off,st); break;
        case 'angled-box': this._angBox(draws,p,off,st); break;
        case 'bucket': this._bucket(draws,p,off,st); break;
        case 'hyd-cyl': this._hyd(draws,p,off,st); break;
      }
    });
    draws.sort((a,b)=>b.z-a.z);
    draws.forEach(d=>{
      ctx.save();
      if(d.glow>0){ctx.shadowColor=d.glowCol;ctx.shadowBlur=d.glow;}
      ctx.globalAlpha=d.a||1;
      if(this.wireframe){ctx.fillStyle='transparent';ctx.strokeStyle=d.stroke;ctx.lineWidth=1;}
      else{ctx.fillStyle=d.fill;ctx.strokeStyle=d.stroke;ctx.lineWidth=d.lw||1;}
      ctx.beginPath();
      d.pts.forEach((p,i)=>i?ctx.lineTo(p.x,p.y):ctx.moveTo(p.x,p.y));
      ctx.closePath();
      if(!this.wireframe)ctx.fill();
      ctx.stroke();
      if(d.lines){
        ctx.shadowColor='transparent';ctx.shadowBlur=0;
        ctx.strokeStyle=d.lineStroke||'rgba(77,166,232,0.3)';ctx.lineWidth=0.7;
        d.lines.forEach(ln=>{ctx.beginPath();ctx.moveTo(ln[0].x,ln[0].y);ctx.lineTo(ln[1].x,ln[1].y);ctx.stroke();});
      }
      ctx.restore();
    });
  },
  _cullCW(pts){
    const c=(pts[1].x-pts[0].x)*(pts[2].y-pts[0].y)-(pts[2].x-pts[0].x)*(pts[1].y-pts[0].y);
    return c>=0;
  },
  _box(out,p,off,st){
    const cx=p.x+off.dx, cy=p.y+off.dy, cz=p.z+off.dz;
    const hw=p.w/2, hh=p.h/2, hd=p.d/2;
    const V=[];
    for(const sy of [-1,1])for(const sx of [-1,1])for(const sz of [-1,1])
      V.push(this.project(cx+sx*hw, cy+sy*hh, cz+sz*hd));
    // V ordering by (sy,sx,sz): sy=-1 first, then sx=-1, then sz=-1
    // 0:(-,-,-) 1:(-,-,+) 2:(-,+,-) 3:(-,+,+) 4:(+,-,-) 5:(+,-,+) 6:(+,+,-) 7:(+,+,+)
    const faces=[
      {i:[0,2,3,1], s:1.35, n:'top'},    // sy=-1 face (top, lit)
      {i:[5,7,6,4], s:0.55, n:'bottom'}, // sy=+1 (bottom, dark)
      {i:[0,1,5,4], s:0.88, n:'left'},   // sx=-1
      {i:[3,2,6,7], s:0.88, n:'right'},  // sx=+1
      {i:[2,0,4,6], s:0.72, n:'back'},   // sz=-1
      {i:[1,3,7,5], s:1.12, n:'front'},  // sz=+1
    ];
    faces.forEach(f=>{
      const pts=f.i.map(i=>V[i]);
      if(this._cullCW(pts))return;
      const z=(pts[0].z+pts[1].z+pts[2].z+pts[3].z)/4;
      const fill=st.override?st.fill:this._shade(p.col,f.s);
      let lines=null, lineStroke=null;
      if(p.detail==='track'){
        if(f.n==='bottom'||f.n==='left'||f.n==='right'){
          lines=[];
          const NP=14;
          for(let k=1;k<NP;k++){
            const t=k/NP;
            lines.push([
              {x:pts[0].x+(pts[1].x-pts[0].x)*t, y:pts[0].y+(pts[1].y-pts[0].y)*t},
              {x:pts[3].x+(pts[2].x-pts[3].x)*t, y:pts[3].y+(pts[2].y-pts[3].y)*t}
            ]);
          }
          lineStroke='rgba(43,144,217,0.3)';
        }
      } else if(p.detail==='cab' && f.n==='front'){
        const q=(t1,t2)=>({
          x: pts[0].x*(1-t1)*(1-t2)+pts[1].x*t1*(1-t2)+pts[2].x*t1*t2+pts[3].x*(1-t1)*t2,
          y: pts[0].y*(1-t1)*(1-t2)+pts[1].y*t1*(1-t2)+pts[2].y*t1*t2+pts[3].y*(1-t1)*t2
        });
        lines=[[q(0.18,0.12),q(0.82,0.12)],[q(0.82,0.12),q(0.82,0.58)],[q(0.82,0.58),q(0.18,0.58)],[q(0.18,0.58),q(0.18,0.12)]];
        lineStroke='rgba(139,92,246,0.55)';
      } else if(p.detail==='vents' && (f.n==='top'||f.n==='right'||f.n==='back')){
        const q=(t1,t2)=>({
          x: pts[0].x*(1-t1)*(1-t2)+pts[1].x*t1*(1-t2)+pts[2].x*t1*t2+pts[3].x*(1-t1)*t2,
          y: pts[0].y*(1-t1)*(1-t2)+pts[1].y*t1*(1-t2)+pts[2].y*t1*t2+pts[3].y*(1-t1)*t2
        });
        lines=[];
        for(let k=1;k<8;k++){const t=k/8;lines.push([q(0.12,t),q(0.88,t)]);}
        lineStroke='rgba(43,144,217,0.3)';
      }
      out.push({pts,fill,stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:1,lines,lineStroke});
    });
  },
  _disc(out,p,off,st){
    const cx=p.x+off.dx, cy=p.y+off.dy, cz=p.z+off.dz;
    const N=30;
    const top=[], bot=[];
    for(let i=0;i<N;i++){const a=(i/N)*Math.PI*2;
      top.push(this.project(cx+Math.cos(a)*p.r, cy-p.h/2, cz+Math.sin(a)*p.r));
      bot.push(this.project(cx+Math.cos(a)*p.r, cy+p.h/2, cz+Math.sin(a)*p.r));
    }
    // top face
    let ta=0; for(let i=0;i<N;i++){const j=(i+1)%N;ta+=top[i].x*top[j].y-top[j].x*top[i].y;}
    if(ta<0){const z=top.reduce((s,q)=>s+q.z,0)/N; out.push({pts:top,fill:st.override?st.fill:this._shade(p.col,1.25),stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:1});}
    let ba=0; for(let i=0;i<N;i++){const j=(i+1)%N;ba+=bot[i].x*bot[j].y-bot[j].x*bot[i].y;}
    if(ba>0){const z=bot.reduce((s,q)=>s+q.z,0)/N; out.push({pts:bot,fill:st.override?st.fill:this._shade(p.col,0.6),stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:1});}
    for(let i=0;i<N;i++){
      const j=(i+1)%N, pts=[top[i],top[j],bot[j],bot[i]];
      if(this._cullCW(pts))continue;
      const z=(top[i].z+top[j].z+bot[i].z+bot[j].z)/4;
      out.push({pts,fill:st.override?st.fill:this._shade(p.col,0.88),stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:0.5});
    }
  },
  _angBox(out,p,off,st){
    const from={x:p.from.x+off.dx,y:p.from.y+off.dy,z:p.from.z+off.dz};
    const to={x:p.to.x+off.dx,y:p.to.y+off.dy,z:p.to.z+off.dz};
    const dx=to.x-from.x, dy=to.y-from.y, dz=to.z-from.z;
    const L=Math.sqrt(dx*dx+dy*dy+dz*dz);
    const ux=dx/L, uy=dy/L, uz=dz/L;
    // For arm in YZ plane (x fixed): up vector perpendicular in YZ plane
    const pyz=Math.sqrt(uz*uz+uy*uy);
    const vx=0, vy=pyz>0?-uz/pyz:-1, vz=pyz>0?uy/pyz:0;
    // Width axis = u × v
    const wx=uy*vz-uz*vy, wy=uz*vx-ux*vz, wz=ux*vy-uy*vx;
    const wL=Math.sqrt(wx*wx+wy*wy+wz*wz)||1;
    const Wx=wx/wL, Wy=wy/wL, Wz=wz/wL;
    const V=[];
    for(const t of [0,1])for(const hi of [-0.5,0.5])for(const wi of [-0.5,0.5])
      V.push(this.project(
        from.x+t*L*ux+hi*p.h*vx+wi*p.w*Wx,
        from.y+t*L*uy+hi*p.h*vy+wi*p.w*Wy,
        from.z+t*L*uz+hi*p.h*vz+wi*p.w*Wz
      ));
    // V[t*4 + (hi>0?2:0) + (wi>0?1:0)]
    // 0:(0,-,-) 1:(0,-,+) 2:(0,+,-) 3:(0,+,+) 4:(1,-,-) 5:(1,-,+) 6:(1,+,-) 7:(1,+,+)
    const faces=[
      {i:[0,1,3,2], s:0.72},  // t=0 (from cap)
      {i:[4,6,7,5], s:0.72},  // t=1 (to cap)
      {i:[0,4,5,1], s:1.30},  // hi=-0.5 (up)
      {i:[2,3,7,6], s:0.55},  // hi=+0.5 (down)
      {i:[0,2,6,4], s:0.90},  // wi=-0.5
      {i:[1,5,7,3], s:0.90}   // wi=+0.5
    ];
    faces.forEach(f=>{
      const pts=f.i.map(i=>V[i]);
      if(this._cullCW(pts))return;
      const z=(pts[0].z+pts[1].z+pts[2].z+pts[3].z)/4;
      const fill=st.override?st.fill:this._shade(p.col,f.s);
      out.push({pts,fill,stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:1});
    });
  },
  _bucket(out,p,off,st){
    const c={x:p.pivot.x+off.dx, y:p.pivot.y+off.dy, z:p.pivot.z+off.dz};
    const s=p.size;
    const cy=c.y+s*0.45, cz=c.z-s*0.1;
    const bw=s*0.5, bh=s*0.7, bd=s*0.8;
    // Core bucket box (curved front is simulated by teeth)
    const V=[];
    for(const sy of [-1,1])for(const sx of [-1,1])for(const sz of [-1,1])
      V.push(this.project(c.x+sx*bw, cy+sy*bh/2, cz+sz*bd/2));
    const faces=[
      {i:[0,2,3,1], s:1.30},
      {i:[5,7,6,4], s:0.55},
      {i:[0,1,5,4], s:0.88},
      {i:[3,2,6,7], s:0.88},
      {i:[2,0,4,6], s:1.05}, // front (back-in-world, but bucket opens backward, so front face shows)
      {i:[1,3,7,5], s:0.72}  // back
    ];
    faces.forEach(f=>{
      const pts=f.i.map(i=>V[i]);
      if(this._cullCW(pts))return;
      const z=(pts[0].z+pts[1].z+pts[2].z+pts[3].z)/4;
      const fill=st.override?st.fill:this._shade(p.col,f.s);
      out.push({pts,fill,stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:1});
    });
    // Teeth on front-bottom edge (pointing -Z, toward viewer in front view)
    const NT=5;
    for(let i=0;i<NT;i++){
      const t=(i+0.5)/NT, tx=c.x-bw+t*bw*2, ty=cy+bh/2, tz=cz-bd/2;
      const tip=this.project(tx, ty+s*0.15, tz-s*0.18);
      const l=this.project(tx-s*0.07, ty, tz);
      const r=this.project(tx+s*0.07, ty, tz);
      const pts=[tip,r,l];
      if(this._cullCW(pts))continue;
      const z=(tip.z+r.z+l.z)/3;
      const fill=st.override?st.fill:this._shade(p.col,1.1);
      out.push({pts,fill,stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:0.8});
    }
  },
  _hyd(out,p,off,st){
    const f={x:p.from.x+off.dx,y:p.from.y+off.dy,z:p.from.z+off.dz};
    const t={x:p.to.x+off.dx,y:p.to.y+off.dy,z:p.to.z+off.dz};
    const pf=this.project(f.x,f.y,f.z), pt=this.project(t.x,t.y,t.z);
    const dx=pt.x-pf.x, dy=pt.y-pf.y;
    const L=Math.sqrt(dx*dx+dy*dy)||1;
    const nx=-dy/L, ny=dx/L;
    const r1=p.r*pf.s, r2=p.r*pt.s;
    const pts=[
      {x:pf.x+nx*r1, y:pf.y+ny*r1},
      {x:pt.x+nx*r2, y:pt.y+ny*r2},
      {x:pt.x-nx*r2, y:pt.y-ny*r2},
      {x:pf.x-nx*r1, y:pf.y-ny*r1}
    ];
    const z=(pf.z+pt.z)/2;
    const fill=st.override?st.fill:this._shade(p.col,1.0);
    // Mid-piston line as a detail
    const m={x:(pf.x+pt.x)/2, y:(pf.y+pt.y)/2};
    const rM=(r1+r2)/2;
    const lines=[[{x:m.x+nx*rM*0.85,y:m.y+ny*rM*0.85},{x:m.x-nx*rM*0.85,y:m.y-ny*rM*0.85}]];
    out.push({pts,fill,stroke:st.stroke,glow:st.glow,glowCol:st.glowCol,z,lw:1,lines,lineStroke:'rgba(139,92,246,0.55)'});
  }
};
function toggle3DRotate(btn){engine3d.autoRotate=!engine3d.autoRotate;btn.classList.toggle('active',engine3d.autoRotate);}
function toggle3DExplode(btn){const bar=document.getElementById('explode-bar-wrap');const active=btn.classList.toggle('active');bar.style.display=active?'flex':'none';if(!active){document.getElementById('explode-slider').value=0;setExplode(0);}else{document.getElementById('explode-slider').value=60;setExplode(60);}}
function toggle3DWire(btn){engine3d.wireframe=!engine3d.wireframe;btn.classList.toggle('active',engine3d.wireframe);}
function reset3DView(){engine3d.pitch=0.32;engine3d.yaw=0.7;engine3d.dist=380;engine3d.zoom=1.8;engine3d.explode=0;engine3d.autoRotate=true;engine3d.wireframe=false;document.getElementById('btn3d-rotate')?.classList.add('active');document.getElementById('btn3d-explode')?.classList.remove('active');document.getElementById('btn3d-wire')?.classList.remove('active');document.getElementById('explode-bar-wrap').style.display='none';document.getElementById('explode-slider').value=0;}
function setExplode(val){engine3d.explode=parseFloat(val);}

/* 
   FAULT INJECTION — MULTI-PARAMETER BUFFER ENGINE
 */
let customInjActive = false;
const INJ_BUF_SIZE = 24;
// Each channel holds a 24-sample noise buffer and a cycling index
const injBuffers = {
  temp: { buf: [], idx: 0, active: false },
  cur:  { buf: [], idx: 0, active: false },
  pres: { buf: [], idx: 0, active: false },
  vib:  { buf: [], idx: 0, active: false },
};

// Build a 24-sample noise buffer around a target value ±3% jitter
// Tight band keeps displayed values very close to the user-specified target
function buildInjBuf(target) {
  const lo = target * 0.97, hi = target * 1.03;
  return Array.from({ length: INJ_BUF_SIZE }, () => +(lo + Math.random() * (hi - lo)).toFixed(3)
  );
}

// Returns next buffered value for a channel (cycling), or null if inactive
function getInjVal(key) {
  const ch = injBuffers[key];
  if (!ch || !ch.active || ch.buf.length === 0) return null;
  const v = ch.buf[ch.idx % ch.buf.length];
  ch.idx = (ch.idx + 1) % ch.buf.length;
  return v;
}

// Threshold helpers
function getThreshTemp()  { return parseFloat(document.getElementById('cfg-alarm-temp')?.value) || 80; }
function getThreshCur()   { return parseFloat(document.getElementById('cfg-alarm-cur')?.value)  || 10; }
function getThreshPres()  { return parseFloat(document.getElementById('cfg-alarm-pres')?.value) || 1013; }
function getThreshVib()   { return parseFloat(document.getElementById('cfg-alarm-vib')?.value)  || 1.5; }

// Fired on every slider move — updates labels, status badges, preview rows
function updateInjPreview() {
  const params = [
    {
      key: 'temp', pctId: 'inj-temp-pct', dispId: 'inj-temp-pct-disp',
      statusId: 'inj-temp-status', previewId: 'inj-temp-preview', refId: 'inj-temp-ref',
      rangeId: 'prev-temp-range', badgeId: 'prev-temp-badge', rowId: 'inj-row-temp',
      thresh: getThreshTemp(), unit: '°C', label: 'Temperature',
      unitFmt: v => v.toFixed(1) + '°C',
    },
    {
      key: 'cur', pctId: 'inj-cur-pct', dispId: 'inj-cur-pct-disp',
      statusId: 'inj-cur-status', previewId: 'inj-cur-preview', refId: 'inj-cur-ref',
      rangeId: 'prev-cur-range', badgeId: 'prev-cur-badge', rowId: 'inj-row-cur',
      thresh: getThreshCur(), unit: 'A', label: 'Current',
      unitFmt: v => v.toFixed(2) + ' A',
    },
    {
      key: 'pres', pctId: 'inj-pres-pct', dispId: 'inj-pres-pct-disp',
      statusId: 'inj-pres-status', previewId: 'inj-pres-preview', refId: 'inj-pres-ref',
      rangeId: 'prev-pres-range', badgeId: 'prev-pres-badge', rowId: 'inj-row-pres',
      thresh: getThreshPres(), unit: 'hPa', label: 'Pressure',
      unitFmt: v => Math.round(v) + ' hPa',
    },
    {
      key: 'vib', pctId: 'inj-vib-pct', dispId: 'inj-vib-pct-disp',
      statusId: 'inj-vib-status', previewId: 'inj-vib-preview', refId: 'inj-vib-ref',
      rangeId: 'prev-vib-range', badgeId: 'prev-vib-badge', rowId: 'inj-row-vib',
      thresh: getThreshVib(), unit: 'g', label: 'Vibrational Imbalance',
      unitFmt: v => v.toFixed(3) + ' g',
    },
  ];

  params.forEach(p => {
    const slider = document.getElementById(p.pctId);
    if (!slider) return;
    const pct = parseFloat(slider.value) || 0;
    const target = (pct / 100) * p.thresh;
    const lo = target * 0.97, hi = target * 1.03;
    const isActive = pct > 0;
    const isOver = pct >= 100;
    const isWarn = pct >= 70 && pct < 100;

    // Update threshold reference label
    const refEl = document.getElementById(p.refId);
    if (refEl) {
      const label = p.key === 'rpm' ? 'Nominal' : 'Threshold';
      refEl.textContent = `${label}: ${p.unitFmt ? p.unitFmt(p.thresh) : p.thresh + ' ' + p.unit}`;
    }

    // Slider display label
    const dispEl = document.getElementById(p.dispId);
    if (dispEl) dispEl.textContent = isActive ? pct + '%' : 'OFF';

    // Status badge on slider row
    const statusEl = document.getElementById(p.statusId);
    if (statusEl) {
      if (!isActive) {
        statusEl.textContent = 'OFF';
        statusEl.style.cssText = 'color:var(--muted);border-color:rgba(43,144,217,0.15);background:rgba(255,255,255,0.04);';
      } else if (isOver) {
        statusEl.textContent = ' OVER';
        statusEl.style.cssText = 'color:var(--red);border-color:rgba(248,113,113,0.5);background:rgba(248,113,113,0.08);';
      } else if (isWarn) {
        statusEl.textContent = ' WARN';
        statusEl.style.cssText = 'color:var(--yellow);border-color:rgba(251,191,36,0.5);background:rgba(251,191,36,0.06);';
      } else {
        statusEl.textContent = ' ACTIVE';
        statusEl.style.cssText = 'color:var(--green);border-color:rgba(52,211,153,0.4);background:rgba(52,211,153,0.08);';
      }
    }

    // Preview text under slider
    const prevEl = document.getElementById(p.previewId);
    if (prevEl) {
      if (!isActive) {
        prevEl.textContent = `Not injecting — motor simulation uses natural ${p.label.toLowerCase()} model`;
        prevEl.style.color = 'var(--muted)';
      } else {
        const loFmt = p.unitFmt(lo), hiFmt = p.unitFmt(hi), tFmt = p.unitFmt(target);
        prevEl.textContent = `Injecting ${pct}% of threshold (${tFmt}) · 24-sample buffer stays within ±3% of target (${loFmt} → ${hiFmt})`;
        prevEl.style.color = isOver ? 'var(--red)' : isWarn ? 'var(--yellow)' : '#a0c8e0';
      }
    }

    // Row highlight
    const rowEl = document.getElementById(p.rowId);
    if (rowEl) {
      rowEl.style.borderColor = !isActive ? '' : isOver ? 'rgba(248,113,113,0.4)' : isWarn ? 'rgba(251,191,36,0.35)' : 'rgba(52,211,153,0.3)';
    }

    // Preview panel (right card)
    const rangeEl = document.getElementById(p.rangeId);
    if (rangeEl) {
      rangeEl.textContent = isActive
        ? `${p.unitFmt(lo)} → ${p.unitFmt(hi)}  (target: ${p.unitFmt(target)})`
        : '— not active';
    }
    const badgeEl = document.getElementById(p.badgeId);
    if (badgeEl) {
      if (!isActive) {
        badgeEl.textContent = 'OFF';
        badgeEl.style.cssText = 'color:var(--muted);border-color:rgba(43,144,217,0.15);background:rgba(255,255,255,0.04);';
      } else if (isOver) {
        badgeEl.textContent = ' OVER';
        badgeEl.style.cssText = 'color:var(--red);border-color:rgba(248,113,113,0.5);background:rgba(248,113,113,0.08);';
      } else {
        badgeEl.textContent = pct + '%';
        badgeEl.style.cssText = isWarn
          ? 'color:var(--yellow);border-color:rgba(251,191,36,0.45);background:rgba(251,191,36,0.06);'
          : 'color:var(--green);border-color:rgba(52,211,153,0.4);background:rgba(52,211,153,0.08);';
      }
    }
  });
  // Keep RUL page in sync with injection sliders
  updateRULPage();
}

// Called when "Inject All Active Parameters" is clicked
function injectCustomParams() {
  const configs = [
    { key: 'temp', pctId: 'inj-temp-pct', thresh: getThreshTemp() },
    { key: 'cur',  pctId: 'inj-cur-pct',  thresh: getThreshCur()  },
    { key: 'pres', pctId: 'inj-pres-pct', thresh: getThreshPres() },
    { key: 'vib',  pctId: 'inj-vib-pct',  thresh: getThreshVib()  },
  ];

  let activeCount = 0;
  const activeLabels = [];

  configs.forEach(cfg => {
    const slider = document.getElementById(cfg.pctId);
    const pct = parseFloat(slider?.value) || 0;
    const ch = injBuffers[cfg.key];
    if (pct > 0) {
      const target = (pct / 100) * cfg.thresh;
      ch.buf = buildInjBuf(target);
      ch.idx = 0;
      ch.active = true;
      activeCount++;
      activeLabels.push(cfg.key.toUpperCase() + '@' + pct + '%');
    } else {
      ch.buf = [];
      ch.idx = 0;
      ch.active = false;
    }
  });

  customInjActive = activeCount > 0;

  // Update the status bar
  const afd = document.getElementById('active-fault-display');
  if (afd) afd.textContent = activeCount > 0 ? activeLabels.join(' · ') : 'NONE';
  const afs = document.getElementById('active-fault-since');
  if (afs) afs.textContent = activeCount > 0 ? new Date().toLocaleTimeString() : '—';

  if (activeCount > 0) {
    twinMode = 'fault';
    faultType = 'none';
    addLog(` Fault injected — ${activeCount} channel(s): ${activeLabels.join(', ')}`,'crit');
    // Clear chart history so old furnace-scale data doesn't mix with injected motor values
    clearChartHistoryForInjection();
    // Switch to Motor Anatomy to observe
    const anEl = document.querySelector('.nav-item[onclick*="anatomy"]');
    goPage('anatomy', anEl);
  }
}

/* 
   MAIN TWIN TICK + CONTROLS
   (twinTick and resetSim defined after updateAllTabsFromTwin below)
 */

function setMode(m,evt){
  twinMode=m;
  if(m==='normal'){
    faultType='none';faultOnset=-1;faultSeverity=0;
    resetAllTabsToBaseline();
  } else {
    // Clear stale furnace-scale chart data before injection takes over
    clearChartHistoryForInjection();
  }
  document.querySelectorAll('.twin-btn').forEach(b=>b.classList.remove('active'));
  if(evt&&evt.target)evt.target.classList.add('active');
  const sl=document.getElementById('sim-mode-label');
  if(sl)sl.textContent='MODE: '+m.toUpperCase()+(faultType!=='none'?' · '+faultType.replace(/_/g,' ').toUpperCase():'');
  // Immediately propagate non-normal state to all tabs
  if(m!=='normal'){const r=getTwinReading();twinStep--;updateAllTabsFromTwin(r);}
}

function injectFaultFromTab(){
  const sel=document.getElementById('fault-select-main')?.value;
  if(!sel||sel==='none')return;
  faultType=sel;
  faultSeverity=parseFloat(document.getElementById('severity-slider')?.value)||0.9;
  faultOnset=twinStep;twinMode='degrading';
  document.querySelectorAll('.twin-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector('.twin-btn.warn-btn')?.classList.add('active');
  // Navigate to anatomy page
  const anEl=document.querySelector('.nav-item[onclick*="anatomy"]');
  goPage('anatomy',anEl);
}

function updateTickInterval(val){
  tickInterval=parseInt(val);
  const cv=document.getElementById('cfg-tick-val');if(cv)cv.textContent=val+'ms';
  startTicker();
}

function updateFaultPreview(){
  const sel=document.getElementById('fault-select-main')?.value;
  const desc=document.getElementById('fault-description');
  const eff=faultEffects[sel];
  if(!eff||sel==='none'){
    if(desc)desc.textContent='Select a fault type to preview expected sensor responses.';
    ['fstat-temp','fstat-vib','fstat-rpm','fstat-cur'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='—';});
    return;
  }
  if(desc)desc.textContent=faultDescs[sel]||'';
  const ft=document.getElementById('fstat-temp');if(ft)ft.textContent='+'+eff.temp+'°C';
  const fv=document.getElementById('fstat-vib');if(fv)fv.textContent=eff.vibMul+'x';
  const fr=document.getElementById('fstat-rpm');if(fr)fr.textContent=eff.rpm+' RPM';
  const fc=document.getElementById('fstat-cur');if(fc)fc.textContent='+'+eff.cur+' A';
}

function startTicker(){
  if(tickTimer)clearInterval(tickTimer);
  tickTimer=setInterval(twinTick,tickInterval);
}

function resizeGaugeCanvases(){
  ['gauge-temp','gauge-vib','gauge-cur',
   'ov-gauge-temp','ov-gauge-vib','ov-gauge-cur','ov-gauge-pres'].forEach(id=>{
    const c=document.getElementById(id);
    if(c)c.width=c.offsetWidth||c.parentElement?.offsetWidth||200;
  });
}
window.addEventListener('resize',()=>{resizeGaugeCanvases();resizeTwinChartCanvases();drawTwinChart();resizeOvGauges();});
function resizeOvGauges(){
  ['ov-gauge-temp','ov-gauge-vib','ov-gauge-cur','ov-gauge-pres'].forEach(id=>{
    const c=document.getElementById(id);
    if(!c)return;
    const w=Math.round(c.getBoundingClientRect().width||c.parentElement?.getBoundingClientRect().width||200);
    if(w>10)c.width=w;
  });
}
// ─── drawOvGauges ──────────────────────────────────────────────────────────────
// Draws 4 live gauges driven by /machine_data.csv: Temperature, Current, Pressure, Vibration.
// Alarm thresholds (hardware spec): Temp=80°C | Current=10A | Pressure=1013hPa | Vib=1.5g
// Needle is scaled to sit at ~65% of full-scale at the alarm point — gives clear headroom.
// fp and rpm parameters removed — Fault Probability card has been retired from this tab.
// ──────────────────────────────────────────────────────────────────────────────
function drawOvGauges(temp, vib, cur, pres) {
  // Safe defaults — overwritten within 2 s by the first liveTick() fetch
  temp = (temp === undefined || isNaN(temp)) ? 45   : temp;
  vib  = (vib  === undefined || isNaN(vib))  ? 0.3  : vib;
  cur  = (cur  === undefined || isNaN(cur))  ? 4.2  : cur;
  pres = (pres === undefined || isNaN(pres)) ? 1013 : pres;

  // Helper: toggle alarm / warning border on the card wrapper
  const setOvCard = (id, alarm, warn) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.toggle('alarm',   alarm);
    el.classList.toggle('warning', warn && !alarm);
  };

  // Pull live thresholds from config sliders when the injection panel is present,
  // otherwise fall back to hardware-spec defaults.
  const aT = typeof getAlarmT    === 'function' ? getAlarmT()     : 80;    // °C
  const aV = typeof getAlarmV    === 'function' ? getAlarmV()     : 1.5;   // g
  const aC = typeof getAlarmCur  === 'function' ? getAlarmCur()   : 10;    // A
  const aP = typeof getThreshPres=== 'function' ? getThreshPres() : 1013;  // hPa

  // Scale each gauge so the alarm needle lands at ~65% of full-scale.
  // Max = 1.55 × alarm-threshold OR 1.25 × live value, whichever is larger.
  const tMax = Math.max(aT  * 1.55, temp * 1.25, aT  + 20);   // e.g. 80°C  → ~124
  const cMax = Math.max(aC  * 1.55, cur  * 1.25, aC  + 5);    // e.g. 10A   → ~15.5
  const pMax = Math.max(aP  * 1.15, pres * 1.10, aP  + 150);  // e.g. 1013  → ~1165
  const vMax = Math.max(aV  * 1.55, vib  * 1.25, aV  + 0.5);  // e.g. 1.5g  → ~2.3

  // Draw the 4 gauges
  drawGauge('ov-gauge-temp', { value: temp, max: tMax, warn: aT * 0.80, alarm: aT, color: '#f87171', label: 'Temperature',  unit: '°C'  });
  drawGauge('ov-gauge-cur',  { value: cur,  max: cMax, warn: aC * 0.75, alarm: aC, color: '#fbbf24', label: 'Current',      unit: 'A'   });
  drawGauge('ov-gauge-pres', { value: pres, max: pMax, warn: aP * 0.97, alarm: aP, color: '#22d3ee', label: 'Pressure',     unit: 'hPa' });
  drawGauge('ov-gauge-vib',  { value: vib,  max: vMax, warn: aV * 0.70, alarm: aV, color: '#4da6e8', label: 'Vibration',    unit: 'g'   });

  // Update card border state
  setOvCard('ov-card-temp', temp > aT,      temp > aT * 0.80);
  setOvCard('ov-card-cur',  cur  > aC,      cur  > aC * 0.75);
  setOvCard('ov-card-pres', pres > aP,      pres > aP * 0.97);
  setOvCard('ov-card-vib',  vib  > aV,      vib  > aV * 0.70);
}

/* 
   LIVE SIMULATION  (original website CSV tick)
 */
let reads=0,critCnt=0,warnCnt=0,anomalyCnt=0;
const t0=Date.now();
let alertLog=[
  {time:'00:00',msg:' System initialized — All 6 sensors online',cls:'ok'},
  {time:'00:10',msg:' Baseline calibration complete',cls:'ok'},
];
function ts(){return new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});}
function pushC(chart,val,di=0,max=60){chart.data.datasets[di].data.push(val);chart.data.labels.push('');if(chart.data.datasets[di].data.length>max){chart.data.datasets[di].data.shift();chart.data.labels.shift();}}
function addLog(msg,cls,tag){alertLog.unshift({time:ts(),msg,cls,tag:tag||null});if(alertLog.length>60)alertLog.pop();renderFeed();if(cls==='crit'){critCnt++;const ce=document.getElementById('a-crit');if(ce)ce.textContent=critCnt;}if(cls==='warn'){warnCnt++;const we=document.getElementById('a-warn');if(we)we.textContent=warnCnt;}const te=document.getElementById('a-total');if(te)te.textContent=alertLog.length;const badge=document.getElementById('alertBadge');const tot=critCnt+warnCnt;if(badge){badge.textContent=tot;badge.classList.toggle('show',tot>0);badge.style.background=critCnt?'var(--red)':'var(--yellow)';}}
function renderFeed(){
  const af=document.getElementById('alertFeed');
  if(!af)return;
  af.innerHTML=alertLog.slice(0,25).map(a=>{
    const tagCls=a.cls==='crit'?'alert-tag-crit':a.cls==='warn'?'alert-tag-warn':a.cls==='ok'?'alert-tag-ok':'alert-tag-info';
    const tagTxt=a.tag||(a.cls==='crit'?'FAULT':a.cls==='warn'?'WARN':a.cls==='ok'?'OK':'INFO');
    return `<div class="alert-row ${a.cls}"><span class="at">${a.time}</span><span class="${tagCls}">${tagTxt}</span><span style="font-size:0.68rem;color:${a.cls==='crit'?'rgba(248,113,113,0.9)':a.cls==='warn'?'rgba(251,191,36,0.9)':a.cls==='ok'?'rgba(52,211,153,0.85)':'rgba(43,144,217,0.8)'};">${a.msg}</span></div>`;
  }).join('');
}
function setKPI(cardId,valId,barId,statusId,val,max,dec){
  if(document.getElementById(valId))document.getElementById(valId).textContent=val.toFixed(dec);
  const pct=Math.min((val/max)*100,100);
  const bar=document.getElementById(barId);const card=document.getElementById(cardId);
  if(bar)bar.style.width=pct+'%';
  const sts=document.getElementById(statusId);
  if(pct>90){if(card)card.className='kpi crit';if(sts){sts.textContent=' Critical';sts.style.color='var(--red)';}}
  else if(pct>70){if(card)card.className='kpi warn';if(sts){sts.textContent=' Warning';sts.style.color='var(--yellow)';}}
  else{if(card)card.className='kpi';if(sts){sts.textContent=' Normal';sts.style.color='var(--green)';}}
}
function updateGauge(g,val,color){g.data.datasets[0].data=[val,100-val];g.data.datasets[0].backgroundColor[0]=color;g.update();}

// ============================================================================
//  TWINSENTINEL v17 — RUL TAB JAVASCRIPT UPDATE
//  Drop-in replacements for liveTick() and updateRULPage()
//  Only these two functions change. HTML, CSS, and all other JS are untouched.
// ============================================================================
 
 
// ─── liveTick ────────────────────────────────────────────────────────────────
// Fetches the latest row from the Flask endpoint /machine_data.csv every 2 s.
//
// CSV header (v17 backend — 11 columns):
//   Timestamp, Ambient, Dist, Gas, Vib, Temp, Current, Pressure,
//   Final_Status, RUL, Health_Pct
//
// Column indices (0-based):
//   0=Timestamp  1=Ambient  2=Dist  3=Gas  4=Vib  5=Temp  6=Current
//   7=Pressure   8=Final_Status   9=RUL (hours)   10=Health_Pct (0–100)
// ─────────────────────────────────────────────────────────────────────────────
// ─── liveTick ────────────────────────────────────────────────────────────────
async function liveTick() {
  reads++;
 
  // ── Uptime + read counter (always runs) ─────────────────────────────────
  const elapsed = Math.floor((Date.now() - t0) / 1000);
  const mm = String(Math.floor(elapsed / 60)).padStart(2, '0');
  const ss = String(elapsed % 60).padStart(2, '0');
  const supEl = document.getElementById('sys-up'); if (supEl) supEl.textContent = `${mm}:${ss}`;
  const srdEl = document.getElementById('sys-rd'); if (srdEl) srdEl.textContent = reads.toLocaleString();
 
  if (typeof customInjActive !== 'undefined' && customInjActive) return;
  if (typeof twinMode !== 'undefined' && twinMode !== 'normal') return;
 
  try {
    // IMPORTANT: Added cache-buster ?t=... so mobile doesn't freeze
    const response = await fetch('/machine_data.csv?t=' + Date.now());
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    const csvText = await response.text();
 
    const rows    = csvText.trim().split('\n');
    const lastRow = rows[rows.length - 1].split(',');
    
    // Fallback if data is malformed
    if (lastRow.length < 10 || lastRow[0].trim() === 'Timestamp') return;
 
    const amb         = parseFloat(lastRow[1]) || 35.0;
    const dist        = parseFloat(lastRow[2]) || 50.0;
    const gas         = parseFloat(lastRow[3]) || 400.0;
    const vib         = parseFloat(lastRow[4]) || 0.5;
    const temp        = parseFloat(lastRow[5]) || 45.0;
    const cur         = parseFloat(lastRow[6]) || 4.2;
    const pres        = parseFloat(lastRow[7]) || 1013.0;
    const finalStatus = lastRow[8] ? lastRow[8].trim() : "NORMAL";
    // ── Persist for Motor Anatomy status-parsing engine (computeAnatomyParts) ─
    lastFinalStatus = finalStatus;
    const rulVal      = parseFloat(lastRow[9]) || 500.0;
    const healthPct   = lastRow.length > 10 ? parseFloat(lastRow[10]) : 100.0;
 
    if ([temp, vib, cur, pres].some(isNaN)) return;
 
    const isCritical = finalStatus.toUpperCase().includes('CRITICAL') ||
                       finalStatus.toUpperCase().includes('FAULT');
    const isWarning  = finalStatus.toUpperCase().includes('WARNING');
 
    // ── 4. Update Global Status Pill (#mainStatus) ───────────────────────────
    const statusPill = document.getElementById('mainStatus');
    if (statusPill) {
      if (isCritical) {
        statusPill.className   = 'status-pill s-critical';
        statusPill.textContent = '⚠ CRITICAL';
      } else if (isWarning) {
        statusPill.className   = 'status-pill s-warning';
        statusPill.textContent = '⚡ WARNING';
      } else {
        statusPill.className   = 'status-pill s-normal';
        statusPill.textContent = '✔ ALL NORMAL';
      }
    }
 
    // ── 5. Log anomalies to the Alert Feed (throttled to every 3rd read) ────
    if (isCritical && reads % 3 === 0) {
      addLog(
        `Live anomaly [${finalStatus}] — VIB:${vib.toFixed(2)}g | CURR:${cur.toFixed(1)}A | TEMP:${temp.toFixed(1)}°C`,
        'crit', 'SENSOR'
      );
    }
 
    // ── 6. Draw the 4-gauge HUD with live values ─────────────────────────────
    drawOvGauges(temp, vib, cur, pres);
 
    // ── 7. Update Overview Line Chart (Temp + Vib) ───────────────────────────
    if (typeof ovLine !== 'undefined') {
      pushCFix(ovLine, temp, 0);
      pushCFix(ovLine, +(vib * VIB_DISPLAY_SCALE).toFixed(2), 1);
      ovLine.update('none');
    }
 
    // ── 7b. Update Hourly Bar Chart — replace last bucket with current temp ──
    if (typeof ovBar !== 'undefined' && ovBar) {
      const d = ovBar.data.datasets[0].data;
      d[d.length - 1] = Math.round(temp);
      ovBar.update('none');
    }
 
    // ── 7c. Update Radar Chart — compute health % for each sensor ────────────
    if (typeof ovRadar !== 'undefined' && ovRadar) {
      const aT = typeof getAlarmT    === 'function' ? getAlarmT()      : 80;
      const aV = typeof getAlarmV    === 'function' ? getAlarmV()      : 1.5;
      const aC = typeof getAlarmCur  === 'function' ? getAlarmCur()    : 10;
      const aP = typeof getThreshPres === 'function' ? getThreshPres() : 1013;
      const tH = Math.max(5, Math.round(100 - Math.min(1, Math.max(0, (temp - 20) / Math.max(1, aT - 20))) * 90));
      const vH = Math.max(5, Math.round(100 - Math.min(1, Math.max(0, vib  / Math.max(0.01, aV))) * 90));
      const cH = Math.max(5, Math.round(100 - Math.min(1, Math.max(0, cur  / Math.max(0.1,  aC))) * 80));
      const pDev = Math.abs(pres - 1013) / 300;
      const pH = Math.max(5, Math.round(100 - pDev * 70));
      ovRadar.data.datasets[0].data = [tH, vH, cH, pH, Math.round((tH + vH + cH + pH) / 4)];
      ovRadar.update('none');
    }
 
    // ── 7d. Update Fault Probability Area Chart (ovArea) ─────────────────────
    if (typeof ovArea !== 'undefined' && ovArea) {
      let fp = 5;
      if (isCritical) fp = Math.min(95, 80 + Math.random() * 15);
      else if (isWarning) fp = Math.max(30, 40 + Math.random() * 20);
      pushCFix(ovArea, fp, 0);
      ovArea.update('none');
    }
 
    // ── 8. Update Worker Safety page ─────────────────────────────────────────
    if (typeof updateWorkerSafety === 'function') {
      updateWorkerSafety(amb, gas, dist, finalStatus);
    }
 
    // ── 9. Update RUL Analysis page ──────────────────────────────────────────
    updateRULPage(temp, vib, cur, pres, healthPct, rulVal);

    // ── 10. UPDATE MONETARY ANALYSIS PAGE ────────────────────────────────────
    // Pass the live Current (cur), Distance (dist), and the status string
    if (typeof patchMonetary === 'function') {
      patchMonetary(cur, dist, finalStatus);
    }

    // ── 11. FIRE ANATOMY ENGINE (live sensor pass-through) ────────────────────
    // Only runs in normal live mode — injection/sim sessions handle their own
    // anatomy updates via twinTick() to avoid cross-contamination.
    if (!customInjActive && twinMode === 'normal') {
      // Step 1 — Fetch current alarm thresholds from UI config inputs
      const aT = typeof getAlarmT   === 'function' ? getAlarmT()   : 80;
      const aV = typeof getAlarmV   === 'function' ? getAlarmV()   : 1.5;
      const aC = typeof getAlarmCur === 'function' ? getAlarmCur() : 10;

      // Step 2 — Build the liveSensorObj with on-the-fly alarm flags.
      // presAlarm fires when the absolute pressure deviation from 1013 hPa
      // baseline exceeds 200 hPa (per spec) — not a raw threshold compare.
      const liveSensorObj = {
        temp        : temp,
        vib         : vib,
        current     : cur,
        pressure    : pres,
        rpm         : 1500,          // Not present in CSV; nominal — anatomy uses alarm bools
        tempAlarm   : temp > aT,
        vibAlarm    : vib  > aV,
        curAlarm    : cur  > aC,
        presAlarm   : Math.abs(pres - 1013) > 200,
        anomaly_hint: isCritical ? 'anomaly' : isWarning ? 'warning' : 'normal',
      };

      // Step 3 — Pass liveSensorObj to the Anatomy engine pipeline
      computeAnatomyParts(liveSensorObj);
      updateAnatomyChips();
      updateAnatomyBanners(liveSensorObj);
      updateDamagePins();
    }

    // ── 12. Update Sync Timestamp ────────────────────────────────────────────
    const ls = document.getElementById('lastSync');
    if (ls) ls.textContent = new Date().toLocaleTimeString();
 
  } catch (err) {
    console.warn('[TwinSentinel] liveTick — waiting for data:', err.message);
  }
}
/* 
   VIB DISPLAY SCALE (defined before chart inits used it)
 */
// VIB_DISPLAY_SCALE is declared near chart inits above (= 3)
// It multiplies motor vib (m/s²) so it co-renders alongside furnace temp on ovLine

/* 
   ═══════════════════════════════════════════════════════════════════════════
   WORKER SAFETY — updateWorkerSafety(amb, gas, dist, finalStatus)
   Called by liveTick every 2 s.  Updates KPIs, charts, and CSS liquid tank.
   ═══════════════════════════════════════════════════════════════════════════
*/
function updateWorkerSafety(amb, gas, dist, finalStatus) {
  const ambBad  = amb  > WS_TEMP_LIMIT;
  const gasBad  = gas  > WS_GAS_LIMIT;
  const fillPct = Math.min(100, Math.max(0, 100 - (isNaN(dist) ? 50 : dist)));
  const tankLow = fillPct < 20;

  // ── 1. Ambient KPI ────────────────────────────────────────────────────────
  const ambEl   = document.getElementById('ws-amb-val');
  const ambBar  = document.getElementById('ws-amb-bar');
  const ambStat = document.getElementById('ws-amb-status');
  const ambKpi  = document.getElementById('ws-kpi-amb');
  const ambGlow = document.getElementById('ws-amb-glow');
  if (ambEl)   ambEl.textContent = isNaN(amb) ? '—' : amb.toFixed(1);
  if (ambBar)  ambBar.style.width = Math.min((amb / 60) * 100, 100) + '%';
  if (ambStat) { ambStat.textContent = ambBad ? 'HIGH' : 'NORMAL'; ambStat.style.color = ambBad ? 'var(--red)' : 'var(--green)'; }
  if (ambKpi)  { ambKpi.classList.toggle('crit', ambBad); ambKpi.classList.toggle('warn', false); }
  if (ambGlow) ambGlow.style.background = ambBad ? '#ef4444' : '#22d3ee';

  // ── 2. Gas KPI ────────────────────────────────────────────────────────────
  const gasEl   = document.getElementById('ws-gas-val');
  const gasBar  = document.getElementById('ws-gas-bar');
  const gasStat = document.getElementById('ws-gas-status');
  const gasKpi  = document.getElementById('ws-kpi-gas');
  const gasGlow = document.getElementById('ws-gas-glow');
  if (gasEl)   gasEl.textContent = isNaN(gas) ? '—' : Math.round(gas);
  if (gasBar)  gasBar.style.width = Math.min((gas / 1200) * 100, 100) + '%';
  if (gasStat) { gasStat.textContent = gasBad ? 'DANGER' : 'NORMAL'; gasStat.style.color = gasBad ? 'var(--red)' : 'var(--green)'; }
  if (gasKpi)  { gasKpi.classList.toggle('crit', gasBad); }
  if (gasGlow) gasGlow.style.background = gasBad ? '#ef4444' : '#f97316';

  // ── 3. Zone Status KPI ────────────────────────────────────────────────────
  const zoneEl  = document.getElementById('ws-zone-status');
  const zoneSub = document.getElementById('ws-zone-sub');
  const zoneKpi = document.getElementById('ws-kpi-zone');
  const zoneGlw = document.getElementById('ws-zone-glow');
  const tagAmb  = document.getElementById('ws-tag-amb');
  const tagGas  = document.getElementById('ws-tag-gas');
  const tagTank = document.getElementById('ws-tag-tank');

  const anyDanger = ambBad || gasBad || tankLow;
  if (zoneEl) {
    if (gasBad || (ambBad && tankLow)) {
      zoneEl.textContent = 'DANGER'; zoneEl.style.color = 'var(--red)';
    } else if (ambBad || gasBad || tankLow) {
      zoneEl.textContent = 'WARNING'; zoneEl.style.color = 'var(--yellow)';
    } else {
      zoneEl.textContent = 'SAFE'; zoneEl.style.color = 'var(--green)';
    }
  }
  if (zoneSub) zoneSub.textContent = anyDanger ? 'Action required — see breakdown below' : 'All parameters within safe limits';
  if (zoneKpi) { zoneKpi.classList.toggle('crit', gasBad); zoneKpi.classList.toggle('warn', !gasBad && (ambBad || tankLow)); }
  if (zoneGlw) zoneGlw.style.background = gasBad ? '#ef4444' : (ambBad || tankLow) ? '#f59e0b' : '#22c55e';
  if (tagAmb)  { tagAmb.textContent  = ambBad  ? 'AMB ✖' : 'AMB ✔'; tagAmb.className  = 'badge ' + (ambBad  ? 'b-red' : 'b-green'); }
  if (tagGas)  { tagGas.textContent  = gasBad  ? 'GAS ✖' : 'GAS ✔'; tagGas.className  = 'badge ' + (gasBad  ? 'b-red' : 'b-green'); }
  if (tagTank) { tagTank.textContent = tankLow ? 'TANK ✖' : 'TANK ✔'; tagTank.className = 'badge ' + (tankLow ? 'b-red' : 'b-green'); }

  // ── 4. Push to charts ─────────────────────────────────────────────────────
  if (wsTempChart && !isNaN(amb)) {
    pushCFix(wsTempChart, +amb.toFixed(1), 0);
    wsTempChart.update('none');
  }
  if (wsGasChart && !isNaN(gas)) {
    pushCFix(wsGasChart, Math.round(gas), 0);
    wsGasChart.update('none');
  }

  // ── 5. CSS Liquid Tank ────────────────────────────────────────────────────
  const tankFill = document.getElementById('ws-tank-fill');
  const tankPct  = document.getElementById('ws-tank-pct');
  const tankLow2 = document.getElementById('ws-tank-low');
  const distEl   = document.getElementById('ws-dist-val');
  if (tankFill) {
    const pct = Math.round(fillPct);
    tankFill.style.height = pct + '%';
    const r = Math.round(255 * (1 - pct/100));
    const g = Math.round(165 + 90 * (pct/100));
    tankFill.style.background = pct < 20
      ? 'linear-gradient(180deg,rgba(239,68,68,0.4) 0%,rgba(239,68,68,0.7) 100%)'
      : `linear-gradient(180deg,rgba(14,${g},201,0.5) 0%,rgba(14,${g},201,0.85) 100%)`;
  }
  if (tankPct) { const pct = Math.round(fillPct); tankPct.textContent = pct + '%'; tankPct.style.color = pct < 20 ? 'var(--red)' : '#0ea5c9'; }
  if (tankLow2) tankLow2.style.display = tankLow ? 'block' : 'none';
  if (distEl) distEl.textContent = isNaN(dist) ? '—' : dist.toFixed(1);

  // ── 6. Breakdown details ──────────────────────────────────────────────────
  const dAmb  = document.getElementById('ws-detail-amb');
  const dGas  = document.getElementById('ws-detail-gas');
  const dTank = document.getElementById('ws-detail-tank');
  const advis = document.getElementById('ws-advisory');
  if (dAmb)  { dAmb.textContent  = ambBad  ? `⚠ HIGH (${amb.toFixed(1)} °C)` : `Normal (${isNaN(amb) ? '—' : amb.toFixed(1)} °C)`; dAmb.style.color  = ambBad  ? 'var(--red)' : 'var(--green)'; }
  if (dGas)  { dGas.textContent  = gasBad  ? `⚠ DANGER (${Math.round(gas)} ppm)` : `Normal (${isNaN(gas) ? '—' : Math.round(gas)} ppm)`; dGas.style.color  = gasBad  ? 'var(--red)' : 'var(--green)'; }
  if (dTank) { dTank.textContent = tankLow ? `⚠ LOW (${Math.round(fillPct)}%)` : `Adequate (${Math.round(fillPct)}%)`; dTank.style.color = tankLow ? 'var(--red)' : 'var(--green)'; }
  if (advis) {
    if (gasBad)         { advis.textContent = '🚨 EVACUATE: Toxic gas exceeds 800 ppm. Activate ventilation & alert safety team immediately.'; advis.style.color='rgba(239,68,68,0.9)'; advis.style.borderColor='rgba(239,68,68,0.3)'; advis.style.background='rgba(239,68,68,0.06)'; }
    else if (ambBad)    { advis.textContent = '⚠ HEAT ALERT: Ambient > 45 °C. Enforce PPE, rotate workers & check cooling systems.'; advis.style.color='rgba(245,158,11,0.9)'; advis.style.borderColor='rgba(245,158,11,0.3)'; advis.style.background='rgba(245,158,11,0.05)'; }
    else if (tankLow)   { advis.textContent = '⚠ COOLANT LOW: Tank below 20%. Schedule refill before next production cycle.'; advis.style.color='rgba(245,158,11,0.9)'; advis.style.borderColor='rgba(245,158,11,0.3)'; advis.style.background='rgba(245,158,11,0.05)'; }
    else                { advis.textContent = '✔ All safety parameters nominal — No action required.'; advis.style.color='rgba(34,197,94,0.85)'; advis.style.borderColor='rgba(34,197,94,0.2)'; advis.style.background='rgba(34,197,94,0.06)'; }
  }
}

/* 
   FAULT INJECTION → ALL-TAB PROPAGATION
   Called from twinTick when injection is active.
   Maps motor simulator readings → furnace-equivalent
   display values and updates every tab's charts/KPIs.
 */
function getAlarmCur(){return parseFloat(document.getElementById('cfg-alarm-cur')?.value)||10;}

function updateAllTabsFromTwin(r){
  // Cache reading so Overview tab can redraw with correct values on tab switch
  lastTwinReading = r;
  //  DIRECT pass-through — no furnace conversion 
  // Every gauge, chart and KPI shows the EXACT motor values being injected.
  // The gauge scales are adjusted by drawOvGauges() based on configured thresholds.
  const aT=getAlarmT();
  const aV=getAlarmV();
  const aC=getAlarmCur();
  const nomRpm=1500;
  const aP=getThreshPres();

  const fTemp = r.temp;      // °C  — exactly what injection tab shows
  const fVib  = r.vib;       // g   — exactly what injection tab shows
  const fCur  = r.current;   // A   — exactly what injection tab shows
  const fPres = r.pressure;  // hPa
  const fRpm  = r.rpm;       // RPM
  const fAmb  = Math.max(20, Math.min(60, 30 + (r.temp - 45) * 0.2));

  // Fault probability: fraction of alarm thresholds exceeded
  const isAn =r.anomaly_hint==='anomaly';
  const isWrn=r.anomaly_hint==='warning';
  const tPct = Math.max(0, (fTemp - 45)   / Math.max(1,    aT - 45));
  const vPct = Math.max(0, (fVib  - 0.30) / Math.max(0.01, aV - 0.30));
  const cPct = Math.max(0, (fCur  - 4.2)  / Math.max(0.1,  aC - 4.2));
  const maxPct = Math.max(tPct, vPct, cPct, 0);
  const fp = isAn ? Math.min(95, Math.round(maxPct * 85 + 10)) : isWrn ? Math.max(30, Math.round(maxPct * 45)) : 5;
  if(lastTwinReading) lastTwinReading._fp = fp;

  //  Injection-active banner (overview page) 
  const injBanner=document.getElementById('inj-active-banner');
  if(injBanner){
    injBanner.style.display='flex';
    const lbl=document.getElementById('inj-banner-fault');
    if(lbl)lbl.textContent=faultType!=='none'?faultType.replace(/_/g,' ').toUpperCase():(customInjActive?'CUSTOM PARAMS':'DEGRADING');
  }

  //  Global status pill 
  const st=document.getElementById('mainStatus');
  if(st){
    if(isAn){st.className='status-pill s-critical';st.textContent=' CRITICAL FAULT';}
    else if(isWrn){st.className='status-pill s-warning';st.textContent=' DEGRADING';}
    else{st.className='status-pill s-normal';st.textContent=' ALL NORMAL';}
  }

  //  Smart Diagnostic Log — cross-correlated fault analysis 
  if(isAn&&twinStep%5===1){
    const ft=faultType,d=FAULT_DIAGNOSIS[ft]||null;
    const ticks=faultOnset>=0?twinStep-faultOnset:0;
    const tPct2=Math.max(0,(fTemp-45)/Math.max(1,getAlarmT()-45));
    const vPct2=Math.max(0,(fVib-0.30)/Math.max(0.01,getAlarmV()-0.30));
    const cPct2=Math.max(0,(fCur-4.2)/Math.max(0.1,getAlarmCur()-4.2));
    const rPct2=Math.max(0,(nomRpm-fRpm)/nomRpm);
    const dominant=tPct2>vPct2&&tPct2>cPct2&&tPct2>rPct2?'TEMP':vPct2>cPct2&&vPct2>rPct2?'VIB':cPct2>rPct2?'CURR':'RPM↓';
    let msg,tag;
    if(d&&ticks<8){
      // Onset — first confirmation
      const ruled=ft==='bearing_wear'||ft==='rotor_imbalance'?'overload/phase_loss (CURR nominal)':
        ft==='overload'?'bearing/rotor (VIB nominal)':
        ft==='phase_loss'?'thermal fault (RPM is key indicator)':
        ft==='cooling_failure'?'mechanical/electrical (VIB+CURR nominal)':'compound fault';
      msg=`ONSET [T+${ticks}] — ${d.name} signature emerging. ${dominant} is primary signal (+${Math.round(Math.max(tPct2,vPct2,cPct2,rPct2)*100)}% of alarm). Rules out: ${ruled}.`;
      tag='ONSET';
    } else if(d&&ticks%15===0){
      // Progression update with reasoning
      const devs=`TEMP:+${Math.round(tPct2*100)}% VIB:+${Math.round(vPct2*100)}% CURR:+${Math.round(cPct2*100)}% RPM:−${Math.round(rPct2*100)}%`;
      msg=`PROGRESSING [T+${ticks}] — ${d.name} at ${fp}% conf. Signature: ${devs}. Pattern: ${d.pattern.slice(0,80)}...`;
      tag='PROG';
    } else if(d&&ticks>30&&ticks%12===3){
      // Component risk + action
      msg=`COMPONENT RISK — ${d.components.slice(0,2).join(' & ')} under stress. ${d.action.slice(0,75)}...`;
      tag='ACTION';
    } else if(!d&&customInjActive){
      // Custom injection — infer fault category from pattern
      const mechOnly=vPct2>0.5&&cPct2<0.3,elecOnly=cPct2>0.5&&vPct2<0.3,thermalOnly=tPct2>0.5&&vPct2<0.2&&cPct2<0.2;
      const category=mechOnly?'MECHANICAL':elecOnly?'ELECTRICAL':thermalOnly?'THERMAL':'COMPOUND';
      const reason=mechOnly?'VIB dominant, CURR nominal → not electrical':
        elecOnly?'CURR dominant, VIB nominal → not mechanical':
        thermalOnly?'TEMP dominant, VIB+CURR nominal → cooling path':
        'multiple params deviate → complex or compound fault';
      msg=`ANOMALY [${fp}% conf] — Category: ${category}. ${reason}. Deviation: TEMP+${Math.round(tPct2*100)}% VIB+${Math.round(vPct2*100)}% CURR+${Math.round(cPct2*100)}%.`;
      tag='DIAG';
    } else {
      msg=`ANOMALY [${fp}% conf] — ${dominant} leads at +${Math.round(Math.max(tPct2,vPct2,cPct2,rPct2)*100)}% of alarm threshold.`;
      tag='ANOMALY';
    }
    addLog(msg,'crit',tag);
  } else if(isWrn&&twinStep%10===1){
    const tPctW=Math.max(0,(fTemp-45)/Math.max(1,getAlarmT()-45));
    const vPctW=Math.max(0,(fVib-0.30)/Math.max(0.01,getAlarmV()-0.30));
    const lead=tPctW>vPctW?`TEMP at ${Math.round(tPctW*100)}% of alarm`:`VIB at ${Math.round(vPctW*100)}% of alarm`;
    addLog(`DEGRADING — ${lead}. Parameters trending upward — fault may develop. Increase monitoring frequency.`,'warn','WATCH');
  }

  // 
  // OVERVIEW PAGE
  // 
  // Use alarm-threshold-based maxima so bars/status reflect motor-scale correctly
  // (e.g. 124°C with 80°C alarm → ~78% fill = WARN, not 11% fill = NORMAL from furnace scale)
  setKPI('kpi-temp','ov-temp','bar-temp','ov-temp-s',fTemp, Math.max(aT*2,  fTemp*1.3, 100), 1);
  setKPI('kpi-vib', 'ov-vib', 'bar-vib', 'ov-vib-s', fVib,  Math.max(aV*3,  fVib*1.3, 3),   3);
  setKPI('kpi-cur', 'ov-cur', 'bar-cur', 'ov-cur-s', fCur,  Math.max(aC*2,  fCur*1.3, 15),  2);
  setKPI('kpi-fault','ov-fault','bar-fault','ov-fault-s',fp,100, 1);
  // Draw arc gauges — always during injection so they're ready when user switches to overview
  drawOvGauges(fTemp, fVib, fCur, fPres);
  // Overview line — push both datasets sharing one label slot
  pushCFix(ovLine,Math.round(fTemp),0);
  pushCFix(ovLine,+(fVib*VIB_DISPLAY_SCALE).toFixed(1),1);
  ovLine.update('none');
  pushCFix(ovArea,fp,0);
  ovArea.update('none');
  // Hourly bar — update last bucket in-place (no push)
  if(ovBar){const d=ovBar.data.datasets[0].data;d[d.length-1]=Math.round(fTemp);ovBar.update('none');}
  // Radar — update live dataset in-place
  if(ovRadar){
    // Motor-scale health: 100% = at baseline, 0% = at/above alarm threshold
    const tH=Math.max(5,Math.round(100-Math.min(1,Math.max(0,(fTemp-20)/Math.max(1,aT-20)))*90));
    const vH=Math.max(5,Math.round(100-Math.min(1,Math.max(0,fVib/Math.max(0.01,aV)))*90));
    const cH=Math.max(5,Math.round(100-Math.min(1,Math.max(0,fCur/Math.max(0.1,aC)))*80));
    const pDev=Math.abs(fPres-1013)/300;
    const pH=Math.max(5,Math.round(100-pDev*70));
    ovRadar.data.datasets[0].data=[tH,vH,cH,pH,Math.round((tH+vH+cH+pH)/4)];
    ovRadar.update('none');
  }

  // 
  // SENSORS PAGE — use motor-scale maxima so bars fill proportionally
  // 
  const sv=(id,bid,v,max,d)=>{
    const e=document.getElementById(id);if(e)e.textContent=Math.max(0,v).toFixed(d);
    const b=document.getElementById(bid);if(b)b.style.width=Math.min(100,(Math.max(0,v)/max)*100)+'%';
  };
  // Bar maxima = 2.5× alarm so bars are readable (100% alarm = 40% bar fill)
  sv('s-temp','sb-temp',fTemp, Math.max(aT*2.5,  fTemp*1.2+1), 1);
  sv('s-amb', 'sb-amb', fAmb,  60, 1);
  sv('s-vib', 'sb-vib', fVib,  Math.max(aV*3,    fVib*1.2+0.1), 3);
  sv('s-cur', 'sb-cur', fCur,  Math.max(aC*2.5,  fCur*1.2+1),  1);
  sv('s-pres','sb-pres',fPres, Math.max(aP*1.5,1500), 0);
  // Multi-line charts — now null (sensor page replaced by Worker Safety)
  if(sTempLine){pushCFix(sTempLine,Math.round(fTemp),0);pushCFix(sTempLine,+fAmb.toFixed(1),1);sTempLine.update('none');}
  if(sCurStep){pushCFix(sCurStep,fCur,0);sCurStep.update('none');}
  // Also push into Worker Safety charts during fault injection
  if(typeof updateWorkerSafety==='function') updateWorkerSafety(fAmb, fAmb*18, 50, 'FAULT');
  // Scatter — add point to correct dataset
  if(sScatter){
    const jx=+(fVib*(0.88+Math.random()*0.24)).toFixed(2);
    const jy=+(fVib*(0.90+Math.random()*0.20)).toFixed(2);
    const di=isAn?1:0;
    sScatter.data.datasets[di].data.push({x:jx,y:jy});
    if(sScatter.data.datasets[di].data.length>(di===1?12:50))sScatter.data.datasets[di].data.shift();
    sScatter.update('none');
  }
  // Pressure chart
  if(sMixedChart){
    pushCFix(sMixedChart,Math.round(fPres),0,40);
    sMixedChart.update('none');
  }

  // 
  // HISTORY PAGE  (throttled — every 10 ticks)
  // 
  if(twinStep%10===0){
    if(hArea){
      // Push all 3 datasets + one label atomically
      const lbl=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
      hArea.data.labels.push(lbl);hArea.data.labels.shift();
      hArea.data.datasets[0].data.push(Math.round(fTemp+8));hArea.data.datasets[0].data.shift();
      hArea.data.datasets[1].data.push(Math.round(fTemp));  hArea.data.datasets[1].data.shift();
      hArea.data.datasets[2].data.push(Math.round(fTemp-8));hArea.data.datasets[2].data.shift();
      hArea.update('none');
    }
    if(hVibBar){
      const d=hVibBar.data.datasets[0].data;
      d[d.length-1]=+fVib.toFixed(2);
      hVibBar.data.datasets[1].data[hVibBar.data.datasets[1].data.length-1]=+(fVib*0.85).toFixed(2);
      hVibBar.update('none');
    }
    if(hBubble&&isAn){
      hBubble.data.datasets[1].data.push({x:Math.round(fTemp),y:+fCur.toFixed(1),r:6});
      if(hBubble.data.datasets[1].data.length>10)hBubble.data.datasets[1].data.shift();
      hBubble.update('none');
    }
    _addHistoryRow(fTemp,fVib,fCur,fPres,isAn,r.anomaly_hint);
  }

  // 
  // ANALYTICS PAGE
  // 
  if(anRadar){
    // Motor-scale health: consistent with Overview radar
    const tH2=Math.max(5,Math.round(100-Math.min(1,Math.max(0,(fTemp-20)/Math.max(1,aT-20)))*90));
    const vH2=Math.max(5,Math.round(100-Math.min(1,Math.max(0,fVib/Math.max(0.01,aV)))*90));
    const cH2=Math.max(5,Math.round(100-Math.min(1,Math.max(0,fCur/Math.max(0.1,aC)))*80));
    const pDev2=Math.abs(fPres-1013)/300;
    const pH2=Math.max(5,Math.round(100-pDev2*70));
    anRadar.data.datasets[0].data=[tH2,vH2,cH2,pH2,Math.round((tH2+vH2+cH2+pH2)/4)];
    anRadar.update('none');
  }



  // 
  // ALERTS PAGE — fault signature radar, evolution chart, diagnosis panel
  // 
  if(twinStep%2===0)updateAlertCenter(r,fp,isAn,isWrn);

  document.getElementById('lastSync').textContent=new Date().toLocaleTimeString();
}

/* Helper — prepend row to history table */
function _addHistoryRow(temp,vib,cur,pres,isAn,hint){
  const hb=document.getElementById('histBody');if(!hb)return;
  const t=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  const st=isAn?'<span class="badge b-red">FAULT</span>':hint==='warning'?'<span class="badge b-yellow">WARN</span>':'<span class="badge b-green">OK</span>';
  const bgColor=isAn?'rgba(248,113,113,0.04)':hint==='warning'?'rgba(251,191,36,0.03)':'';
  hb.insertAdjacentHTML('afterbegin',`<tr style="background:${bgColor}"><td>${t}</td><td>${temp.toFixed(1)}</td><td>${vib.toFixed(2)}</td><td>${cur.toFixed(1)}</td><td>${pres.toFixed(0)}</td><td style="color:${isAn?'var(--red)':'var(--green)'};font-weight:700;">${isAn?1:0}</td><td>${st}</td></tr>`);
  while(hb.children.length>35)hb.removeChild(hb.lastChild);
}

/* Clear all time-series chart data when injection starts,
   so motor-scale values start on a clean canvas */
function clearChartHistoryForInjection(){
  const clearChart=(ch,nSets)=>{
    if(!ch)return;
    ch.data.labels=Array.from({length:60},()=>'');
    for(let i=0;i<nSets;i++){
      if(ch.data.datasets[i])ch.data.datasets[i].data=Array.from({length:60},()=>null);
    }
    ch.update('none');
  };
  const clearChart40=(ch,nSets)=>{
    if(!ch)return;
    ch.data.labels=Array.from({length:40},()=>'');
    for(let i=0;i<nSets;i++){
      if(ch.data.datasets[i])ch.data.datasets[i].data=Array.from({length:40},()=>null);
    }
    ch.update('none');
  };
  clearChart(ovLine,2);
  clearChart(ovArea,1);
  if(sTempLine){clearChart(sTempLine,2);}
  if(sCurStep){clearChart(sCurStep,1);}
  if(sMixedChart){clearChart40(sMixedChart,1);}

}

/* Reset all tabs to baseline */
function resetAllTabsToBaseline(){
  const bT=852,bV=9.81,bC=21.4,bFp=5;
  // Re-seed charts with furnace baseline values so they look correct after reset
  const furnaceSeed=(ch,v0,v1)=>{
    if(!ch)return;
    ch.data.labels=Array.from({length:60},()=>'');
    ch.data.datasets[0].data=Array.from({length:60},()=>+(v0+(Math.random()-.5)*v0*0.02).toFixed(0));
    if(v1!==undefined&&ch.data.datasets[1])
      ch.data.datasets[1].data=Array.from({length:60},()=>+(v1+(Math.random()-.5)*v1*0.05).toFixed(1));
    ch.update('none');
  };
  furnaceSeed(ovLine,852,bV*VIB_DISPLAY_SCALE);
  furnaceSeed(ovArea,5);
  if(sTempLine){furnaceSeed(sTempLine,852,37);}
  if(sCurStep){furnaceSeed(sCurStep,21.4);}
  if(sMixedChart){sMixedChart.data.labels=Array.from({length:40},()=>'');sMixedChart.data.datasets[0].data=Array.from({length:40},()=>1013);sMixedChart.update('none');}
  // Also reset worker safety charts to baseline
  if(wsTempChart){furnaceSeed(wsTempChart,35,undefined);}
  if(wsGasChart){wsTempChart&&furnaceSeed(wsGasChart,350,undefined);}
  if(typeof updateWorkerSafety==='function') setTimeout(()=>updateWorkerSafety(35,350,50,'NORMAL'),100);
  drawOvGauges(bT, bV, bC, 1013);
  const sv=(id,bid,v,max,d)=>{const e=document.getElementById(id);if(e)e.textContent=v.toFixed(d);const b=document.getElementById(bid);if(b)b.style.width=Math.min((v/max)*100,100)+'%';};
  sv('s-temp','sb-temp',bT,1100,0);sv('s-amb','sb-amb',37,60,1);
  sv('s-vib','sb-vib',bV,50,2);sv('s-cur','sb-cur',bC,35,1);sv('s-pres','sb-pres',1013,1200,0);
  if(ovRadar){ovRadar.data.datasets[0].data=[77,49,61,50,70];ovRadar.update('none');}
  if(anRadar){anRadar.data.datasets[0].data=[88,72,81,95,85];anRadar.update('none');}
  const injBanner=document.getElementById('inj-active-banner');
  if(injBanner)injBanner.style.display='none';
  const st=document.getElementById('mainStatus');
  if(st){st.className='status-pill s-normal';st.textContent=' ALL NORMAL';}
  lastTwinReading=null;
}

/* 
   TWIN TICK — wired to injection engine
 */
function twinTick(){
  const r=getTwinReading();
  updateTwinCards(r);
  addTwinAlert(r);
  pushTwinBuffer('temp',r.temp,20,100);
  pushTwinBuffer('vib',r.vib,0,2);
  pushTwinBuffer('cur',r.current,0,10);
  drawTwinChart();
  // Motor Anatomy backend sync — only run when simulator is driving the UI.
  // In Normal mode with no custom injection, the real Raspberry Pi data owns
  // these UI elements; running the anatomy pipeline here would fight with it.
  if(customInjActive||twinMode!=='normal'){
    computeAnatomyParts(r);
    updateAnatomyChips();
    updateAnatomyBanners(r);
    updateDamagePins();
    // Propagate to all other tabs when injection or non-normal mode
    updateAllTabsFromTwin(r);
  }
}

/* 
   RESET SIM — extended to restore all tabs
 */
function resetSim(){
  twinStep=0;twinMode='normal';faultType='none';faultOnset=-1;faultSeverity=0;
  tempState=45;twinAlertCount=0;peakTemp=45;peakVib=0.3;
  Object.keys(twinBuffers).forEach(k=>twinBuffers[k]=[]);
  customInjActive=false;
  Object.keys(injBuffers).forEach(k=>{injBuffers[k].buf=[];injBuffers[k].idx=0;injBuffers[k].active=false;});
  ['inj-temp-pct','inj-cur-pct','inj-pres-pct','inj-vib-pct'].forEach(id=>{const el=document.getElementById(id);if(el)el.value=0;});
  updateInjPreview();
  const ac=document.getElementById('alert-count');if(ac)ac.textContent='0 anomalies';
  document.querySelectorAll('.twin-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tw-btn-normal')?.classList.add('active');
  const afd=document.getElementById('active-fault-display');if(afd)afd.textContent='NONE';
  const afs=document.getElementById('active-fault-since');if(afs)afs.textContent='—';
  const sl=document.getElementById('sim-mode-label');if(sl)sl.textContent='MODE: NORMAL';
  anatomyAlertParts=new Set();anatomyWarnParts=new Set();
  updateAnatomyChips();
  resetAllTabsToBaseline();
}

/* 
   CLOCK + INIT
 */
/* 
   RUL ANALYSIS ENGINE
   Logic: Health Index = max(0, 100 - injection_pct)
   where injection_pct is the slider % of threshold.
   If pct=50% → HI=50%, pct=100% → HI=0%, pct=0% → HI=100%
   MHI = equal average of all 4 HIs (25% each)
   RUL = (MHI/100) * MAX_RUL_HOURS
 */

const RUL_MAX_HOURS = 8760; // 1 year = max RUL when machine is fully healthy
const rulHistBuf = [];
const RUL_HIST_MAX = 60;

// Chart instances
let rulGaugeTemp=null, rulGaugeCur=null, rulGaugePres=null, rulGaugeVib=null;
let rulGaugeMhi=null, rulBarChart=null, rulHistChart=null, rulRadarChart=null;
let rulChartsInited = false;

function rulHiColor(hi) {
  if (hi >= 70) return '#34d399';
  if (hi >= 40) return '#fbbf24';
  return '#f87171';
}

function rulHiLabel(hi) {
  if (hi >= 80) return 'HEALTHY';
  if (hi >= 60) return 'GOOD';
  if (hi >= 40) return 'DEGRADED';
  if (hi > 5)   return 'CRITICAL';
  return 'FAILED';
}

function rulHiBadgeStyle(hi) {
  if (hi >= 70) return 'color:var(--green);border-color:rgba(52,211,153,0.4);background:rgba(52,211,153,0.08);';
  if (hi >= 40) return 'color:var(--yellow);border-color:rgba(251,191,36,0.45);background:rgba(251,191,36,0.07);';
  return 'color:var(--red);border-color:rgba(248,113,113,0.45);background:rgba(248,113,113,0.08);';
}

function rulMakeSemiGauge(id, val, color) {
  const el = document.getElementById(id);
  if (!el) return null;
  const v = Math.max(0, Math.min(100, val));
  return new Chart(el, {
    type: 'doughnut',
    data: { datasets: [{ data: [v, 100-v], backgroundColor: [color, 'rgba(255,255,255,0.05)'], borderWidth: 0, cutout: '76%' }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 500 },
      circumference: 180, rotation: -90,
      plugins: { legend: { display: false }, tooltip: { enabled: false } }
    }
  });
}

function rulUpdateGauge(chart, val, color) {
  if (!chart) return;
  const v = Math.max(0, Math.min(100, val));
  chart.data.datasets[0].data = [v, 100 - v];
  chart.data.datasets[0].backgroundColor[0] = color;
  chart.update('none');
}

function initRULCharts() {
  if (rulChartsInited) return;
  rulChartsInited = true;

  rulGaugeTemp = rulMakeSemiGauge('rul-g-temp', 100, '#34d399');
  rulGaugeCur  = rulMakeSemiGauge('rul-g-cur',  100, '#34d399');
  rulGaugePres = rulMakeSemiGauge('rul-g-pres', 100, '#34d399');
  rulGaugeVib  = rulMakeSemiGauge('rul-g-vib',  100, '#34d399');
  rulGaugeMhi  = rulMakeSemiGauge('rul-g-mhi',  100, '#34d399');

  // Bar chart — 5 columns: 4 individual HIs + MHI
  const rulBarEl = document.getElementById('rul-bar-chart');
  if (rulBarEl) {
    rulBarChart = new Chart(rulBarEl, {
      type: 'bar',
      data: {
        labels: [' Temp', ' Current', ' Pressure', ' Vibration', ' MHI'],
        datasets: [{
          label: 'Health Index (%)',
          data: [100, 100, 100, 100, 100],
          backgroundColor: [
            'rgba(248,113,113,0.75)', 'rgba(251,191,36,0.75)',
            'rgba(34,211,238,0.75)',  'rgba(43,144,217,0.75)',
            'rgba(52,211,153,0.9)'
          ],
          borderRadius: 8, borderSkipped: false
        }]
      },
      options: {
        animation: false, responsive: true, maintainAspectRatio: false,
        scales: {
          x: ax,
          y: { ...ax, min: 0, max: 100, ticks: { ...ax.ticks, callback: v => v + '%' } }
        },
        plugins: { legend: { display: false } }
      }
    });
  }

  // MHI history + RUL% dual line chart
  const rulHistEl = document.getElementById('rul-hist-chart');
  if (rulHistEl) {
    rulHistChart = new Chart(rulHistEl, {
      type: 'line',
      data: {
        labels: Array.from({ length: RUL_HIST_MAX }, () => ''),
        datasets: [
          { label: 'MHI (%)', data: [], borderColor: '#34d399', backgroundColor: 'rgba(52,211,153,0.08)', fill: true, tension: 0.4, pointRadius: 0, borderWidth: 2 },
          { label: 'RUL (% of max)', data: [], borderColor: '#4da6e8', backgroundColor: 'transparent', fill: false, tension: 0.4, pointRadius: 0, borderWidth: 1.5, borderDash: [4, 4] }
        ]
      },
      options: {
        animation: false, responsive: true, maintainAspectRatio: false,
        scales: {
          x: { ...ax, display: false },
          y: { ...ax, min: 0, max: 100, ticks: { ...ax.ticks, callback: v => v + '%' } }
        },
        plugins: { legend: { labels: { color: tc, font: { family: F, size: 10 }, boxWidth: 12, padding: 10 } } }
      }
    });
  }

  // Radar — 4 HIs
  const rulRadarEl = document.getElementById('rul-radar-chart');
  if (rulRadarEl) {
    rulRadarChart = new Chart(rulRadarEl, {
      type: 'radar',
      data: {
        labels: ['Temperature', 'Current', 'Pressure', 'Vibration'],
        datasets: [
          { label: 'Health Index', data: [100, 100, 100, 100], backgroundColor: 'rgba(52,211,153,0.14)', borderColor: '#34d399', pointBackgroundColor: '#34d399', pointRadius: 4, borderWidth: 2 },
          { label: 'Ideal (100%)', data: [100, 100, 100, 100], backgroundColor: 'rgba(43,144,217,0.04)', borderColor: 'rgba(43,144,217,0.18)', borderDash: [5,5], pointRadius: 0, borderWidth: 1 }
        ]
      },
      options: {
        animation: false, responsive: true, maintainAspectRatio: false,
        scales: {
          r: {
            min: 0, max: 100,
            ticks: { color: tc, font: { family: F, size: 9 }, backdropColor: 'transparent', stepSize: 25, callback: v => v + '%' },
            grid: { color: gc },
            pointLabels: { color: tc, font: { family: F, size: 11, weight: '700' } }
          }
        },
        plugins: { legend: { labels: { color: tc, font: { family: F, size: 10 }, boxWidth: 12, padding: 10 } } }
      }
    });
  }

  // Run an initial update pass
  updateRULPage();
}

//─── updateRULPage ────────────────────────────────────────────────────────────
//
//  DUAL-MODE function:
//
//  LIVE MODE  — called by liveTick() with 6 arguments:
//    updateRULPage(liveTemp, liveVib, liveCur, livePres, mhi, rulHours)
//    • Computes individual sensor deviations & Health Indices locally
//      using the fixed baseline/max constants below.
//    • Uses backend-supplied mhi (Health_Pct) and rulHours (RUL) directly.
//
//  INJECTION MODE — called without arguments (from sliders / initRULCharts):
//    updateRULPage()
//    • Preserves the original injection-slider logic unchanged so the
//      Fault Injection page continues to work independently.
//
//  Sensor baseline constants (fixed by spec):
//    Temp     : Base = 40.0 °C,    Max = 80.0 °C
//    Vib      : Base = 0.5  g,     Max = 2.0  g
//    Current  : Base = 5.0  A,     Max = 10.0 A
//    Pressure : Base = 1013 hPa,   Max deviation = ±200 hPa
//
//  Deviation % = clamp( ((Live - Base) / (Max - Base)) × 100,  0, 100 )
//  Health Index = 100 − Deviation %
// ─────────────────────────────────────────────────────────────────────────────
function updateRULPage(liveTemp, liveVib, liveCur, livePres, mhi, rulHours) {
 
  // ── Determine operating mode ─────────────────────────────────────────────
  const isLiveMode = (arguments.length >= 6 &&
                      liveTemp !== undefined && mhi !== undefined);
 
  // ── A.  Sensor-baseline constants (spec-defined) ─────────────────────────
  const TEMP_BASE  = 40.0,  TEMP_MAX   = 80.0;
  const VIB_BASE   = 0.5,   VIB_MAX    = 2.0;
  const CUR_BASE   = 5.0,   CUR_MAX    = 10.0;
  const PRES_BASE  = 1013.0, PRES_MAXDEV = 200.0;
 
  // ── B.  Compute Health Indices ────────────────────────────────────────────
  let hiTemp, hiVib, hiCur, hiPres, mhiVal, rulHoursVal, rulDays;
 
  if (isLiveMode) {
    // --- LIVE: derive HIs from real sensor readings -----------------------
    const devTemp = Math.max(0, Math.min(100,
      ((liveTemp - TEMP_BASE) / (TEMP_MAX - TEMP_BASE)) * 100));
 
    const devVib  = Math.max(0, Math.min(100,
      ((liveVib  - VIB_BASE)  / (VIB_MAX  - VIB_BASE))  * 100));
 
    const devCur  = Math.max(0, Math.min(100,
      ((liveCur  - CUR_BASE)  / (CUR_MAX  - CUR_BASE))   * 100));
 
    const devPres = Math.max(0, Math.min(100,
      (Math.abs(livePres - PRES_BASE) / PRES_MAXDEV) * 100));
 
    hiTemp = 100 - devTemp;
    hiVib  = 100 - devVib;
    hiCur  = 100 - devCur;
    hiPres = 100 - devPres;
 
    // Backend-supplied master HI and RUL (authoritative)
    mhiVal      = mhi;
    rulHoursVal = rulHours;
    rulDays     = rulHoursVal / 24;
 
  } else {
    // --- INJECTION: derive HIs from fault-injection sliders ---------------
    const tPct = parseFloat(document.getElementById('inj-temp-pct')?.value) || 0;
    const cPct = parseFloat(document.getElementById('inj-cur-pct')?.value)  || 0;
    const pPct = parseFloat(document.getElementById('inj-pres-pct')?.value) || 0;
    const vPct = parseFloat(document.getElementById('inj-vib-pct')?.value)  || 0;
 
    hiTemp = Math.max(0, 100 - tPct);
    hiCur  = Math.max(0, 100 - cPct);
    hiPres = Math.max(0, 100 - pPct);
    hiVib  = Math.max(0, 100 - vPct);
 
    mhiVal      = (hiTemp + hiCur + hiPres + hiVib) / 4;
    rulHoursVal = (mhiVal / 100) * RUL_MAX_HOURS;
    rulDays     = rulHoursVal / 24;
  }
 
  // ═══════════════════════════════════════════════════════════════════════════
  //  SECTION 1 — Parameter status cards
  // ═══════════════════════════════════════════════════════════════════════════
 
  if (isLiveMode) {
    // Deviation % for each sensor (already computed above; re-derive for cards)
    const devMap = {
      temp: Math.max(0, Math.min(100, ((liveTemp - TEMP_BASE) / (TEMP_MAX - TEMP_BASE)) * 100)),
      vib:  Math.max(0, Math.min(100, ((liveVib  - VIB_BASE)  / (VIB_MAX  - VIB_BASE))  * 100)),
      cur:  Math.max(0, Math.min(100, ((liveCur  - CUR_BASE)  / (CUR_MAX  - CUR_BASE))   * 100)),
      pres: Math.max(0, Math.min(100, (Math.abs(livePres - PRES_BASE) / PRES_MAXDEV)     * 100)),
    };
 
    const liveParamMap = {
      temp: { liveVal: liveTemp, fmt: v => v.toFixed(1),                  unit: '°C',  refText: `Baseline: ${TEMP_BASE}°C · Max: ${TEMP_MAX}°C` },
      vib:  { liveVal: liveVib,  fmt: v => v.toFixed(3),                  unit: 'g',   refText: `Baseline: ${VIB_BASE} g · Max: ${VIB_MAX} g` },
      cur:  { liveVal: liveCur,  fmt: v => v.toFixed(2),                  unit: 'A',   refText: `Baseline: ${CUR_BASE} A · Max: ${CUR_MAX} A` },
      pres: { liveVal: livePres, fmt: v => Math.round(v).toString(),       unit: 'hPa', refText: `Baseline: ${PRES_BASE} hPa ± ${PRES_MAXDEV} hPa` },
    };
 
    const CARD_COLORS = {
      temp: '#f87171', vib: '#4da6e8', cur: '#fbbf24', pres: '#22d3ee'
    };
 
    ['temp', 'vib', 'cur', 'pres'].forEach(key => {
      const p      = liveParamMap[key];
      const devPct = devMap[key];
      const isOver = devPct >= 100;
      const isWarn = devPct >= 70 && devPct < 100;
      const barW   = Math.min(100, devPct);
 
      const vEl    = document.getElementById(`rul-v-${key}`);
      const fillEl = document.getElementById(`rul-fill-${key}`);
      const pctEl  = document.getElementById(`rul-pct-${key}`);
      const sEl    = document.getElementById(`rul-s-${key}`);
      const rEl    = document.getElementById(`rul-ref-${key}`);
 
      if (rEl)    rEl.textContent = p.refText;
      if (vEl)    vEl.textContent = p.fmt(p.liveVal);
 
      if (fillEl) {
        fillEl.style.width      = barW + '%';
        fillEl.style.background = isOver ? '#f87171'
                                : isWarn ? '#fbbf24'
                                : CARD_COLORS[key];
      }
 
      if (pctEl) {
        pctEl.textContent = `${devPct.toFixed(1)}% deviation · ${p.fmt(p.liveVal)} ${p.unit} (live)`;
      }
 
      if (sEl) {
        if (isOver)      { sEl.textContent = ' OVER';    sEl.style.cssText = 'color:var(--red);border-color:rgba(248,113,113,0.5);background:rgba(248,113,113,0.08);'; }
        else if (isWarn) { sEl.textContent = ' WARN';    sEl.style.cssText = 'color:var(--yellow);border-color:rgba(251,191,36,0.5);background:rgba(251,191,36,0.06);'; }
        else if (devPct > 0) { sEl.textContent = ' LIVE'; sEl.style.cssText = 'color:var(--green);border-color:rgba(52,211,153,0.4);background:rgba(52,211,153,0.08);'; }
        else             { sEl.textContent = 'BASELINE'; sEl.style.cssText = 'color:var(--muted);border-color:rgba(43,144,217,0.15);background:rgba(255,255,255,0.04);'; }
      }
    });
 
  } else {
    // Original injection-slider card logic (unchanged)
    const tPct = parseFloat(document.getElementById('inj-temp-pct')?.value) || 0;
    const cPct = parseFloat(document.getElementById('inj-cur-pct')?.value)  || 0;
    const pPct = parseFloat(document.getElementById('inj-pres-pct')?.value) || 0;
    const vPct = parseFloat(document.getElementById('inj-vib-pct')?.value)  || 0;
 
    const injParams = [
      { key: 'temp', pct: tPct, thresh: getThreshTemp(), fmt: v => v.toFixed(1),                  unit: '°C'  },
      { key: 'cur',  pct: cPct, thresh: getThreshCur(),  fmt: v => v.toFixed(2),                  unit: 'A'   },
      { key: 'pres', pct: pPct, thresh: getThreshPres(), fmt: v => Math.round(v).toString(),       unit: 'hPa' },
      { key: 'vib',  pct: vPct, thresh: getThreshVib(),  fmt: v => v.toFixed(3),                  unit: 'g'   },
    ];
 
    injParams.forEach(p => {
      const isActive = p.pct > 0;
      const injVal   = (p.pct / 100) * p.thresh;
      const isOver   = p.pct >= 100;
      const isWarn   = p.pct >= 70 && p.pct < 100;
      const barW     = Math.min(100, p.pct);
 
      const vEl    = document.getElementById(`rul-v-${p.key}`);
      const fillEl = document.getElementById(`rul-fill-${p.key}`);
      const pctEl  = document.getElementById(`rul-pct-${p.key}`);
      const sEl    = document.getElementById(`rul-s-${p.key}`);
      const rEl    = document.getElementById(`rul-ref-${p.key}`);
 
      if (rEl)    rEl.textContent = `Threshold: ${p.fmt(p.thresh)} ${p.unit}`;
      if (vEl)    vEl.textContent = isActive ? p.fmt(injVal) : '—';
 
      if (fillEl) {
        fillEl.style.width = barW + '%';
        const barColor = isOver ? '#f87171' : isWarn ? '#fbbf24'
          : p.key === 'temp' ? '#f87171' : p.key === 'cur' ? '#fbbf24'
          : p.key === 'pres' ? '#22d3ee' : '#4da6e8';
        fillEl.style.background = barColor;
      }
 
      if (pctEl) pctEl.textContent = isActive
        ? `${p.pct}% of threshold · ${p.fmt(injVal)} ${p.unit}`
        : '0% of threshold · No injection — baseline';
 
      if (sEl) {
        if (!isActive)   { sEl.textContent = 'BASELINE'; sEl.style.cssText = 'color:var(--muted);border-color:rgba(43,144,217,0.15);background:rgba(255,255,255,0.04);'; }
        else if (isOver) { sEl.textContent = ' OVER';   sEl.style.cssText = 'color:var(--red);border-color:rgba(248,113,113,0.5);background:rgba(248,113,113,0.08);'; }
        else if (isWarn) { sEl.textContent = ' WARN';   sEl.style.cssText = 'color:var(--yellow);border-color:rgba(251,191,36,0.5);background:rgba(251,191,36,0.06);'; }
        else             { sEl.textContent = ' ACTIVE'; sEl.style.cssText = 'color:var(--green);border-color:rgba(52,211,153,0.4);background:rgba(52,211,153,0.08);'; }
      }
    });
  }
 
  // ═══════════════════════════════════════════════════════════════════════════
  //  SECTION 2 — Individual Health Index gauges
  //  (identical for both modes — uses computed hiTemp/hiVib/hiCur/hiPres)
  // ═══════════════════════════════════════════════════════════════════════════
  const gaugeData = [
    { chart: rulGaugeTemp, hi: hiTemp, valId: 'rul-hi-temp-val', badgeId: 'rul-hi-temp-badge' },
    { chart: rulGaugeCur,  hi: hiCur,  valId: 'rul-hi-cur-val',  badgeId: 'rul-hi-cur-badge'  },
    { chart: rulGaugePres, hi: hiPres, valId: 'rul-hi-pres-val', badgeId: 'rul-hi-pres-badge' },
    { chart: rulGaugeVib,  hi: hiVib,  valId: 'rul-hi-vib-val',  badgeId: 'rul-hi-vib-badge'  },
  ];
 
  gaugeData.forEach(g => {
    const col = rulHiColor(g.hi);
    rulUpdateGauge(g.chart, g.hi, col);
    const vEl = document.getElementById(g.valId);
    if (vEl) { vEl.textContent = Math.round(g.hi) + '%'; vEl.style.color = col; }
    const bEl = document.getElementById(g.badgeId);
    if (bEl) { bEl.textContent = rulHiLabel(g.hi); bEl.style.cssText = rulHiBadgeStyle(g.hi); }
  });
 
  // ═══════════════════════════════════════════════════════════════════════════
  //  SECTION 3 — Master Health Index (MHI)
  // ═══════════════════════════════════════════════════════════════════════════
  const mhiCol = rulHiColor(mhiVal);
 
  rulUpdateGauge(rulGaugeMhi, mhiVal, mhiCol);
 
  const mhiValEl = document.getElementById('rul-mhi-val');
  if (mhiValEl) { mhiValEl.textContent = mhiVal.toFixed(1) + '%'; mhiValEl.style.color = mhiCol; }
 
  const mhiBarEl = document.getElementById('rul-mhi-bar');
  if (mhiBarEl) {
    mhiBarEl.style.width = mhiVal + '%';
    mhiBarEl.style.background = mhiVal >= 70
      ? 'linear-gradient(90deg,#34d399,#22d3ee)'
      : mhiVal >= 40 ? 'linear-gradient(90deg,#fbbf24,#fb923c)'
      : 'linear-gradient(90deg,#f87171,#ef4444)';
  }
 
  const mhiStatusEl  = document.getElementById('rul-mhi-status-text');
  const mhiStatusBox = document.getElementById('rul-mhi-status-box');
  const mhiLabel = mhiVal >= 80 ? 'OPTIMAL'
                 : mhiVal >= 60 ? 'GOOD'
                 : mhiVal >= 40 ? 'DEGRADED'
                 : mhiVal >= 20 ? 'CRITICAL'
                 : 'FAILURE IMMINENT';
  if (mhiStatusEl) { mhiStatusEl.textContent = mhiLabel; mhiStatusEl.style.color = mhiCol; }
  if (mhiStatusBox) {
    const borderRgb = mhiVal >= 70 ? '52,211,153' : mhiVal >= 40 ? '251,191,36' : '248,113,113';
    mhiStatusBox.style.cssText = `width:100%;margin-top:14px;padding:11px 14px;background:rgba(${borderRgb},0.05);border:1px solid rgba(${borderRgb},0.22);border-radius:10px;text-align:center;transition:all 0.4s;`;
  }
 
  // ═══════════════════════════════════════════════════════════════════════════
  //  SECTION 4 — RUL display
  //  In LIVE mode rulHoursVal comes directly from the backend Python model.
  //  In INJECTION mode it is derived from the computed mhiVal.
  // ═══════════════════════════════════════════════════════════════════════════
  let displayVal, displayUnit;
  if      (rulHoursVal >= 720) { displayVal = Math.round(rulDays);                          displayUnit = 'DAYS';    }
  else if (rulHoursVal >= 1)   { displayVal = Math.round(rulHoursVal);                       displayUnit = 'HOURS';   }
  else                         { displayVal = Math.max(0, Math.round(rulHoursVal * 60));     displayUnit = 'MINUTES'; }
 
  const rulValEl  = document.getElementById('rul-main-val');
  const rulUnitEl = document.getElementById('rul-main-unit');
  if (rulValEl)  { rulValEl.textContent = displayVal.toLocaleString();  rulValEl.style.color = mhiCol; }
  if (rulUnitEl)   rulUnitEl.textContent = displayUnit;
 
  const bandEl = document.getElementById('rul-status-band');
  if (bandEl) {
    if (mhiVal >= 70)      { bandEl.textContent = ' MACHINE IN GOOD HEALTH';        bandEl.style.cssText = 'padding:7px 20px;border-radius:8px;font-size:0.7rem;font-weight:700;letter-spacing:1px;border:1px solid rgba(52,211,153,0.4);color:var(--green);background:rgba(52,211,153,0.08);'; }
    else if (mhiVal >= 40) { bandEl.textContent = ' SCHEDULE MAINTENANCE';          bandEl.style.cssText = 'padding:7px 20px;border-radius:8px;font-size:0.7rem;font-weight:700;letter-spacing:1px;border:1px solid rgba(251,191,36,0.45);color:var(--yellow);background:rgba(251,191,36,0.08);'; }
    else                   { bandEl.textContent = ' CRITICAL — IMMEDIATE SHUTDOWN'; bandEl.style.cssText = 'padding:7px 20px;border-radius:8px;font-size:0.7rem;font-weight:700;letter-spacing:1px;border:1px solid rgba(248,113,113,0.5);color:var(--red);background:rgba(248,113,113,0.1);animation:critGlow 1s infinite;'; }
  }
 
  const hoursEl = document.getElementById('rul-hours');
  const daysEl  = document.getElementById('rul-days');
  const basisEl = document.getElementById('rul-mhi-basis');
  if (hoursEl) hoursEl.textContent = Math.round(rulHoursVal).toLocaleString() + ' hrs';
  if (daysEl)  daysEl.textContent  = Math.round(rulDays).toLocaleString() + ' days';
  if (basisEl) { basisEl.textContent = mhiVal.toFixed(1) + '%'; basisEl.style.color = mhiCol; }
 
  const noteEl = document.getElementById('rul-note-text');
  if (noteEl) {
    if      (mhiVal >= 80) noteEl.textContent = 'All parameters within safe bounds. Machine is operating at peak health.';
    else if (mhiVal >= 60) noteEl.textContent = 'Minor stress on one or more parameters. Monitor closely — plan preventive maintenance soon.';
    else if (mhiVal >= 40) noteEl.textContent = 'Significant degradation detected. Schedule maintenance to prevent unplanned downtime.';
    else if (mhiVal >= 20) noteEl.textContent = 'CRITICAL — one or more parameters severely exceeded threshold. Immediate action required.';
    else                   noteEl.textContent = 'FAILURE IMMINENT — Machine should be shut down immediately for full inspection.';
  }
 
  // ═══════════════════════════════════════════════════════════════════════════
  //  SECTION 5 — Charts
  // ═══════════════════════════════════════════════════════════════════════════
 
  // Bar chart: update per-sensor and MHI health values
  if (rulBarChart) {
    const hiVals = [hiTemp, hiCur, hiPres, hiVib, mhiVal];
    rulBarChart.data.datasets[0].data = hiVals;
    const barCols = [
      rulHiColor(hiTemp) === '#34d399' ? 'rgba(248,113,113,0.75)'  : rulHiColor(hiTemp) === '#fbbf24' ? 'rgba(251,191,36,0.8)' : 'rgba(248,113,113,0.85)',
      rulHiColor(hiCur)  === '#34d399' ? 'rgba(251,191,36,0.75)'   : rulHiColor(hiCur)  === '#fbbf24' ? 'rgba(251,191,36,0.8)' : 'rgba(248,113,113,0.85)',
      rulHiColor(hiPres) === '#34d399' ? 'rgba(34,211,238,0.75)'   : rulHiColor(hiPres) === '#fbbf24' ? 'rgba(251,191,36,0.8)' : 'rgba(248,113,113,0.85)',
      rulHiColor(hiVib)  === '#34d399' ? 'rgba(43,144,217,0.75)'   : rulHiColor(hiVib)  === '#fbbf24' ? 'rgba(251,191,36,0.8)' : 'rgba(248,113,113,0.85)',
      mhiCol + 'cc'
    ];
    rulBarChart.data.datasets[0].backgroundColor = barCols;
    rulBarChart.update('none');
  }
 
  // History buffer: push new MHI value
  // In LIVE mode we also record the normalised RUL % so it tracks the backend model
  const rulNormPct = isLiveMode
    ? Math.max(0, Math.min(100, (rulHoursVal / RUL_MAX_HOURS) * 100))
    : +mhiVal.toFixed(1);
 
  rulHistBuf.push({ mhi: +mhiVal.toFixed(1), rul: +rulNormPct.toFixed(1) });
  if (rulHistBuf.length > RUL_HIST_MAX) rulHistBuf.shift();
 
  if (rulHistChart) {
    rulHistChart.data.datasets[0].data = rulHistBuf.map(d => d.mhi);
    rulHistChart.data.datasets[1].data = rulHistBuf.map(d => d.rul);
    rulHistChart.data.datasets[0].borderColor      = mhiCol;
    rulHistChart.data.datasets[0].backgroundColor  = mhiCol === '#34d399'
      ? 'rgba(52,211,153,0.08)' : mhiCol === '#fbbf24'
      ? 'rgba(251,191,36,0.08)' : 'rgba(248,113,113,0.08)';
    rulHistChart.update('none');
  }
 
  // Radar chart: per-sensor HI data
  if (rulRadarChart) {
    rulRadarChart.data.datasets[0].data = [hiTemp, hiCur, hiPres, hiVib];
    const rbg = mhiCol === '#34d399' ? 'rgba(52,211,153,0.14)'
              : mhiCol === '#fbbf24' ? 'rgba(251,191,36,0.14)'
              :                        'rgba(248,113,113,0.14)';
    rulRadarChart.data.datasets[0].borderColor         = mhiCol;
    rulRadarChart.data.datasets[0].backgroundColor     = rbg;
    rulRadarChart.data.datasets[0].pointBackgroundColor = mhiCol;
    rulRadarChart.update('none');
  }
}

// Initialize RUL charts on load (deferred so canvas layout is computed)
setTimeout(initRULCharts, 350);

// ═══════════════════════════════════════════════════════════════════════════
//  MONETARY ANALYSIS — Chart Initialization
//  monGapChart: Operational Load Variance (Baseline vs Live Current)
// ═══════════════════════════════════════════════════════════════════════════
let monGapChart = null;

function initMonGapChart() {
  const canvas = document.getElementById('mon-gap-chart');
  if (!canvas) return;

  // ── Seed data: 60 plausible idle-state samples ────────────────────────────
  // Electrical Load Spikes  — live kW draw vs nominal (left Y axis, kW)
  const elecSpikeData  = Array.from({ length: 60 }, () => +(18.5 + (Math.random() - 0.5) * 1.4).toFixed(2));
  // Fuel Drop Rates         — observed L/hr vs baseline (right Y axis, L/hr)
  const fuelDropData   = Array.from({ length: 60 }, () => +(3.20 + (Math.random() - 0.5) * 0.55).toFixed(3));
  const labels         = Array.from({ length: 60 }, () => '');

  // Destroy any stale instance first
  if (monGapChart) { monGapChart.destroy(); monGapChart = null; }

  monGapChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels,
      datasets: [
        // ── Dataset 0 · Electrical Load Spikes (kW) — left axis ─────────────
        {
          label: 'Electrical Load Spikes',
          data: elecSpikeData,
          yAxisID: 'yKW',
          borderColor: 'rgba(14,165,201,0.9)',
          backgroundColor: 'rgba(14,165,201,0.055)',
          borderWidth: 2,
          pointRadius: 0,
          tension: 0.35,
          fill: 'origin',
          order: 1,
        },
        // ── Dataset 1 · Fuel Drop Rates (L/hr)     — right axis ─────────────
        {
          label: 'Fuel Drop Rates',
          data: fuelDropData,
          yAxisID: 'yLhr',
          borderColor: 'rgba(249,115,22,0.75)',
          backgroundColor: 'transparent',
          borderWidth: 1.5,
          borderDash: [5, 4],
          pointRadius: 0,
          tension: 0.35,
          fill: false,
          order: 2,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      interaction: { mode: 'index', intersect: false },
      scales: {
        x: { ...ax, display: false },
        // Left Y axis — Electrical Load (kW)
        yKW: {
          ...ax,
          position: 'left',
          title: {
            display: true,
            text: 'kW',
            color: 'rgba(14,165,201,0.45)',
            font: { family: F, size: 9, weight: '700' },
          },
          grid: { color: 'rgba(43,144,217,0.06)' },
        },
        // Right Y axis — Fuel Drop Rate (L/hr)
        yLhr: {
          ...ax,
          position: 'right',
          title: {
            display: true,
            text: 'L/hr',
            color: 'rgba(249,115,22,0.45)',
            font: { family: F, size: 9, weight: '700' },
          },
          grid: { drawOnChartArea: false },
        },
      },
      plugins: {
        legend: { display: false }, // Custom HTML legend rendered below canvas
        tooltip: {
          backgroundColor: 'rgba(7,9,11,0.92)',
          borderColor: 'rgba(43,144,217,0.18)',
          borderWidth: 1,
          titleColor: '#7fafc8',
          bodyColor: '#b8c8d8',
          padding: 10,
          titleFont: { family: F, size: 10, weight: '700' },
          bodyFont: { family: F, size: 10, weight: '600' },
          callbacks: {
            label: ctx => {
              const unit = ctx.datasetIndex === 0 ? ' kW' : ' L/hr';
              return `  ${ctx.dataset.label}: ${ctx.parsed.y.toFixed(ctx.datasetIndex === 0 ? 2 : 3)}${unit}`;
            },
          },
        },
      },
    },
  });
}

// Defer until layout is computed; also re-init when navigating to monetary page
