  type:'line',
  data:{labels:hrs60(), datasets:[
    ds('Gas Level (ppm)', rnd(400,80), 'rgb(249,115,22)', true)
  ]},
  options:{
    animation:false, responsive:true, maintainAspectRatio:false,
    scales:{x:{...ax,display:false}, y:ax},
    plugins:{legend:{labels:{color:tc,font:{family:F,size:10},boxWidth:12}}}
  },
  plugins:[wsGasRefPlugin]
});
