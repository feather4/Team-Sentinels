// Deviation buffers for evolution chart (% deviation from baseline)
const aDevBufs={temp:[],vib:[],cur:[],pres:[]};
const A_BUF_MAX=60;

function dsAlt(color){
  return {data:[],borderColor:color,backgroundColor:color.replace('rgb','rgba').replace(')',',0.07)'),
  fill:false,tension:0.4,pointRadius:0,borderWidth:2};
}
const aEvoRefPlugin={
  id:'aEvoRef',
  afterDraw(chart){
    const{ctx,chartArea:{left,right,top,bottom},scales:{y}}=chart;
    [[50,'rgba(251,191,36,0.3)','WARN 50%'],[100,'rgba(248,113,113,0.3)','ALARM 100%']].forEach(([val,col,lbl])=>{
      const yp=y.getPixelForValue(val);
      if(yp<top||yp>bottom)return;
      ctx.save();ctx.beginPath();ctx.moveTo(left,yp);ctx.lineTo(right,yp);
      ctx.strokeStyle=col;ctx.lineWidth=1;ctx.setLineDash([4,5]);ctx.stroke();
      ctx.setLineDash([]);ctx.font='7px Inter,sans-serif';ctx.fillStyle=col;
      ctx.textAlign='right';ctx.fillText(lbl,right-4,yp-3);ctx.restore();
    });
  }
};
const aEvoChart=(()=>{
  const el=document.getElementById('a-evo');
  if(!el)return null;
  return new Chart(el,{
    type:'line',
    data:{
      labels:Array.from({length:A_BUF_MAX},()=>''),
      datasets:[
        dsAlt('rgb(248,113,113)'),  // TEMP
        dsAlt('rgb(167,139,250)'),  // VIB
        dsAlt('rgb(52,211,153)'),   // CURR
        dsAlt('rgb(251,191,36)'),   // PRES
      ]
    },
    options:{
      animation:false,responsive:true,maintainAspectRatio:false,
      scales:{
        x:{display:false},
        y:{
          ...ax,min:0,
          title:{display:true,text:'% deviation from baseline',color:'rgba(43,144,217,0.45)',font:{family:F,size:8}},
          ticks:{...ax.ticks,callback:v=>v+'%'}
        }
      },
      plugins:{legend:{display:false}}
    },
    plugins:[aEvoRefPlugin]
  });
})();

// Fault knowledge base for differential diagnosis
const FAULT_DIAGNOSIS={
  bearing_wear:{
    name:'BEARING WEAR',
    desc:'Progressive bearing degradation — micro-fractures causing friction heat buildup and vibration.',
    components:['Front Bearing','Rear Bearing','Shaft','Rotor'],
    pattern:'VIB spiked FIRST, TEMP followed (thermal friction lag). RPM declining slightly. Current nominal → rules out electrical fault. Cascade order: mechanical stress → friction heat → thermal expansion → accelerated wear.',
    action:'STOP motor within 4 hrs. Inspect bearing clearance & lubrication. Check for micro-pitting on races. Replace if clearance >0.05mm. Do not restart without bearing inspection.'
  },
  overload:{
    name:'MOTOR OVERLOAD',
    desc:'Motor exceeding rated torque — excessive current draw creating thermal stress on windings.',
    components:['Winding A','Winding B','Winding C','Terminal Box','Stator Core'],
    pattern:'CURR spiked FIRST, TEMP followed proportionally. VIB nominal → NOT a mechanical fault. RPM declining under load. Pure electrical signature. Driven equipment likely seized or undersized.',
    action:'Reduce mechanical load immediately. Inspect driven equipment for seizure or blockage. Verify motor rating matches load requirement. Check contactor and thermal relay settings.'
  },
  rotor_imbalance:{
    name:'ROTOR IMBALANCE',
    desc:'Asymmetric rotor mass — uneven centrifugal forces producing extreme vibration signature.',
    components:['Rotor','Shaft','Front Bearing','Rear Bearing'],
    pattern:'VIB EXTREMELY elevated (dominant signal). TEMP mildly affected. CURR and RPM near nominal. Classic mass-imbalance: centrifugal force ∝ ω² × eccentricity. Not an electrical fault.',
    action:'Schedule dynamic balancing. Check for debris on rotor or shaft bend. Motor can run briefly — monitor bearing temp closely. Avoid sustained operation above 150% vibration baseline.'
  },
  phase_loss:{
    name:'PHASE LOSS',
    desc:'Single-phase supply failure — motor running 2-phase, extreme overcurrent on remaining windings.',
    components:['Winding A','Terminal Box','Rotor'],
    pattern:'RPM dropped SEVERELY. CURR surged on remaining phases. VIB moderate (2× line freq torque ripple). TEMP rising. Electrical supply fault — not mechanical. Check incoming supply FIRST.',
    action:'EMERGENCY STOP immediately. Inspect supply, contactors, and fuses before ANY restart. Measure phase-to-phase voltages. Check winding insulation resistance. Do not restart until phase continuity confirmed.'
  },
  cooling_failure:{
    name:'COOLING FAILURE',
    desc:'Cooling system inoperative — heat cannot dissipate, temperature rising unchecked.',
    components:['Cooling Fins','Housing','Winding A','Winding B','Winding C'],
    pattern:'TEMP rising RAPIDLY. All other parameters nominal. Pure thermal isolation — no mechanical or electrical signatures. Fan blocked, belt broken, or ambient temperature anomaly. Exclusive thermal path fault.',
    action:'Reduce load to 50% immediately. Inspect cooling fan and ventilation path. Check for blocked fins or high ambient. Allow 30min thermal cool-down. Restart only after cooling restored.'
  }
};

/* 
   FAULT SIGNATURE RADAR — pure canvas polar chart
 */
function drawFaultRadar(temp,vib,rpm,cur,pres){
  const canvas=document.getElementById('a-sig-radar');
  if(!canvas)return;
  const W=canvas.offsetWidth||340,H=218;
  if(canvas.width!==W)canvas.width=W;
  canvas.height=H;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const cx=W/2,cy=H*0.48,R=Math.min(W,H)*0.36;
  const aT=getAlarmT(),aV=getAlarmV(),aC=getAlarmCur();
  // Deviation: how far from baseline relative to alarm threshold (0=baseline, 1=alarm)
  const devTemp =Math.max(0,(temp-45)/Math.max(1,aT-45));
  const devVib  =Math.max(0,(vib-0.30)/Math.max(0.01,aV-0.30));
  const devCur  =Math.max(0,(cur-4.2)/Math.max(0.1,aC-4.2));
  const devPres =Math.min(1.5,Math.abs(pres-1013)/200);
  const devs=[devTemp,devVib,devCur,devPres];
  const labels=['TEMP','VIB','CURR','PRES'];
  const N=4;
  const baseAngle=-Math.PI/2;
  const angles=Array.from({length:N},(_,i)=>baseAngle+(i/N)*Math.PI*2);
  const maxDev=Math.max(...devs);
  // Draw web rings: 25%, 50%, 75%, 100% of alarm threshold
  [1,0.75,0.5,0.25].forEach(frac=>{
    const r=R*frac;
    const isAlarm=frac===1,isWarn=frac===0.5;
    ctx.beginPath();
    angles.forEach((ang,i)=>{
      const x=cx+Math.cos(ang)*r,y=cy+Math.sin(ang)*r;
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    });
    ctx.closePath();
    ctx.strokeStyle=isAlarm?'rgba(248,113,113,0.22)':isWarn?'rgba(251,191,36,0.22)':'rgba(43,144,217,0.1)';
    ctx.lineWidth=isAlarm||isWarn?1:0.7;
    if(isAlarm||isWarn)ctx.setLineDash([3,4]);
    ctx.stroke();ctx.setLineDash([]);
    // Ring label at top
    if(isAlarm||isWarn){
      ctx.save();ctx.font='6.5px Inter,sans-serif';
      ctx.fillStyle=isAlarm?'rgba(248,113,113,0.45)':'rgba(251,191,36,0.45)';
      ctx.textAlign='center';ctx.fillText(isAlarm?'ALARM':'WARN',cx,cy-r-4);ctx.restore();
    }
  });
  // Draw axis spokes + labels
  angles.forEach((ang,i)=>{
    ctx.save();ctx.beginPath();ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(ang)*R,cy+Math.sin(ang)*R);
    ctx.strokeStyle='rgba(43,144,217,0.18)';ctx.lineWidth=0.8;ctx.stroke();ctx.restore();
    const lx=cx+Math.cos(ang)*(R+20),ly=cy+Math.sin(ang)*(R+20);
    const d=devs[i];
    ctx.save();ctx.font='bold 7.5px Inter,sans-serif';
    ctx.fillStyle=d>0.75?'#f87171':d>0.4?'#fbbf24':d>0.1?'rgba(43,144,217,0.9)':'rgba(43,144,217,0.45)';
    ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(labels[i],lx,ly);ctx.restore();
    // Dev % value near axis tip
    if(d>0.05){
      const pct=Math.round(d*100)+'%';
      const px=cx+Math.cos(ang)*Math.min(1.4,d)*R*0.82;
      const py=cy+Math.sin(ang)*Math.min(1.4,d)*R*0.82;
      ctx.save();ctx.font='bold 7px Inter,sans-serif';
      ctx.fillStyle=d>0.75?'#f87171':d>0.4?'#fbbf24':'#4da6e8';
      ctx.textAlign='center';ctx.textBaseline='middle';ctx.shadowColor=ctx.fillStyle;ctx.shadowBlur=4;
      ctx.fillText(pct,px,py);ctx.restore();
    }
  });
  // Fill polygon — current state
  const clampedDevs=devs.map(d=>Math.min(1.4,d));
  ctx.beginPath();
  angles.forEach((ang,i)=>{
    const x=cx+Math.cos(ang)*clampedDevs[i]*R,y=cy+Math.sin(ang)*clampedDevs[i]*R;
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  ctx.closePath();
  const fillCol=maxDev>0.75?'rgba(248,113,113,0.14)':maxDev>0.4?'rgba(251,191,36,0.12)':'rgba(43,144,217,0.09)';
  const strokeCol=maxDev>0.75?'rgba(248,113,113,0.85)':maxDev>0.4?'rgba(251,191,36,0.85)':'rgba(43,144,217,0.55)';
  ctx.fillStyle=fillCol;ctx.fill();
  ctx.strokeStyle=strokeCol;ctx.lineWidth=2;
  if(maxDev>0.75){ctx.shadowColor='rgba(248,113,113,0.4)';ctx.shadowBlur=10;}
  else if(maxDev>0.4){ctx.shadowColor='rgba(251,191,36,0.3)';ctx.shadowBlur=8;}
  ctx.stroke();ctx.shadowBlur=0;
  // Dot at each axis tip
  angles.forEach((ang,i)=>{
    const r2=clampedDevs[i]*R;
    if(r2<4)return;
    const x=cx+Math.cos(ang)*r2,y=cy+Math.sin(ang)*r2;
    const col=devs[i]>0.75?'#f87171':devs[i]>0.4?'#fbbf24':'#4da6e8';
    ctx.beginPath();ctx.arc(x,y,3.5,0,Math.PI*2);
    ctx.fillStyle=col;ctx.shadowColor=col;ctx.shadowBlur=8;ctx.fill();ctx.shadowBlur=0;
  });
  // Centre dot
  ctx.beginPath();ctx.arc(cx,cy,3,0,Math.PI*2);
  ctx.fillStyle='rgba(43,144,217,0.3)';ctx.fill();
}

/* 
   UPDATE ALERT CENTER — KPIs, radar, evolution, diagnosis
 */
function updateAlertCenter(r,fp,isAn,isWrn){
  const aT=getAlarmT(),aV=getAlarmV(),aC=getAlarmCur();
  // % deviation from baseline (relative to alarm threshold)
  const devTemp =Math.max(0,(r.temp-45)/Math.max(1,aT-45))*100;
  const devVib  =Math.max(0,(r.vib-0.30)/Math.max(0.01,aV-0.30))*100;
  const devCur  =Math.max(0,(r.current-4.2)/Math.max(0.1,aC-4.2))*100;
  const devPres =Math.min(150,Math.abs(r.pressure-1013)/200*100);
  const maxDev  =Math.max(devTemp,devVib,devCur,devPres);
  const paramNames=[['TEMP',devTemp],['VIB',devVib],['CURR',devCur],['PRES',devPres]];
  const worst=paramNames.reduce((a,b)=>b[1]>a[1]?b:a);

  // Push to evolution buffers
  [['temp',devTemp],['vib',devVib],['cur',devCur],['pres',devPres]].forEach(([k,v])=>{
    aDevBufs[k].push(+v.toFixed(1));
    if(aDevBufs[k].length>A_BUF_MAX)aDevBufs[k].shift();
  });
  // Update evolution chart
  if(aEvoChart){
    [aDevBufs.temp,aDevBufs.vib,aDevBufs.cur,aDevBufs.pres].forEach((buf,i)=>{
      aDevBufs[Object.keys(aDevBufs)[i]];
      aEvoChart.data.datasets[i].data=[...buf];
    });
    aEvoChart.update('none');
  }
  // Draw fault signature radar
  drawFaultRadar(r.temp,r.vib,0,r.current,r.pressure);

  //  KPI: Fault Hypothesis 
  const ft=faultType!=='none'?faultType.replace(/_/g,' ').toUpperCase():(customInjActive?'MULTI-PARAM':null);
  const hypEl=document.getElementById('a-hyp-val');
  const confEl=document.getElementById('a-hyp-conf');
  if(hypEl){
    hypEl.textContent=ft||(isAn?'ANOMALY':isWrn?'DEGRADING':'NONE');
    hypEl.style.color=isAn?'var(--red)':isWrn?'var(--yellow)':'var(--green)';
    hypEl.style.fontSize=ft&&ft.length>12?'0.62rem':'0.78rem';
  }
  if(confEl)confEl.textContent=isAn?`${fp}% model confidence`:isWrn?'degrading — watch closely':'awaiting fault signal';

  //  KPI: Cascade Stage 
  const ticks=faultOnset>=0?twinStep-faultOnset:0;
  const casEl=document.getElementById('a-cascade-val'),casSubEl=document.getElementById('a-cascade-sub');
  if(casEl){
    if(!isAn&&!isWrn){casEl.textContent='NOMINAL';casEl.style.color='var(--green)';}
    else if(isWrn||(isAn&&ticks<12)){casEl.textContent='EARLY';casEl.style.color='var(--yellow)';}
    else if(isAn&&ticks<35){casEl.textContent='BUILDING';casEl.style.color='var(--orange)';}
    else if(isAn&&ticks<70){casEl.textContent='CRITICAL';casEl.style.color='var(--red)';}
    else if(isAn){casEl.textContent='SEVERE';casEl.style.color='#ff3333';}
    if(casSubEl)casSubEl.textContent=isAn?`T+${ticks} ticks · ${fp}% conf`:isWrn?'onset detected':'all params in range';
  }

  //  KPI: Worst Deviation 
  const peakEl=document.getElementById('a-peak-dev'),peakPEl=document.getElementById('a-peak-param');
  if(peakEl){
    peakEl.textContent=`+${maxDev.toFixed(0)}%`;
    peakEl.style.color=maxDev>75?'var(--red)':maxDev>40?'var(--yellow)':'#a0c8e0';
  }
  if(peakPEl)peakPEl.textContent=`${worst[0]} leading deviation`;


  //  Diagnosis Panel 
  const d=faultType!=='none'&&FAULT_DIAGNOSIS[faultType]?FAULT_DIAGNOSIS[faultType]:null;
  const fnEl=document.getElementById('diag-fault-name'),fdEl=document.getElementById('diag-fault-desc');
  const fcEl=document.getElementById('diag-components'),fpEl=document.getElementById('diag-pattern'),faEl=document.getElementById('diag-action');
  const chipRed=c=>`<span style="font-size:0.62rem;color:#f87171;background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.25);border-radius:5px;padding:2px 8px;font-weight:700;">${c}</span>`;
  const chipYel=c=>`<span style="font-size:0.62rem;color:#fbbf24;background:rgba(251,191,36,0.07);border:1px solid rgba(251,191,36,0.22);border-radius:5px;padding:2px 8px;font-weight:700;">${c}</span>`;

  if(d&&isAn){
    if(fnEl){fnEl.textContent=d.name;fnEl.style.color='#f87171';}
    if(fdEl)fdEl.textContent=d.desc;
    if(fcEl)fcEl.innerHTML=d.components.map(chipRed).join('');
    if(fpEl)fpEl.textContent=d.pattern;
    if(faEl)faEl.textContent=d.action;
  } else if(customInjActive&&isAn){
    const mechOnly=devVib>50&&devCur<30,elecOnly=devCur>50&&devVib<30,thermalOnly=devTemp>50&&devVib<20&&devCur<20;
    const hyp=mechOnly?'MECHANICAL FAULT':elecOnly?'ELECTRICAL FAULT':thermalOnly?'COOLING FAILURE':'COMPOUND FAULT';
    if(fnEl){fnEl.textContent=hyp;fnEl.style.color='#f87171';}
    if(fdEl)fdEl.textContent='Custom injection active — cross-correlating parameter deviations to classify fault category.';
    const comps=[];
    if(devTemp>40)comps.push('Thermal Path');if(devVib>40)comps.push('Rotating Assembly');
    if(devCur>40)comps.push('Electrical Windings');if(devRpm>30)comps.push('Drive Shaft');
    if(fcEl)fcEl.innerHTML=comps.length?comps.map(chipYel).join(''):`<span style="font-size:0.64rem;color:var(--muted);font-style:italic;">Analyzing...</span>`;
    if(fpEl)fpEl.textContent=mechOnly?'VIB elevated without CURR surge → mechanical origin. Rules out: overload, phase loss.':
      elecOnly?'CURR elevated without VIB → electrical origin. Check supply, windings, insulation.':
      thermalOnly?'TEMP isolated, all others nominal → cooling path fault or ambient anomaly.':
      'Multiple parameters deviating — compound fault or rapid cascade. Prioritize highest-deviation parameter.';
    if(faEl)faEl.textContent=mechOnly?'Inspect bearings, rotor balance, shaft alignment.':
      elecOnly?'Check power supply and phase continuity. Measure winding resistance before restart.':
      thermalOnly?'Inspect cooling fan and ventilation. Reduce load to 60%.':
      'Full inspection protocol. Prioritize by deviation magnitude. Consider scheduled shutdown.';
  } else {
    if(fnEl){fnEl.textContent='— NO FAULT —';fnEl.style.color='var(--muted)';}
    if(fdEl)fdEl.textContent='Motor operating within normal parameters.';
    if(fcEl)fcEl.innerHTML='<span style="font-size:0.64rem;color:var(--muted);font-style:italic;">None identified</span>';
    if(fpEl)fpEl.textContent='Awaiting fault signal to begin differential analysis.';
    if(faEl)faEl.textContent='System normal — continue standard monitoring cycle.';
  }
}

