// Annotate 45°C danger threshold as a horizontal line via plugin
const WS_TEMP_LIMIT = 45;
const WS_GAS_LIMIT  = 800;
const wsGasRefPlugin = {
  id:'wsGasRef',
  afterDraw(chart){
    const{ctx,chartArea:{left,right},scales:{y}}=chart;
    if(!y) return;
    const yp=y.getPixelForValue(WS_GAS_LIMIT);
    ctx.save();
    ctx.setLineDash([4,4]);
    ctx.strokeStyle='rgba(239,68,68,0.55)';
    ctx.lineWidth=1.2;
    ctx.beginPath();ctx.moveTo(left,yp);ctx.lineTo(right,yp);ctx.stroke();
    ctx.fillStyle='rgba(239,68,68,0.7)';
    ctx.font='600 9px Inter';
    ctx.fillText('ALARM 800 ppm',left+4,yp-4);
    ctx.restore();
  }
};
// Gas concentration profile
