// ═══════════════════════════════════════════════════════════════════════════
//  PATCH FUNCTION — Monetary Analysis Logic (Electrical + Fuel Flap Demo)
// ═══════════════════════════════════════════════════════════════════════════

let distBuffer = [];
let lastMonTime = Date.now();
let smoothedFuelLhr = 2.5; // Smoothed fuel rate — decays toward baseline between ticks

// Helper function to animate numbers & bars safely
function setMonVal(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
function setMonBar(id, pct) { const el = document.getElementById(id); if (el) el.style.width = Math.min(100, Math.max(0, pct)) + '%'; }

// This function is automatically called every 2 seconds by liveTick()
window.patchMonetary = function(currentAmps, liveDist, backendStatus) {
    const page = document.getElementById('page-monetary');
    if (!page || page.style.display === 'none') return; // Skip heavy math if tab is hidden

    const now = Date.now();

    // ─── 1. ELECTRICAL MATH ───────────────────────────────────────
    const BASELINE_AMPS = 4.20;
    const ELEC_RATE = 9.50; // ₹/kWh
    const CO2_ELEC_FACTOR = 0.82; // kg per kWh

    const deltaAmps = Math.max(0, currentAmps - BASELINE_AMPS);
    const wastedKW = deltaAmps * 0.61;
    const elecHourlyLoss = wastedKW * ELEC_RATE;
    const elecDailyLoss = elecHourlyLoss * 24;
    const elecCO2Daily = wastedKW * 24 * CO2_ELEC_FACTOR;

    // ─── 2. FUEL MATH (With Smoothing Buffer for Cardboard Demo) ──
    const FUEL_BASELINE = 2.5; // L/hr
    const DIESEL_RATE = 92.0; // ₹/L
    const CO2_FUEL_FACTOR = 2.68; // kg per Litre of diesel
    
    let fuelLhr = smoothedFuelLhr;

    if (liveDist !== null && !isNaN(liveDist) && liveDist > 0) {
        distBuffer.push(liveDist);
        if (distBuffer.length > 5) distBuffer.shift(); // Keep last 5 readings (~10 seconds window)
        
        if (distBuffer.length > 2) {
            // Smooth calculation: Compare oldest reading in buffer with newest
            const oldestDist = distBuffer[0];
            const newestDist = distBuffer[distBuffer.length - 1];
            const dropCm = oldestDist - newestDist; 
            
            // Only calculate rate if distance actually dropped, otherwise decay back to baseline
            if (dropCm > 0.1) {
                // Formula: 1cm drop = 5 Litres. Time = (buffer items × 2 sec) → hours
                const timeInBufferHrs = (distBuffer.length * 2) / 3600; // 2 seconds per tick
                fuelLhr = (dropCm * 5.0) / timeInBufferHrs; 
            } else {
                // Slowly decay smoothedFuelLhr back toward baseline when flap is idle
                smoothedFuelLhr = smoothedFuelLhr * 0.8 + FUEL_BASELINE * 0.2;
                fuelLhr = smoothedFuelLhr;
            }
        }
    }
    
    // Clamp fuel rate for UI stability (0–20 L/hr physical ceiling)
    fuelLhr = Math.max(0, Math.min(fuelLhr, 20.0)); 
    smoothedFuelLhr = fuelLhr;

    const wastedFuelLhr = Math.max(0, fuelLhr - FUEL_BASELINE);
    const fuelHourlyLoss = wastedFuelLhr * DIESEL_RATE;
    const fuelDailyLoss = fuelHourlyLoss * 24;
    const fuelCO2Daily = wastedFuelLhr * 24 * CO2_FUEL_FACTOR;

    // ─── 3. COMBINED & ESG MATH ───────────────────────────────────
    const totalDailyLoss = elecDailyLoss;
    const totalHourlyLoss = elecHourlyLoss + fuelHourlyLoss;
    const totalMonthlyLoss = totalDailyLoss * 30;
    const totalAnnualLoss = totalDailyLoss * 365;
    const totalCO2 = elecCO2Daily + fuelCO2Daily;

    // Fuel Efficiency Index (FEI)
    let fei = 100;
    if (fuelLhr > 0) fei = Math.min(100, Math.max(0, (FUEL_BASELINE / fuelLhr) * 100));

    // Status Engine (The Demo Triggers)
    let fStatus = "NOMINAL";
    let fColor = "var(--green)";
    if (fuelLhr >= 7.0) { fStatus = "CRITICAL LEAK"; fColor = "var(--red)"; } 
    else if (fuelLhr > 3.5) { fStatus = "INEFFICIENT BURN"; fColor = "var(--yellow)"; }

    // Backend override: if status string explicitly signals a critical fuel event, escalate
    if (backendStatus && typeof backendStatus === 'string' && backendStatus.toUpperCase().includes('CRITICAL_FUEL')) {
        fStatus = "CRITICAL LEAK";
        fColor  = "var(--red)";
    }

    // ─── 4. UPDATE DOM (Push values to UI) ────────────────────────
    
    // Top KPIs
    setMonVal('mon-total-drain', '₹' + Math.round(totalDailyLoss).toLocaleString('en-IN'));
    setMonBar('mon-drain-bar', (totalDailyLoss / 5000) * 100);

    setMonVal('mon-annual-drain', '₹' + Math.round(totalAnnualLoss).toLocaleString('en-IN'));
    setMonBar('mon-annual-bar', (totalAnnualLoss / 1500000) * 100);

    setMonVal('mon-fei-val', Math.round(fei) + '%');
    setMonBar('mon-fei-bar', fei);

    setMonVal('mon-co2-total', totalCO2.toFixed(1) + ' kg');
    setMonBar('mon-co2-bar', (totalCO2 / 100) * 100);

    // Grid Column A: Electrical
    setMonVal('mon-delta-amps', '+' + deltaAmps.toFixed(2) + ' A');
    setMonVal('mon-wasted-kw', wastedKW.toFixed(3));
    setMonVal('mon-elec-loss-daily', '₹' + Math.round(elecDailyLoss).toLocaleString('en-IN'));

    // Grid Column B: Fuel
    setMonVal('mon-live-consumption', fuelLhr.toFixed(2));
    setMonVal('mon-fuel-waste', wastedFuelLhr.toFixed(2));
    
    const statusLabel = document.getElementById('mon-fuel-status-label');
    if(statusLabel) {
        statusLabel.textContent = fStatus;
        statusLabel.style.color = fColor;
    }

    // Mid Metrics
    setMonVal('mon-hourly-val', '₹' + Math.round(totalHourlyLoss).toLocaleString('en-IN'));
    setMonVal('mon-monthly-val', '₹' + Math.round(totalMonthlyLoss).toLocaleString('en-IN'));

    // ─── 5. UPDATE CHART (`monGapChart`) ──────────────────────────
    if (window.monGapChart) {
        const chart = window.monGapChart;
        const timeLabel = new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        
        chart.data.labels.push(timeLabel);
        chart.data.datasets[0].data.push(wastedKW); // Dataset 0: Elec Spikes
        chart.data.datasets[1].data.push(fuelLhr);  // Dataset 1: Fuel Drop Rate

        // Keep 60 points buffer
        if (chart.data.labels.length > 60) {
            chart.data.labels.shift();
            chart.data.datasets[0].data.shift();
            chart.data.datasets[1].data.shift();
        }
        chart.update('none');
    }

    lastMonTime = now;
};

setInterval(liveTick,2000);
liveTick();

// Live clock
setInterval(()=>{const c=document.getElementById('clock');if(c)c.textContent=new Date().toLocaleTimeString();},1000);
document.addEventListener('DOMContentLoaded',()=>{const c=document.getElementById('clock');if(c)c.textContent=new Date().toLocaleTimeString();});

