startTicker();
setTimeout(()=>engine3d.init(),150);
twinTick();
updateInjPreview();
// Initial draw with plausible idle-state values — overwritten within 2 s by liveTick()
setTimeout(()=>{ resizeOvGauges(); drawOvGauges(45, 0.3, 4.2, 1013); }, 250);

/* 
   3D DEPTH SYSTEM — Optimized Master Loop
   Single RAF drives: Particles · Cursor · (Grid is static/resize-only)
 */
(function initSG3D(){

  /*  Custom Cursor  */
  const cursorEl  = document.getElementById('sg-cursor');
  const cursorDot = document.getElementById('sg-cursor-dot');
  let mX = -200, mY = -200;
  let cX = -200, cY = -200; // lerped reticle position

  document.addEventListener('mousemove', e => {
    mX = e.clientX; mY = e.clientY;
    // Both ring and dot follow immediately — no lag
    const pos = `translate(calc(${mX}px - 50%), calc(${mY}px - 50%))`;
    cursorEl.style.transform  = pos;
    cursorDot.style.transform = pos;
  }, {passive: true});

  document.addEventListener('mousedown', e => {
    cursorDot.classList.add('cursor-click');
    // Spawn a glow ripple at the exact click position
    const ripple = document.createElement('div');
    ripple.className = 'sg-click-glow';
    ripple.style.left = e.clientX + 'px';
    ripple.style.top  = e.clientY + 'px';
    document.body.appendChild(ripple);
    ripple.addEventListener('animationend', () => ripple.remove());
  }, {passive: true});

  document.addEventListener('mouseup', () => cursorDot.classList.remove('cursor-click'), {passive: true});

  /*  1. Floating 3D Particles  */
  const pCanvas = document.createElement('canvas');
  pCanvas.id = 'sg-particles-3d';
  document.body.insertBefore(pCanvas, document.body.children[2]); // after cursor divs
  const pCtx = pCanvas.getContext('2d', {alpha:true, willReadFrequently: false});
  let pW = 0, pH = 0;

  function pResize(){
    pW = pCanvas.width  = window.innerWidth;
    pH = pCanvas.height = window.innerHeight;
  }
  pResize();

  const COLS = [
    [26,111,168],[43,144,217],[14,165,201],
    [77,166,232],[22,197,94],[150,190,210]
  ];
  // Reduced from 48 → 26 particles
  const pts = Array.from({length:26}, () => ({
    x  : Math.random() * window.innerWidth,
    y  : Math.random() * window.innerHeight,
    z  : Math.random() * 520 + 80,
    vx : (Math.random()-.5) * 0.14,
    vy : (Math.random()-.5) * 0.12,
    vz : (Math.random()-.5) * 0.38,
    col: COLS[Math.floor(Math.random()*COLS.length)]
  }));

  function proj(x,y,z){
    const fov = 520, s = fov/(fov+z);
    return { px:(x-pW/2)*s+pW/2, py:(y-pH/2)*s+pH/2, s };
  }

  /*  2. Perspective Grid Floor (static — only redraws on resize)  */
  const gCanvas = document.createElement('canvas');
  gCanvas.id = 'sg-grid-3d';
  document.body.insertBefore(gCanvas, document.body.children[2]);
  const gCtx = gCanvas.getContext('2d');

  function drawGrid(){
    const W = gCanvas.width  = window.innerWidth;
    const H = gCanvas.height = Math.round(window.innerHeight * 0.44);
    gCtx.clearRect(0,0,W,H);
    const VP_X = W/2, VP_Y = -H*0.08;
    const nH=20, nV=24;
    for(let i=1; i<=nH; i++){
      const t=i/nH, y=H*(1-Math.pow(1-t,2.4)), a=0.05+t*0.22;
      gCtx.beginPath(); gCtx.moveTo(0,y); gCtx.lineTo(W,y);
      gCtx.strokeStyle=`rgba(26,111,168,${a})`; gCtx.lineWidth=0.7; gCtx.stroke();
    }
    for(let j=0; j<=nV; j++){
      const bx=(j/nV)*W, dist=Math.abs(bx-W/2)/(W/2), a=0.04+(1-dist)*0.13;
      gCtx.beginPath(); gCtx.moveTo(VP_X,VP_Y); gCtx.lineTo(bx,H);
      gCtx.strokeStyle=`rgba(43,144,217,${a})`; gCtx.lineWidth=0.5; gCtx.stroke();
    }
    const hg=gCtx.createLinearGradient(0,0,0,H*0.18);
    hg.addColorStop(0,'rgba(26,111,168,0.09)'); hg.addColorStop(1,'transparent');
    gCtx.fillStyle=hg; gCtx.fillRect(0,0,W,H*0.18);
  }
  drawGrid();

  // Debounced resize — redraws grid + resizes particle canvas once
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { pResize(); drawGrid(); }, 120);
  }, {passive: true});

  /*  3. Mouse-tracking 3D Tilt (excluded from anatomy + inject pages)  */
  function enableTilt(selector, maxDeg, zLift){
    // Build a selector that excludes elements inside anatomy/inject pages
    document.querySelectorAll(selector).forEach(el => {
      // Skip if inside motor anatomy or fault injection pages
      if(el.closest('#page-anatomy') || el.closest('#page-inject')) return;
      el.addEventListener('mousemove', e => {
        const r  = el.getBoundingClientRect();
        const dx = (e.clientX - r.left - r.width/2)  / (r.width/2);
        const dy = (e.clientY - r.top  - r.height/2) / (r.height/2);
        const rx = -dy*maxDeg, ry = dx*maxDeg;
        const gx = 50+(dx*30), gy = 50+(dy*30);
        el.style.transform = `perspective(700px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(${zLift}px)`;
        el.style.transition = 'transform 0.07s ease-out';
        el.style.backgroundImage = `radial-gradient(circle at ${gx}% ${gy}%,rgba(255,255,255,0.04) 0%,transparent 65%)`;
      }, {passive:true});
      el.addEventListener('mouseleave', () => {
        el.style.transform='';
        el.style.transition='all 0.5s cubic-bezier(0.4,0,0.2,1)';
        el.style.backgroundImage='';
      });
    });
  }

  enableTilt('.kpi',             7, 7);
  enableTilt('.card',            5, 5);
  enableTilt('.gauge-card-wrap', 6, 5);
  enableTilt('.glass-chart-wrap',4, 3);

  /*  4. Master RAF loop — particles + cursor reticle lerp (throttled to ~30fps)  */
  const FRAME_INTERVAL = 1000 / 30; // 30 fps cap for background effects
  let lastFrameTime = 0;

  function masterLoop(now){
    requestAnimationFrame(masterLoop);
    const dt = now - lastFrameTime;
    if(dt < FRAME_INTERVAL) return; // throttle
    lastFrameTime = now - (dt % FRAME_INTERVAL);

    // Particles
    pCtx.clearRect(0, 0, pW, pH);
    for(let i = 0; i < pts.length; i++){
      const p = pts[i];
      p.x += p.vx; p.y += p.vy; p.z += p.vz;
      if(p.x < 0) p.x = pW; else if(p.x > pW) p.x = 0;
      if(p.y < 0) p.y = pH; else if(p.y > pH) p.y = 0;
      if(p.z < 80) p.z = 600; else if(p.z > 600) p.z = 80;
      const {px, py, s} = proj(p.x, p.y, p.z);
      const r = Math.max(0.3, s * 2.1);
      const a = s * 0.45;
      const [cr,cg,cb] = p.col;
      pCtx.beginPath();
      pCtx.arc(px, py, r, 0, Math.PI*2);
      pCtx.fillStyle = `rgba(${cr},${cg},${cb},${a})`;
      pCtx.fill();
    }
  }
  requestAnimationFrame(masterLoop);

})();

</script>
</body>
</html>
