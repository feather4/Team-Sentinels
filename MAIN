const PAGES={
  overview:  ['Parameter Overview','Live furnace telemetry · Speedometer HUDs · Full system health at a glance'],
  sensors:   ['Live Sensor Data','All 6 sensor streams from ESP32'],
  alerts:    ['Alert Center','Anomaly events & notifications'],
  history:   ['Historical Trends','24-hour analysis & patterns'],
  twin:      ['Motor Digital Twin','Real-time simulation · Arc gauges · JARVIS engine'],
  anatomy:   ['Excavator Anatomy','3D view · Top-down plan · Side profile · Component health map'],
  inject:    ['Fault Injection','Inject faults · Observe sensor response · Anatomy highlights'],
  rul:       ['RUL Analysis','Remaining Useful Life · Health Indices · Master Health Index · Prognostics'],
  monetary:  ['Operational Economic Analysis','Dhanbad Grid Rates · ₹9.50/kWh · Load deviation economics · Cost-of-downtime modelling'],
  about:     ['About the Project','How it works · Sensors · AI · Tech Stack'],
  system:    ['System Information','Hardware, software & network'],
};

function goPage(name,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const pg=document.getElementById('page-'+name);
  if(pg) pg.classList.add('active');
  if(el) el.classList.add('active');
  const info=PAGES[name]||[name,''];
  document.getElementById('pageTitle').textContent=info[0];
  document.getElementById('pageSub').textContent=info[1];
  // Resize canvases when switching to twin pages
  if(name==='twin'){setTimeout(()=>{resizeGaugeCanvases();resizeTwinChartCanvases();drawTwinChart();},60);}
  if(name==='overview'){setTimeout(()=>{ resizeOvGauges(); if(!customInjActive&&twinMode==='normal'){drawOvGauges(45,0.3,4.2,1013);}else if(typeof lastTwinReading!=='undefined'&&lastTwinReading){drawOvGauges(lastTwinReading.temp,lastTwinReading.vib,lastTwinReading.current,lastTwinReading.pressure||1013);}else{drawOvGauges(45,0.3,4.2,1013);}},80);}
  if(name==='anatomy'){setTimeout(()=>{resizeAnatomyCanvases();if(engine3d&&engine3d.resize)engine3d.resize();},60);}
  if(name==='rul'){setTimeout(()=>{initRULCharts();updateRULPage();},80);}
  if(name==='monetary'){setTimeout(initMonGapChart,120);}
}

/* 
   CHART.JS HELPERS
 */
const F='Inter';
const gc='rgba(43,144,217,0.08)';
const tc='#7c6fa0';
const ax={ticks:{color:tc,font:{family:F,size:10,weight:'600'}},grid:{color:gc}};

function mkLine(id,dsets,labels=[]){
  return new Chart(document.getElementById(id),{
    type:'line',data:{labels,datasets:dsets},
    options:{responsive:true,maintainAspectRatio:false,animation:false,
      scales:{x:{...ax,display:labels.length>0},y:ax},
      plugins:{legend:{labels:{color:tc,font:{family:F,size:10,weight:'600'},boxWidth:12,padding:12}}}}
  });
}
function ds(label,data,color,fill=false,stepped=false){
  const c=color;
  return{label,data,borderColor:c,
    backgroundColor:fill?c.replace('rgb','rgba').replace(')',',0.12)'):'transparent',
    fill,tension:stepped?0:0.4,stepped:stepped?'before':false,
    pointRadius:0,borderWidth:2};
}
function rnd(b,n,c=60){return Array.from({length:c},()=>+(b+(Math.random()-.5)*n*2).toFixed(2));}
function hrs60(){return Array.from({length:60},()=>'');}
function h24(){return Array.from({length:24},(_,i)=>`${String(i).padStart(2,'0')}:00`);}
// pushC: push val to dataset di, only push a label when di===0 to keep all datasets in sync
function pushCFix(chart,val,di,max=60){
  chart.data.datasets[di].data.push(val);
  if(di===0)chart.data.labels.push('');
  const d=chart.data.datasets[di].data;
  if(d.length>max){d.shift();if(di===0)chart.data.labels.shift();}
}
/* 
   CHART.JS INITS — PAGE 1 (OVERVIEW)
 */
